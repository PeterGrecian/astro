#!/usr/bin/env python3
"""mark-moon-net — turn splay p-probes into a moon-net thread.

The hand-marking workflow is: open a night's frames in splay, press `p`
on the moon in each frame. Every `p` appends a line to
~/.splay-probes.log (native full-res coords, tagged RES=WxH — see splay's
p-probe). This tool ingests those probe lines for one camera+night and
writes them as a proper thread in that camera's moon-net.json:

  * matches each probe to a frame of THIS camera+night (by resolved path),
  * derives the frame's UTC (EXIF for day JPEGs, epoch_ms for night FITS),
  * computes moon az/alt at that UTC from location.json,
  * rescales any probe whose RES tag != the camera's capture_full_res
    (defends against pre-fix half-scale probes),
  * writes/updates the thread, deduped by frame — idempotent, so you can
    re-run after marking a few more.

EVERY probe is accounted for in the summary: accepted / duplicate /
skipped (and why). Nothing is silently dropped.

After marking >=3 points, seed the auto-tracker: `moon-track --append`.

Usage:
    mark-moon-net --camera eclipticam-v1 --night 2026-06-25 --mode day
    mark-moon-net --camera eclipticam-v3w --night 2026-06-24 --mode night \\
        --dec -19.1 --phase 78
    # sun sightings (daytime, v1 ND filter) -> sun-net.json:
    mark-moon-net --camera eclipticam-v1 --night 2026-07-04 --body sun --mode day

--body {moon,sun} picks both the ephemeris body and the target net file
(moon-net.json / sun-net.json). Threads are keyed by capture-night and
coordinate space (day-JPEG vs night-FITS), so nights and spaces never mix.
"""
from __future__ import annotations

import argparse
import datetime
import json
import re
import sys
from pathlib import Path

import numpy as np

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
from astro.config import CameraConfig
from astro.nightdir import night_of


# Frame-time + moon az/alt — same conventions as bin/moon-track, so
# hand-marked and auto points share one time + coordinate basis.
def _frame_dt(path, mode):
    if mode == "day":
        from PIL import Image
        from PIL.ExifTags import TAGS
        try:
            ex = Image.open(path)._getexif() or {}
        except (FileNotFoundError, OSError):
            return None
        s = {TAGS.get(k): v for k, v in ex.items()}.get("DateTimeOriginal")
        return (datetime.datetime.strptime(s, "%Y:%m:%d %H:%M:%S")
                if s else None)
    # night FITS: epoch_ms filename
    try:
        ms = int(Path(path).name.split(".")[0])
        return datetime.datetime.fromtimestamp(
            ms / 1000, datetime.timezone.utc).replace(tzinfo=None)
    except ValueError:
        return None


def _body_azalt(obs, dt, body="moon"):
    """(az, alt) in degrees for the sun or moon at UTC `dt`."""
    import ephem
    obs.date = dt
    b = ephem.Sun(obs) if body == "sun" else ephem.Moon(obs)
    return (float(b.az) * 180 / np.pi, float(b.alt) * 180 / np.pi)


def _read_crop_exif(path):
    """If `path` is a moon-extract crop with our EXIF, return a dict:
    {origin:[x0,y0], scale, src, src_ms, camera, mode}. Else None. The
    UserComment carries the crop geometry; DateTimeOriginal the capture UTC.
    Best-effort — never raises."""
    from PIL import Image
    import datetime as _d
    try:
        ex = Image.open(path)._getexif() or {}
    except Exception:
        return None
    uc = ex.get(0x9286)   # UserComment
    if isinstance(uc, bytes):
        uc = uc.decode("utf-8", "ignore")
    if not uc or "origin" not in str(uc):
        return None
    try:
        meta = json.loads(uc)
    except (json.JSONDecodeError, TypeError):
        return None
    dto = ex.get(0x9003)  # DateTimeOriginal -> epoch ms for src_ms
    if dto:
        try:
            t = _d.datetime.strptime(dto, "%Y:%m:%d %H:%M:%S")
            meta["src_ms"] = int(t.replace(
                tzinfo=_d.timezone.utc).timestamp() * 1000)
        except ValueError:
            pass
    return meta


PROBE_RE = re.compile(
    r"PROBE\s+(?P<path>\S+)\s+(?P<x>\d+)\s+(?P<y>\d+)"
    r"(?:\s+RES=(?P<rw>\d+)x(?P<rh>\d+))?"
    r"(?:\s+CAP=(?P<cap>\S+))?")
# The log line is prefixed with the probe's wall-clock ISO time.
LINE_TS_RE = re.compile(r"^(?P<ts>\d{4}-\d\d-\d\dT\d\d:\d\d:\d\d)\s")
# moon-extract crop filenames: moon_<epoch_ms>_x<X0>_y<Y0>.jpg
CROP_RE = re.compile(r"moon_(?P<ms>\d+)_x(?P<x0>\d+)_y(?P<y0>\d+)\.")


def main():
    ap = argparse.ArgumentParser(description=__doc__.split("\n", 1)[0])
    ap.add_argument("--camera", required=True)
    ap.add_argument("--night", required=True)
    ap.add_argument("--body", choices=("moon", "sun"), default="moon",
                    help="which body traces the thread. 'moon' -> moon-net.json "
                         "(default); 'sun' -> sun-net.json (daytime; use with "
                         "--mode day and the v1 ND filter). Az/alt are computed "
                         "for the chosen body.")
    ap.add_argument("--mode", choices=("day", "night"), default="day")
    ap.add_argument("--log", type=Path,
                    default=Path.home() / ".splay-probes.log")
    ap.add_argument("--since", default=None,
                    help="only probes logged at/after this ISO time "
                         "(e.g. 2026-07-01T10:00) — filters out stray older "
                         "marks that happen to match the same night")
    ap.add_argument("--require-res", action="store_true",
                    help="only accept probes carrying a RES= tag (i.e. taken "
                         "after the splay full-res p-probe fix) — rejects "
                         "old possibly-half-scale marks")
    ap.add_argument("--dec", type=float, default=None,
                    help="thread declination (deg), for the net metadata")
    ap.add_argument("--phase", type=int, default=None,
                    help="moon illuminated fraction (%%), metadata only")
    ap.add_argument("--net", type=Path, default=None)
    ap.add_argument("--replace", action="store_true",
                    help="replace the thread's points entirely (default: merge "
                         "+ dedup by frame, so day/night points accumulate)")
    ap.add_argument("--no-render", action="store_true",
                    help="don't re-render moon-net.png after writing "
                         "(default: re-render so the cumulative view stays "
                         "current on every ingest)")
    ap.add_argument("--dry-run", action="store_true",
                    help="show what would be written, change nothing")
    args = ap.parse_args()

    import ephem

    cfg = CameraConfig.load(args.camera)
    subcam = args.camera.rsplit("-", 1)[-1]
    fullW, fullH = cfg.resolution  # native full-res for THIS camera
    # v3w day frames are full-sensor 4608x2592 even though camera.json
    # resolution (the binned night mode) is 2304x1296 — prefer the net's
    # declared capture_full_res when present.
    net_file = "sun-net.json" if args.body == "sun" else "moon-net.json"
    net_path = args.net or (Path(__file__).resolve().parent.parent
                            / args.camera / net_file)
    net = (json.loads(net_path.read_text()) if net_path.exists()
           else {"_comment": f"{args.body}-net for {args.camera}",
                 "capture_full_res": [fullW, fullH], "threads": []})
    fullW, fullH = net.get("capture_full_res", [fullW, fullH])

    loc_path = (Path(__file__).resolve().parent.parent / args.camera
                / "location.json")
    loc = json.loads(loc_path.read_text())
    obs = ephem.Observer()
    obs.lat = str(loc["lat_deg"]); obs.lon = str(loc["lon_deg"])
    obs.elevation = loc.get("height_m", 0); obs.pressure = 0

    if not args.log.exists():
        sys.stderr.write(f"no probe log at {args.log}\n")
        return 2

    # A probe belongs to this camera+night when its resolved path sits under
    # <mode>/<night>/<subcam>/. Probe paths in the log vary (dayframes/, tmp/,
    # eclipticam-frames/) so we match on the /<subcam>/ tail, not a fixed root.
    tail = f"/{subcam}/"
    accepted, dup, skipped = [], [], []
    seen_frames = set()
    for line in args.log.read_text().splitlines():
        m = PROBE_RE.search(line)
        if not m:
            continue
        p = m.group("path")
        # moon-extract crop? filename moon_<epoch_ms>_x<X0>_y<Y0>.jpg — the
        # probe coords are crop-local; recover full-frame by adding the origin.
        # Crops live in an OUTPUT dir (no /<subcam>/ tail), and carry their own
        # identity (the source frame's epoch_ms), so this check comes BEFORE the
        # subcam-tail filter. Crops are DEBAYERED HALF-RES (2304x1296 v3w);
        # origin+coord are half-res, scaled to full-res below. Time = the ms.
        crop_meta = _read_crop_exif(p)          # EXIF: {origin, scale, src, ...}
        crop_m = CROP_RE.search(Path(p).name)   # fallback: filename encoding
        crop_origin = crop_scale = crop_ms = None
        if crop_meta is not None:
            crop_origin = tuple(crop_meta["origin"])
            crop_scale = crop_meta.get("scale", 2.0)
            crop_ms = crop_meta.get("src_ms")   # set from DateTimeOriginal path
            frame_id = crop_meta.get("src") or Path(p).name
        elif crop_m:
            crop_origin = (int(crop_m.group("x0")), int(crop_m.group("y0")))
            crop_scale = 2.0                     # filename-only: assume half-res
            crop_ms = crop_m.group("ms")
            frame_id = crop_ms
        elif tail not in p:
            continue
        else:
            # normal frame: frame_id = everything after /<subcam>/
            frame_id = p.split(tail, 1)[1]
        rw, rh = m.group("rw"), m.group("rh")
        # --since: skip probes logged before the given wall-clock time.
        if args.since:
            tsm = LINE_TS_RE.match(line)
            if tsm and tsm.group("ts") < args.since:
                skipped.append((frame_id, f"before --since {args.since}"))
                continue
        # --require-res: skip untagged (pre-fix, possibly half-scale) probes.
        if args.require_res and not rw:
            skipped.append((frame_id, "no RES tag (--require-res)"))
            continue
        # Capture time: prefer the CAP= tag splay wrote at probe time (works
        # even after the frame is deleted), else fall back to reading the
        # frame's EXIF/epoch_ms.
        cap = m.group("cap")
        dt = None
        if crop_origin is not None and crop_ms is not None:
            # crop of a night FITS: time is the source frame's epoch_ms
            # (from EXIF DateTimeOriginal, or the filename ms fallback).
            try:
                dt = datetime.datetime.fromtimestamp(
                    int(crop_ms) / 1000,
                    datetime.timezone.utc).replace(tzinfo=None)
            except (ValueError, OverflowError):
                dt = None
        if dt is None and cap:
            try:
                dt = datetime.datetime.fromisoformat(cap)
            except ValueError:
                dt = None
        if dt is None:
            dt = _frame_dt(p, args.mode)
        if dt is None:
            skipped.append((frame_id, "no timestamp (no CAP tag, "
                            "frame missing/no EXIF)"))
            continue
        # Night guard: a point belongs to --night only if its OWN capture time
        # falls in that noon-rollover night. Normal frames are already filtered
        # by the /<subcam>/<night>/ path tail, but crop probes (moon-extract
        # JPEGs) bypass that filter — they match by EXIF/filename regardless of
        # which night they came from. Without this guard, a --night run swept in
        # every crop ever probed in ~/.splay-probes.log, mixing 5+ nights (each
        # a different moon declination) into one thread — the "wrong cyan line".
        pt_night = night_of(dt.replace(tzinfo=datetime.timezone.utc))
        if pt_night != args.night:
            skipped.append((frame_id, f"night {pt_night} != --night {args.night}"))
            continue
        x, y = int(m.group("x")), int(m.group("y"))
        note = None
        if crop_origin is not None:
            # crop-local -> full-res. (origin + click) are in the crop's own
            # pixel space (debayered half-res for v3w night); crop_scale maps
            # that to full-res (2.0 for half-res crops; from EXIF when present).
            x = int(round((crop_origin[0] + x) * crop_scale))
            y = int(round((crop_origin[1] + y) * crop_scale))
            note = (f"crop origin {crop_origin} +click x{crop_scale:g} "
                    f"({'EXIF' if crop_meta else 'filename'})")
        # Rescale to full-res if the probe carried a RES tag that disagrees
        # (old half-scale probes taken before the splay p-probe fix).
        elif rw and (int(rw), int(rh)) != (fullW, fullH):
            sx, sy = fullW / int(rw), fullH / int(rh)
            x, y = int(round(x * sx)), int(round(y * sy))
            note = f"rescaled from {rw}x{rh}"
        elif not rw:
            note = "no RES tag (assumed full-res — verify zoom was 1x)"
        a, alt = _body_azalt(obs, dt, args.body)
        rec = {"frame": frame_id, "utc": dt.isoformat(),
               "x": x, "y": y, "az": round(a, 2), "alt": round(alt, 2)}
        if note:
            rec["mark_note"] = note
        # Coordinate space: crop probes come from the night FITS (raw Bayer
        # readout), whose pixel space is offset from the day JPEG (ISP-processed
        # path) by an un-calibrated ~(+470,+85)px shift plus a small roll —
        # measured on 2026-06-25 where day and night points overlap in azimuth.
        # NOT a flip: the moon tracks the same left-to-right direction in both,
        # so it's an offset/scale, not a mirror. Likely a differing ScalerCrop /
        # sensor mode between the day and night picamera2 configs. Until that
        # transform is pinned, night-space points must NOT share a thread with
        # day-space points, or the polyline jumps between the two frames. Tag
        # the space so upsert routes them apart.
        rec["_space"] = "night" if crop_origin is not None else "day"
        if frame_id in seen_frames:
            dup.append((frame_id, "duplicate probe (kept last)"))
            # keep the latest probe for a frame
            accepted = [r for r in accepted if r["frame"] != frame_id]
        seen_frames.add(frame_id)
        accepted.append(rec)

    accepted.sort(key=lambda r: r["utc"])

    print(f"camera {args.camera}  night {args.night}  mode {args.mode}  "
          f"full-res {fullW}x{fullH}")
    print(f"probe log: {args.log}")
    print(f"  {len(accepted)} points accepted, {len(dup)} duplicates "
          f"collapsed, {len(skipped)} skipped")
    for r in accepted:
        n = f"   [{r['mark_note']}]" if "mark_note" in r else ""
        print(f"    {r['frame']:14} {r['utc'][11:19]}  ({r['x']:5},{r['y']:5})"
              f"  az={r['az']:6.1f} alt={r['alt']:5.1f}{n}")
    for f, why in skipped:
        print(f"    SKIP {f}: {why}")

    if len(accepted) < 3:
        sys.stderr.write("\n<3 usable points — mark more before this thread "
                         "is useful for a fit\n")

    if args.dry_run:
        print("\n[dry-run] nothing written")
        return 0
    if not accepted:
        return 1

    # Upsert per COORDINATE SPACE. Day-JPEG points and night-FITS (crop) points
    # live in different pixel spaces (see the _space tag above), so each goes
    # into its own thread: "<night>" for day, "<night>-night" for night. This
    # keeps every polyline within a single coordinate frame — no cross-space
    # jumps. moon-overlay draws both as independent threads.
    def _thread_name(space):
        return args.night if space == "day" else f"{args.night}-night"

    spaces = sorted({r["_space"] for r in accepted})
    summaries = []
    for space in spaces:
        tname = _thread_name(space)
        space_pts = [r for r in accepted if r["_space"] == space]
        for r in space_pts:
            r.pop("_space", None)
        thread = next((t for t in net["threads"] if t["night"] == tname), None)
        if thread is None:
            thread = {"night": tname}
            net["threads"].append(thread)
        if args.dec is not None:
            thread["dec_deg"] = args.dec
        if args.phase is not None:
            thread["phase_pct"] = args.phase
        # MERGE (append + dedup by frame), don't replace — so a re-run, or new
        # points added to an existing thread, accumulate instead of wiping it.
        # New points win on a frame collision. --replace forces the old wipe.
        if args.replace:
            merged = space_pts
        else:
            new_frames = {r["frame"] for r in space_pts}
            kept = [p for p in thread.get("points", [])
                    if p["frame"] not in new_frames]
            merged = kept + space_pts
            merged.sort(key=lambda r: r["utc"])
        thread["points"] = merged
        summaries.append((tname, len(merged), len(space_pts)))
    net["threads"].sort(key=lambda t: t["night"])
    net_path.write_text(json.dumps(net, indent=2) + "\n")
    for tname, total, added in summaries:
        print(f"\n{tname} thread now {total} points "
              f"({'replaced' if args.replace else f'+{added} merged'}) "
              f"in {net_path}")

    # Keep the cumulative render fresh: re-draw moon-net.png whenever the net
    # changes (--no-render to skip). moon-overlay auto-finds a backdrop.
    if not args.no_render:
        import subprocess
        overlay = Path(__file__).resolve().parent / "moon-overlay"
        out_png = net_path.with_suffix(".png")
        r = subprocess.run(
            [sys.executable, str(overlay), "--camera", args.camera,
             "--net", str(net_path), "--out", str(out_png), "--extend"],
            capture_output=True, text=True)
        line = (r.stdout.strip().splitlines() or [""])[-1]
        print(f"render: {line}" if r.returncode == 0
              else f"render skipped ({r.stderr.strip().splitlines()[-1:] or ['?'][0]})")
    return 0


if __name__ == "__main__":
    sys.exit(main())
