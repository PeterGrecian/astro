#!/usr/bin/env python3
"""fit-geometry — joint fit of pole + radial distortion (k1, k2).

Omega (sidereal rotation rate × frame interval) is known to 1 part
in 10^6 from physics (sidereal day, 3-s exposure cadence), so we
PIN it and only fit 4 free parameters:
    pole_x, pole_y, k1, k2

Distortion model: each pixel (x, y) is mapped to undistorted (x', y')
relative to the image centre (cx, cy) via:
    r  = hypot(x - cx, y - cy) / R     # normalised radius, R = half-diag
    s  = 1 + k1*r^2 + k2*r^4
    x' = cx + (x - cx) * s
    y' = cy + (y - cy) * s

The derotation is applied in undistorted space. Output pixels are
sampled from the input frame at the distorted positions corresponding
to the rotated undistorted coordinates.

Optimisation: Nelder-Mead in 4D from --pole-x/--pole-y seed,
k1=0, k2=0 (no distortion to start). Converges in tens of
evaluations.

Usage:
    fit-geometry <dir> --pole-x 905.5 --pole-y 50.4
    fit-geometry <dir> --frames 200 --top 15 --refine-only
"""
from __future__ import annotations

import argparse
import csv
import sys
from pathlib import Path

import cv2
import numpy as np
from astropy.io import fits
from scipy.optimize import minimize


def load_frame(path: Path) -> tuple[np.ndarray, int | None]:
    """Return (image, epoch_ms or None) — EPOCH_MS carried through binning."""
    with fits.open(path, memmap=True) as h:
        for hdu in h:
            if hdu.data is not None and hdu.data.ndim == 2:
                ep = hdu.header.get("EPOCH_MS")
                return hdu.data, int(ep) if ep is not None else None
    raise SystemExit(f"no 2D image in {path}")


def angles_from_epochs(epochs_ms: list[int | None], omega_per_frame: float,
                       nominal_dt_ms: int = 3000) -> list[float]:
    """Per-frame derotation angle in degrees. Time-based via EPOCH_MS
    deltas when available (handles network/IO cadence jitter that
    breaks frame-index × omega over long baselines). Falls back to
    frame index if any epoch is missing."""
    if any(e is None for e in epochs_ms):
        return [float(np.degrees(i * omega_per_frame))
                for i in range(len(epochs_ms))]
    e0 = epochs_ms[0]
    return [float(np.degrees(((e - e0) / nominal_dt_ms) * omega_per_frame))
            for e in epochs_ms]


def top_cells_with_peak(csv_path: Path, n: int):
    sums = {}
    first_peak = {}
    with open(csv_path) as f:
        r = csv.DictReader(f)
        for row in r:
            k = (int(row["cell_x"]), int(row["cell_y"]))
            sums[k] = sums.get(k, 0) + int(row["peak_value"])
            if k not in first_peak:
                first_peak[k] = (int(row["peak_x"]), int(row["peak_y"]))
    ranked = sorted(sums.items(), key=lambda kv: -kv[1])[:n]
    return [(cx, cy, *first_peak[(cx, cy)]) for (cx, cy), _ in ranked]


def build_patch_grid(patch_centres: list[tuple[int, int]],
                     patch: int,
                     w: int, h: int) -> np.ndarray:
    """Return (N, patch, patch, 2) array of (x, y) output-pixel coords for
    each patch. N patches, each holds the absolute (x, y) of its pixels
    in the *output* (derotated) image."""
    half = patch // 2
    out = np.zeros((len(patch_centres), patch, patch, 2), dtype=np.float32)
    for i, (px, py) in enumerate(patch_centres):
        x0 = px - half
        y0 = py - half
        ys_g, xs_g = np.indices((patch, patch), dtype=np.float32)
        out[i, :, :, 0] = xs_g + x0
        out[i, :, :, 1] = ys_g + y0
    return out


def patch_sample_maps(grid: np.ndarray, pole: tuple[float, float],
                      angle_deg: float, k1: float, k2: float,
                      w: int, h: int
                      ) -> tuple[np.ndarray, np.ndarray]:
    """For an (N, patch, patch, 2) grid of output-pixel coords, compute
    the corresponding source-frame sample coords given pole, angle, and
    distortion. Returns (xs, ys) each shaped (N*patch, patch) suitable
    for cv2.remap.
    """
    cx, cy = w / 2.0, h / 2.0
    R = np.hypot(cx, cy)

    # Output pixel → undistorted output: same forward map.
    dx = grid[..., 0] - cx
    dy = grid[..., 1] - cy
    rn = np.hypot(dx, dy) / R
    s = 1.0 + k1 * rn**2 + k2 * rn**4
    xu = cx + dx * s
    yu = cy + dy * s

    # Rotate undistorted coords about pole by angle_deg (CCW image).
    rad = np.deg2rad(angle_deg)
    c, ss = np.cos(rad), np.sin(rad)
    dxp = xu - pole[0]
    dyp = yu - pole[1]
    xur = pole[0] + c * dxp - ss * dyp
    yur = pole[1] + ss * dxp + c * dyp

    # Re-distort (same forward map, applied to inverse direction).
    dxr = xur - cx
    dyr = yur - cy
    rnr = np.hypot(dxr, dyr) / R
    sr = 1.0 + k1 * rnr**2 + k2 * rnr**4
    inv = 1.0 / sr
    xs_arr = cx + dxr * inv
    ys_arr = cy + dyr * inv

    # Stack patches vertically so a single remap call samples all of them.
    N, P, _ = xs_arr.shape
    return (xs_arr.reshape(N * P, P).astype(np.float32),
            ys_arr.reshape(N * P, P).astype(np.float32))


def score_geom(params, imgs, cells, patch, angles_deg):
    """Per-patch only. For each frame, sample just the N patches' worth
    of pixels (N*patch² total) rather than the whole frame. Then sum
    across frames, score peak/mean per patch.

    angles_deg is precomputed per frame (handles cadence jitter via
    EPOCH_MS deltas — see angles_from_epochs)."""
    pole_x, pole_y, k1, k2 = params
    if abs(k1) > 0.5 or abs(k2) > 0.5:
        return 1e9
    h, w = imgs[0].shape
    half = patch // 2
    patch_centres = [(px, py) for (_, _, px, py) in cells]
    grid = build_patch_grid(patch_centres, patch, w, h)
    N = len(patch_centres)
    acc = np.zeros((N * patch, patch), dtype=np.float32)
    for ang, img in zip(angles_deg, imgs):
        xs_map, ys_map = patch_sample_maps(grid, (pole_x, pole_y),
                                           ang, k1, k2, w, h)
        sampled = cv2.remap(img, xs_map, ys_map,
                            interpolation=cv2.INTER_LINEAR,
                            borderMode=cv2.BORDER_CONSTANT, borderValue=0)
        acc += sampled
    score = 0.0
    for n in range(N):
        p = acc[n * patch:(n + 1) * patch, :]
        m = float(p.mean())
        if m <= 0:
            continue
        score += float(p.max()) / m
    return -score  # minimise


def main() -> int:
    ap = argparse.ArgumentParser(
        description=__doc__.split("\n", 1)[0],
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    ap.add_argument("dir", type=Path)
    ap.add_argument("--candidates", type=Path, default=None)
    ap.add_argument("--pole-x", type=float, default=905.5)
    ap.add_argument("--pole-y", type=float, default=50.4)
    ap.add_argument("--omega", type=float, default=-0.000219)
    ap.add_argument("--k1", type=float, default=0.0)
    ap.add_argument("--k2", type=float, default=0.0)
    ap.add_argument("--frames", type=int, default=200,
                    help="frames to derot per score (more = slower but more precise)")
    ap.add_argument("--top", type=int, default=15,
                    help="top-N candidate cells")
    ap.add_argument("--patch", type=int, default=50)
    args = ap.parse_args()

    cand_csv = args.candidates or (args.dir / "candidates.csv")
    cells = top_cells_with_peak(cand_csv, args.top)
    fns = sorted(args.dir.glob("*.fits.fz"))
    fns = [f for f in fns
           if f.name not in ("sum.fits.fz", "motion.fits.fz")
           and not f.name.startswith(("stack", "hot-pixels"))]
    fns = fns[:args.frames]
    print(f"loading {len(fns)} frames; {len(cells)} cells")
    loaded = [load_frame(fn) for fn in fns]
    imgs = [d.astype(np.float32) for d, _ in loaded]
    epochs = [e for _, e in loaded]
    angles_deg = angles_from_epochs(epochs, args.omega)
    if any(e is None for e in epochs):
        print("  warn: some frames lack EPOCH_MS — falling back to "
              "frame-index time model")

    x0 = [args.pole_x, args.pole_y, args.k1, args.k2]
    s0 = -score_geom(x0, imgs, cells, args.patch, angles_deg)
    print(f"seed: pole=({x0[0]:.1f},{x0[1]:.1f}) "
          f"k1={x0[2]:.4f} k2={x0[3]:.4f} (omega pinned at {args.omega:.7f}) "
          f"→ score={s0:.2f}")

    # Nelder-Mead with parameter scales (initial simplex size).
    res = minimize(score_geom, x0=x0, method="Nelder-Mead",
                   args=(imgs, cells, args.patch, angles_deg),
                   options={"xatol": 1e-4, "fatol": 0.01, "maxiter": 400,
                            "disp": True,
                            "initial_simplex": np.array([
                                x0,
                                [x0[0]+10, x0[1],    x0[2],     x0[3]],
                                [x0[0],    x0[1]+10, x0[2],     x0[3]],
                                [x0[0],    x0[1],    x0[2]+0.02,x0[3]],
                                [x0[0],    x0[1],    x0[2],     x0[3]+0.02],
                            ])})
    final = res.x
    score = -float(res.fun)
    print(f"\nfit:  pole=({final[0]:.2f},{final[1]:.2f}) "
          f"k1={final[2]:.5f} k2={final[3]:.5f} "
          f"→ score={score:.2f}")
    print(f"\nrecommended --pole-x {final[0]:.2f} --pole-y {final[1]:.2f} "
          f"--omega {args.omega:.7f} --k1 {final[2]:.5f} --k2 {final[3]:.5f}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
