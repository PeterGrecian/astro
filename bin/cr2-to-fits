#!/usr/bin/env python3
"""cr2-to-fits — convert Canon CR2 raw frames to compressed FITS (.fits.fz),
matching the astrocam pipeline format so EOS data joins the same toolchain
(stacking, badpixel.fits, plate-solving, brightness tools).

Stores the RAW BAYER plane (undemosaiced, linear 14-bit) as a RICE-compressed
CompImageHDU — exactly like astrocam/capture.py's write_fits(). Demosaic happens
later in processing, not here (keeps it linear and small, and pipeline-native).

NB on size (measured 2026-07-23): CR2 is already losslessly compressed by Canon,
so .fits.fz comes out ~30% LARGER, not smaller. Convert for pipeline
compatibility, not storage — keep the CR2s as the stored form and convert on
demand when building a stack.

Needs rawpy (installed on muppet: pip install --user --break-system-packages rawpy)
and astropy. Reads EXIF exposure/ISO from the CR2 for the FITS headers.

  cr2-to-fits FRAME.CR2 [FRAME2.CR2 ...]        -> FRAME.fits.fz alongside
  cr2-to-fits --out DIR *.CR2                    -> into DIR
  cr2-to-fits --stack out.fits.fz *.CR2          -> coadd (sum) into one FITS
"""
import argparse, os, sys, datetime
import numpy as np

def read_cr2(path):
    import rawpy
    r = rawpy.imread(path)
    bayer = r.raw_image_visible.astype(np.uint16)   # linear, undemosaiced
    # bayer pattern label
    pat = r.raw_pattern
    desc = r.color_desc.decode() if isinstance(r.color_desc, bytes) else r.color_desc
    label = "".join(desc[pat[i // 2, i % 2]] for i in range(4))  # e.g. RGGB
    return bayer, label

def exif_meta(path):
    """Pull exposure seconds + ISO from the CR2 EXIF (via PIL, no extra deps)."""
    expt = iso = None; dt = None
    try:
        from PIL import Image
        from PIL.ExifTags import TAGS
        ex = Image.open(path)._getexif() or {}
        for k, v in ex.items():
            n = TAGS.get(k, k)
            if n == "ExposureTime": expt = float(v)
            elif n == "ISOSpeedRatings": iso = int(v if not isinstance(v, (tuple, list)) else v[0])
            elif n == "DateTimeOriginal": dt = str(v)
    except Exception:
        pass
    return expt, iso, dt

def write_fits(bayer, out_path, bayerpat, exptime, iso, dt, n_coadd=1):
    from astropy.io import fits
    hdu = fits.CompImageHDU(data=bayer, compression_type="RICE_1")
    h = hdu.header
    if exptime is not None:
        h["FRAMEEXP"] = (exptime, "single-frame exposure, s")
        h["EXPTIME"] = (exptime * n_coadd, "total integration, s")
    if iso is not None:
        h["GAIN"] = (f"ISO{iso}", "camera ISO (analog gain)")
        h["ISO"] = iso
    h["NCOADD"] = (n_coadd, "frames coadded")
    h["BAYERPAT"] = (bayerpat, "Bayer CFA pattern")
    h["CAMERA"] = "EOS2000D"
    if dt: h["DATE-OBS"] = dt
    h["ORIGIN"] = "cr2-to-fits"
    fits.HDUList([fits.PrimaryHDU(), hdu]).writeto(out_path, overwrite=True)

def main():
    ap = argparse.ArgumentParser(description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("frames", nargs="+", help="CR2 file(s)")
    ap.add_argument("--out", help="output dir (default: alongside each CR2)")
    ap.add_argument("--stack", metavar="OUT.fits.fz",
                    help="coadd (sum) all inputs into one FITS instead of 1:1")
    args = ap.parse_args()
    if args.out: os.makedirs(args.out, exist_ok=True)

    if args.stack:
        acc = None; pat = None; expt = iso = dt0 = None; n = 0
        for f in args.frames:
            bayer, pat = read_cr2(f)
            e, i, d = exif_meta(f)
            if acc is None:
                acc = bayer.astype(np.uint32); expt, iso, dt0 = e, i, d
            else:
                acc += bayer
            n += 1
            print(f"  coadd {n}/{len(args.frames)}: {os.path.basename(f)}", flush=True)
        # keep as uint32 sum (processing scales); clamp label
        write_fits(acc.astype(np.uint32), args.stack, pat, expt, iso, dt0, n_coadd=n)
        print(f"stacked {n} frames -> {args.stack} ({os.path.getsize(args.stack)/1e6:.1f} MB)")
        return

    for f in args.frames:
        bayer, pat = read_cr2(f)
        e, i, d = exif_meta(f)
        base = os.path.splitext(os.path.basename(f))[0]
        outdir = args.out or os.path.dirname(f) or "."
        out = os.path.join(outdir, base + ".fits.fz")
        write_fits(bayer, out, pat, e, i, d)
        print(f"{os.path.basename(f)} -> {out} "
              f"({os.path.getsize(f)/1e6:.1f} MB CR2 -> {os.path.getsize(out)/1e6:.1f} MB fz)")

if __name__ == "__main__":
    main()
