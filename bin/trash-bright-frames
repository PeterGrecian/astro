#!/usr/bin/env python3
"""trash-bright-frames — move twilight/cloud-lit frames out of a night dir.

Bright-sky frames hurt the stack more than they help (sky background adds
photon noise; the dark floor is what we care about). This tool reads the
per-camera quality config to find a per-second mean ceiling, scans every
.fits.fz under a night dir, and (by default) prints the verdict. With
--apply it actually moves over-threshold frames using super/bin/trash so
the GC can reclaim them at its own pace.

Usage:
    trash-bright-frames --camera astrocam <night-dir>           # dry-run
    trash-bright-frames --camera eclipticam <night-dir> --apply
    trash-bright-frames --camera astrocam --threshold 1500 <dir>  # override

Threshold is in counts per second of integration (i.e. mean / EXPTIME).
A camera's quality.json sets the default; --threshold overrides it.

Inputs that are NEVER trashed:
    - Files matching max.fits.fz, min.fits.fz, sum.fits.fz, badpixel.fits
    - *.derot.fits.fz, *.derot.masked.fits.fz
    - *.cands.json
    - Any file whose EXPTIME header is missing (we can't reason about it)

Dry-run output: per-frame keep/trash + a histogram of per-second means
so the threshold can be tuned by eye.
"""
import argparse
import json
import os
import shutil
import subprocess
import sys
from collections import Counter, defaultdict
from pathlib import Path

import numpy as np
from astropy.io import fits

REPO_ROOT = Path(__file__).resolve().parent.parent

# Derived-artefact filenames that must never be trashed.
KEEP_NAMES = {"max.fits.fz", "min.fits.fz", "sum.fits.fz", "badpixel.fits"}


def load_camera_config(camera):
    cfg_path = REPO_ROOT / camera / "quality.json"
    if not cfg_path.exists():
        print(f"no quality config at {cfg_path}", file=sys.stderr)
        sys.exit(2)
    return json.loads(cfg_path.read_text())


def is_derived(path):
    name = path.name
    if name in KEEP_NAMES:
        return True
    if ".derot." in name:
        return True
    if name.endswith(".cands.json"):
        return True
    if name.startswith("max-") or name.startswith("min-") or name.startswith("sum-"):
        return True
    if name.startswith("max.") or name.startswith("min.") or name.startswith("sum."):
        return True
    return False


def scan_one(path):
    """Return (per_s_mean, exptime_s, mean) or None if the frame can't be read."""
    try:
        with fits.open(path) as hdul:
            hd = hdul[1].header
            exp = float(hd.get("EXPTIME", 0))
            if exp <= 0:
                return None
            data = hdul[1].data
            mean = float(data.mean())
        return mean / exp, exp, mean
    except Exception:
        return None


def histogram_text(values, n_bins=30, width=60):
    """ASCII histogram for terminal. Log-binned because brightness spans
    several stops."""
    if not values:
        return ""
    lo = max(min(values), 1.0)
    hi = max(values)
    if hi <= lo:
        return f"  all values ≈ {lo:.1f}"
    log_lo, log_hi = np.log2(lo), np.log2(hi)
    edges = np.linspace(log_lo, log_hi, n_bins + 1)
    counts, _ = np.histogram(np.log2(values), bins=edges)
    max_count = counts.max() or 1
    lines = []
    for i, c in enumerate(counts):
        lo_b = 2 ** edges[i]
        bar = "█" * int(width * c / max_count)
        lines.append(f"  {lo_b:8.0f}  {c:5d} {bar}")
    return "\n".join(lines)


def main():
    p = argparse.ArgumentParser()
    p.add_argument("--camera", required=True, choices=("astrocam", "eclipticam"))
    p.add_argument("--threshold", type=float, default=None,
                   help="counts/s ceiling (overrides quality.json)")
    p.add_argument("--apply", action="store_true",
                   help="actually trash; default is dry-run only")
    p.add_argument("night_dir", help="path to a night/<date>/ tree to scan")
    args = p.parse_args()

    cfg = load_camera_config(args.camera)
    threshold = args.threshold if args.threshold is not None \
        else float(cfg["stack_brightness_max_per_s"])

    root = Path(args.night_dir).expanduser()
    if not root.is_dir():
        print(f"not a directory: {root}", file=sys.stderr)
        sys.exit(2)

    candidates = []
    skipped_derived = 0
    skipped_unreadable = 0
    for path in root.rglob("*.fits.fz"):
        if is_derived(path):
            skipped_derived += 1
            continue
        r = scan_one(path)
        if r is None:
            skipped_unreadable += 1
            continue
        per_s, exp, mean = r
        candidates.append((path, per_s, exp, mean))

    if not candidates:
        print("no frames found", file=sys.stderr)
        sys.exit(1)

    candidates.sort(key=lambda x: x[1])
    pers = [c[1] for c in candidates]
    pers_arr = np.array(pers)

    print(f"camera: {args.camera}")
    print(f"threshold: {threshold:.1f} counts/s (frames above this would be trashed)")
    print(f"frames scanned: {len(candidates)}  "
          f"(skipped derived: {skipped_derived}, unreadable: {skipped_unreadable})")
    print(f"per-s mean: min={pers_arr.min():.1f}  "
          f"median={float(np.median(pers_arr)):.1f}  max={pers_arr.max():.1f}")
    print()
    print("per-s mean histogram (log-binned):")
    print(histogram_text(pers))
    print()

    keep = [c for c in candidates if c[1] <= threshold]
    trash = [c for c in candidates if c[1] > threshold]
    keep_bytes = sum(c[0].stat().st_size for c in keep)
    trash_bytes = sum(c[0].stat().st_size for c in trash)

    # By sub-dir summary (helps see whether bright frames cluster in dawn/dusk).
    by_sub = defaultdict(lambda: [0, 0])
    for c in keep:
        sub = c[0].parent.name
        by_sub[sub][0] += 1
    for c in trash:
        sub = c[0].parent.name
        by_sub[sub][1] += 1

    print(f"verdict: keep {len(keep)} ({keep_bytes/1e9:.2f} GB),  "
          f"trash {len(trash)} ({trash_bytes/1e9:.2f} GB)")
    print()
    print(f"by sub-dir (keep / trash):")
    for sub in sorted(by_sub):
        k, t = by_sub[sub]
        print(f"  {sub:8s}  {k:5d}  {t:5d}")
    print()

    if not args.apply:
        print("DRY-RUN: nothing moved. Re-run with --apply to trash bright frames.")
        # Show a few examples
        if trash:
            print("\nfirst 5 frames that would be trashed (sorted brightest first):")
            for c in sorted(trash, key=lambda x: -x[1])[:5]:
                path, per_s, exp, mean = c
                print(f"  {path}  per_s={per_s:.0f}  exp={exp:.1f}s  mean={mean:.0f}")
        return 0

    # Apply: use super/bin/trash for each candidate.
    trash_cmd = Path.home() / "super" / "bin" / "trash"
    if not trash_cmd.exists():
        print(f"super/bin/trash not found at {trash_cmd}; falling back to mv",
              file=sys.stderr)
        # Fall back to a manual trash dir.
        backup = root.parent / f".trashbright-{root.name}"
        backup.mkdir(exist_ok=True)
        for path, _, _, _ in trash:
            rel = path.relative_to(root)
            dst = backup / rel
            dst.parent.mkdir(parents=True, exist_ok=True)
            shutil.move(str(path), str(dst))
        print(f"moved {len(trash)} frames to {backup}")
        return 0

    for path, _, _, _ in trash:
        subprocess.run([str(trash_cmd), str(path)], check=True)
    print(f"trashed {len(trash)} frames via {trash_cmd}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
