#!/usr/bin/env python3
"""moon-overlay — draw the accumulated moon-net threads onto a deliverable.

Peter's monthly-net idea: each clear night the moon traces a different,
precisely-known track across the FIXED sensor. moon-net.json accumulates
those threads (full-res 4608x2592 pixel points). This tool overlays them
on any image (a max-stack, detrans-deep, etc), AUTO-SCALING from the
full-res capture geometry to the target image's resolution — so the moon
path can be drawn on binned deliverables too (the camera is fixed, so the
pixel curve transfers; only the scale changes).

Each thread is drawn as a coloured polyline through its marked points,
with the points circled and the end azimuths labelled. Different threads
(different declinations) get different colours -> you SEE the net.

Usage:
    moon-overlay --image night/2026-06-21/max.fits.fz --out moon-net.png
    moon-overlay --image .../poster-detrans-deep.jpg --camera eclipticam-v3w
"""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

import numpy as np
from PIL import Image, ImageDraw

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

THREAD_COLOURS = [
    (0, 255, 80), (255, 200, 0), (0, 200, 255), (255, 80, 200),
    (180, 255, 0), (255, 120, 0), (120, 160, 255),
]


def load_image(path: Path):
    """Return an RGB PIL image, asinh-stretched if it's a FITS."""
    if path.suffix.lower() in (".fits", ".fit", ".fts", ".fz"):
        from astropy.io import fits
        with fits.open(path) as h:
            for hdu in h:
                if getattr(hdu, "data", None) is not None and hdu.data.ndim == 2:
                    d = hdu.data.astype(float)
                    break
        lo, hi = np.percentile(d, 50), np.percentile(d, 99.7)
        x = np.clip((d - lo) / max(hi - lo, 1e-6), 0, None)
        u8 = np.clip(np.arcsinh(x * 10) / np.arcsinh(10) * 255,
                     0, 255).astype("uint8")
        return Image.fromarray(u8).convert("RGB")
    return Image.open(path).convert("RGB")


def _reference_stack(repo_root, cfg):
    """Path to the camera's pinned reference-night max-stack (the fixed
    backdrop for the accumulating moon net). Uses reference_nights[0] from
    camera.json — the same dark/clear night combined-brightness overlays.
    Returns None if no reference is pinned or the stack isn't on disk."""
    subcam = (cfg.get("name", "").split("-", 1) + [""])[1]

    def _stack_for(night):
        # Layout (eclipticam, night_layout=percam): per-night stacks live in
        # <frames_root>/night/<night>/ with a <subcam>_ prefix (v3w_max.fits.fz)
        # or bare (max.fits.fz); the <subcam>/ subdir holds raw frames.
        nd = cfg.frames_root / "night" / night
        cands = []
        if subcam:
            cands += [nd / f"{subcam}_max.fits.fz", nd / subcam / "max.fits.fz"]
        # The BARE max.fits.fz belongs to whichever camera owns the night
        # stack (v3w). Only accept it for a camera that actually captured
        # night raw this night — otherwise a day-only camera (v1) would
        # borrow v3w's stack and draw its net in the WRONG pixel space
        # (this was the sun-net-on-a-v3w-backdrop bug).
        if not subcam or (nd / subcam).is_dir():
            cands.append(nd / "max.fits.fz")
        return next((c for c in cands if c.exists()), None)

    # Prefer the pinned reference night (a fixed dark/clear backdrop).
    for night in (cfg.get("reference_nights") or []):
        s = _stack_for(night)
        if s:
            return s
    # Fallback for reliable automated rendering: the pinned reference may not
    # be on disk (retention / predates capture). Use the MOST RECENT available
    # max-stack so the daily render always has a backdrop.
    ndir = cfg.frames_root / "night"
    if ndir.exists():
        for night in sorted((p.name for p in ndir.iterdir() if p.is_dir()),
                            reverse=True):
            s = _stack_for(night)
            if s:
                return s
    # Day-camera fallback: a day-only camera (eclipticam-v1) never produces a
    # night max-stack, so the sun-net would otherwise borrow another camera's
    # night stack — the WRONG pixel space. Use the most recent day JPEG so the
    # net draws on this camera's OWN sky (sun points then land on the sun).
    ddir = cfg.frames_root / "day"
    if ddir.exists():
        for day in sorted((p.name for p in ddir.iterdir() if p.is_dir()),
                          reverse=True):
            dd = ddir / day / subcam
            frames = sorted(dd.glob("*/*.jpg")) if dd.exists() else []
            if frames:
                # mid-afternoon-ish: a lit sky. Take the median frame of the day.
                return frames[len(frames) // 2]
    return None


def main():
    ap = argparse.ArgumentParser(description=__doc__.split("\n", 1)[0])
    ap.add_argument("--image", type=Path, default=None,
                    help="deliverable to overlay on (FITS or image). "
                         "Default: the camera's reference-night max-stack "
                         "(reference_nights[0]) as a fixed backdrop.")
    ap.add_argument("--net", type=Path, default=None,
                    help="moon-net.json (default: <camera>/moon-net.json)")
    ap.add_argument("--camera", default="eclipticam-v3w")
    ap.add_argument("--out", type=Path, default=None)
    ap.add_argument("--extend", action="store_true",
                    help="extend each thread as a smooth curve across the "
                         "whole frame (not just between marked points)")
    ap.add_argument("--publish", action="store_true",
                    help="upload to S3 as <camera>/moon-net.png (one fixed "
                         "key, no per-night prefix — like combined-brightness)")
    ap.add_argument("--v1-fov", action="store_true",
                    help="draw the eclipticam-v1 frame perimeter on the "
                         "backdrop, via the fov_box model in "
                         "eclipticam-v1/v1_to_v3w.json (v3w backdrop only)")
    ap.add_argument("--v1-sun", action="store_true",
                    help="also map eclipticam-v1's sun-net trail into the v1 "
                         "patch (via fov_box) and draw it — implies --v1-fov")
    args = ap.parse_args()
    if args.v1_sun:
        args.v1_fov = True

    repo_root = Path(__file__).resolve().parent.parent
    from astro.config import CameraConfig
    cfg = CameraConfig.load(args.camera)

    net_path = args.net or (repo_root / args.camera / "moon-net.json")
    if not net_path.exists():
        print(f"no moon net for {args.camera} ({net_path.name} absent) — "
              "nothing to overlay; skipping")
        return 0
    net = json.loads(net_path.read_text())
    if not net.get("threads"):
        print(f"moon net for {args.camera} has no threads yet — skipping")
        return 0
    fullW, fullH = net.get("capture_full_res", [4608, 2592])

    backdrop = args.image or _reference_stack(repo_root, cfg)
    if backdrop is None:
        print(f"no backdrop for {args.camera}: pass --image or pin "
              "reference_nights[0] with its max.fits.fz on disk — skipping")
        return 0

    im = load_image(backdrop)
    W, H = im.size
    sx, sy = W / fullW, H / fullH   # full-res -> target scale
    draw = ImageDraw.Draw(im)

    drawn = 0
    for i, thread in enumerate(net["threads"]):
        col = THREAD_COLOURS[i % len(THREAD_COLOURS)]
        pts = sorted(thread["points"], key=lambda p: p.get("az", p["x"]))
        xy = [(p["x"] * sx, p["y"] * sy) for p in pts]
        if len(xy) < 1:
            continue
        if args.extend and len(xy) >= 3:
            # smooth quadratic y(x) through the points, drawn across frame
            xs = np.array([p["x"] * sx for p in pts])
            ys = np.array([p["y"] * sy for p in pts])
            c = np.polyfit(xs, ys, min(2, len(xs) - 1))
            prev = None
            for px in range(0, W, 3):
                py = np.polyval(c, px)
                if prev and 0 <= py < H:
                    draw.line([prev, (px, py)], fill=col, width=1)
                prev = (px, py)
        # the measured polyline (bold)
        for j in range(len(xy) - 1):
            draw.line([xy[j], xy[j + 1]], fill=col, width=2)
        for (x, y), p in zip(xy, pts):
            draw.ellipse([x - 4, y - 4, x + 4, y + 4], outline=col, width=2)
        # label the thread (night + dec) at its first point
        lx, ly = xy[0]
        label = f"{thread['night']} dec{thread.get('dec_deg', '?')}"
        draw.text((lx + 6, ly - 14), label, fill=col)
        drawn += 1

    # v1 FOV perimeter (+ optional sun trail): map the v1 frame into this (v3w)
    # frame so you SEE where the day camera looks relative to v3w. Uses the
    # FOV-BOX model: scale from the published FOV ratio + a small fitted rotation
    # (q = s*R@p + t). Rotation-aware, so v1 content FAR from the moon anchor —
    # the daytime SUN — still lands in the right part of the patch. See
    # bin/fit-v1-v3w. (Affine is tighter on the moon arc but extrapolates badly.)
    if args.v1_fov:
        tf_path = repo_root / "eclipticam-v1" / "v1_to_v3w.json"
        if not tf_path.exists():
            print(f"--v1-fov: no {tf_path.name} (run fit-v1-v3w first) — "
                  "skipping FOV box")
        else:
            tf = json.loads(tf_path.read_text())
            box = tf.get("fov_box")
            warp = tf.get("warp")
            vw, vh = tf["from_full_res"]              # v1 frame size

            def _warp_eval(a, w):
                """bivariate-polynomial warp v1 -> v3w (bends for distortion)."""
                (mx, my), sc = w["norm"]
                xn = (a[:, 0] - mx) / sc
                yn = (a[:, 1] - my) / sc
                deg = w["degree"]
                cols = []
                for i in range(deg + 1):
                    for j in range(deg + 1 - i):
                        cols.append((xn ** i) * (yn ** j))
                A = np.stack(cols, axis=-1)
                C = np.array(w["coeffs"])             # (nterms, 2)
                return A @ C

            def _to_v3w(v1pts):
                """map v1 full-res pixels -> v3w full-res. Prefer the polynomial
                warp (distortion-aware); else the fov_box (scale*R+t); else the
                affine. The warp is the correct map at v3w's distorted edge."""
                a = np.asarray(v1pts, float)
                if warp:
                    return _warp_eval(a, warp)
                if box:
                    R = np.array(box.get("rotation_2x2", [[1, 0], [0, 1]]))
                    return box["scale"] * (a @ R.T) + np.array(box["translate"])
                M = np.array(tf["affine_2x3"])
                return (M[:, :2] @ a.T).T + M[:, 2]

            fov_col = (255, 60, 60)
            # Sample the v1 frame PERIMETER densely, then map — under the
            # distortion-aware warp the straight v1 edges become CURVED in v3w,
            # so we can't just connect 4 corners. (Linear models: the samples
            # stay collinear, so it still looks like straight edges.)
            n = 40
            edge = []
            for a, b in [((0, 0), (vw, 0)), ((vw, 0), (vw, vh)),
                         ((vw, vh), (0, vh)), ((0, vh), (0, 0))]:
                ts = np.linspace(0, 1, n, endpoint=False)
                edge += [(a[0] + t * (b[0] - a[0]),
                          a[1] + t * (b[1] - a[1])) for t in ts]
            perim = _to_v3w(edge)
            poly = [(px * sx, py * sy) for px, py in perim]
            draw.line(poly + [poly[0]], fill=fov_col, width=2)
            lc = max(poly, key=lambda p: p[1])        # lowest on-frame corner
            model = ("warp" if warp else "FOV-scale" if box else "affine")
            rms = (warp or box or {}).get("rms_px", "?")
            draw.text((lc[0] + 4, min(lc[1], H - 14) - 12),
                      f"v1 FOV ({model}, {rms}px)", fill=fov_col)

            # Sun trail inside the v1 patch: map v1's sun-net points through the
            # same model and draw them where v1 sees the sun (high in the patch).
            if args.v1_sun:
                sun_path = repo_root / "eclipticam-v1" / "sun-net.json"
                sun = (json.loads(sun_path.read_text()).get("threads", [])
                       if sun_path.exists() else [])
                sun_col = (255, 200, 0)
                for thr in sun:
                    v1pts = [(p["x"], p["y"]) for p in
                             sorted(thr["points"], key=lambda p: p.get("az", 0))]
                    if len(v1pts) < 2:
                        continue
                    mapped = _to_v3w(v1pts)
                    xy = [(px * sx, py * sy) for px, py in mapped]
                    for a, b in zip(xy, xy[1:]):
                        draw.line([a, b], fill=sun_col, width=2)
                    for x, y in xy:
                        draw.ellipse([x - 3, y - 3, x + 3, y + 3],
                                     outline=sun_col, width=1)
                    draw.text((xy[0][0] + 4, xy[0][1] - 12), "v1 sun",
                              fill=sun_col)

    draw.text((8, 8), f"moon net: {drawn} thread(s)", fill=(0, 255, 80))

    # Privacy crop: the backdrop is a real max-stack (camera pixels), so any
    # internet-reachable copy must be cropped to the published region. The net
    # points share the backdrop's full-res, top-anchored coordinate space, so
    # cropping AFTER drawing keeps every kept pixel at its original y. (The
    # v3w moon trails sit at y~1059-1293 of 2592 — inside the top-82% keep.)
    from astro.present import privacy as P
    spec = P.entry_for(cfg)
    if spec is not None:
        keep = spec["publish_keep_top_px"]
        spec_h = spec["frame_size_px"][1]
        if H != spec_h:
            keep = int(round(keep * H / spec_h))
        im = im.crop((0, 0, W, keep))

    out = args.out or (repo_root / args.camera / "moon-net.png")
    out.parent.mkdir(parents=True, exist_ok=True)
    im.save(out)
    if spec is not None:
        P.mark_ok(out)   # cropped through the publication spec
    print(f"wrote {out}  ({drawn} threads on {W}x{H} image, "
          f"scaled x{sx:.3f}{', privacy-cropped' if spec else ''})")

    if args.publish:
        import boto3
        bucket = cfg.s3["bucket"]
        cam_prefix = cfg.s3["prefix"].removesuffix("/nights")
        # Key follows the OUTPUT basename, not a fixed "moon-net.png" — so a
        # sun-net.png render publishes to <cam>/sun-net.png and doesn't clobber
        # the moon net. (One fixed key per net, no per-night prefix.)
        key = f"{cam_prefix}/{out.name}"
        boto3.client("s3").upload_file(
            str(out), bucket, key, ExtraArgs={"ContentType": "image/png"})
        print(f"uploaded s3://{bucket}/{key}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
