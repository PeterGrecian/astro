#!/usr/bin/env python3
"""Overlay an 8x6 labelled grid on an existing JPG."""
import sys
from pathlib import Path
import numpy as np
from PIL import Image, ImageDraw, ImageFont

inp = Path(sys.argv[1])
out = Path(sys.argv[2])
cols = int(sys.argv[3]) if len(sys.argv) > 3 else 8
rows = int(sys.argv[4]) if len(sys.argv) > 4 else 6

pil = Image.open(inp).convert("RGB")
W, H = pil.size
SCALE = 2
pil = pil.resize((W * SCALE, H * SCALE), Image.NEAREST)
draw = ImageDraw.Draw(pil)
try:
    font = ImageFont.truetype("/usr/share/fonts/truetype/dejavu/DejaVuSansMono-Bold.ttf", 22)
except OSError:
    font = ImageFont.load_default()

cw, rh = W * SCALE / cols, H * SCALE / rows
gridcol = (255, 255, 0)
for c in range(1, cols):
    x = int(c * cw)
    draw.line([(x, 0), (x, H * SCALE)], fill=gridcol, width=1)
for r in range(1, rows):
    y = int(r * rh)
    draw.line([(0, y), (W * SCALE, y)], fill=gridcol, width=1)
for r in range(rows):
    for c in range(cols):
        label = f"{chr(ord('A')+c)}{r+1}"
        x, y = int(c * cw + 6), int(r * rh + 6)
        bbox = draw.textbbox((x, y), label, font=font)
        draw.rectangle(bbox, fill=(0, 0, 0))
        draw.text((x, y), label, fill=gridcol, font=font)
pil.save(out, quality=92)
print(f"wrote {out}")
