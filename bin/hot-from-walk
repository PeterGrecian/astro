#!/usr/bin/env python3
"""hot-from-walk — build a hot-pixel mask from the arc-walk image.

The arc-walk binary image has bright pixels at every frame-to-frame-
changing position. Real star arcs are long, elongated streaks; hot
pixels are small isolated bright dots.

Filter the connected components to keep only the SHORT and COMPACT
ones — those are the hot pixels. Optionally dilate by 1 px to catch
charge-leak neighbours.

Outputs:
  --out: boolean .npy hot-pixel mask, shape (H, W)
  --out-overlay: optional .jpg with hot pixels marked red
"""
from __future__ import annotations

import argparse
import sys
from pathlib import Path

import cv2
import numpy as np


EXAMPLES = """\
Examples:
  hot-from-walk --in photon_2230_0300_p50.jpg --out hot_pixels.npy
      → standard hot-pixel extraction from the photon-sum image

  hot-from-walk --in photon_dark50.jpg --out hot_pixels.npy \\
                --out-overlay hot_overlay.jpg
      → also write a visualisation with hot pixels marked red

  hot-from-walk --in photon_dark50.jpg --out hot.npy \\
                --max-arc-pixels 20 --max-elong 4
      → looser (more pixels marked as hot)

Criteria for hot pixel:
  area <= --max-arc-pixels (default 15)
  AND elongation (eigenvalue ratio) <= --max-elong (default 3)

Final mask is dilated 1 px to catch charge-leak around each hot pixel.
"""


def main() -> int:
    ap = argparse.ArgumentParser(
        description=__doc__.split("\n", 1)[0],
        epilog=EXAMPLES,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    ap.add_argument("--in", dest="in_path", required=True, type=Path,
                    help="arc-walk image (8-bit greyscale JPG)")
    ap.add_argument("--out", required=True, type=Path,
                    help="hot-pixel mask, boolean .npy")
    ap.add_argument("--out-overlay", type=Path, default=None,
                    help="optional visualisation JPG with hot pixels red")
    ap.add_argument("--threshold", type=int, default=40,
                    help="binary threshold for bright-pixel mask (0-255)")
    ap.add_argument("--max-arc-pixels", type=int, default=15,
                    help="components <= this many pixels are candidate hot")
    ap.add_argument("--max-elong", type=float, default=3.0,
                    help="components <= this elongation are candidate hot")
    args = ap.parse_args()

    img = cv2.imread(str(args.in_path), cv2.IMREAD_GRAYSCALE)
    if img is None:
        sys.stderr.write(f"cannot read {args.in_path}\n")
        return 2
    H, W = img.shape
    print(f"loaded {args.in_path}  {W}x{H}")

    _, binary = cv2.threshold(img, args.threshold, 255, cv2.THRESH_BINARY)
    n_cc, labels, stats, _ = cv2.connectedComponentsWithStats(binary, 8)
    print(f"connected components: {n_cc - 1}")

    hot_mask = np.zeros((H, W), dtype=bool)
    n_hot = n_arc = n_other = 0
    for i in range(1, n_cc):
        area = int(stats[i, cv2.CC_STAT_AREA])
        if area > args.max_arc_pixels:
            n_arc += 1
            continue
        ys, xs = np.where(labels == i)
        if len(xs) > 1:
            pts = np.column_stack([xs.astype(float), ys.astype(float)])
            cov = np.cov(pts.T)
            eigs = np.sort(np.linalg.eigvalsh(cov))[::-1]
            elong = eigs[0] / max(eigs[1], 1e-3)
            if elong > args.max_elong:
                n_other += 1
                continue
        hot_mask[ys, xs] = True
        n_hot += 1

    hot_mask_d = cv2.dilate(hot_mask.astype(np.uint8),
                            np.ones((3, 3), np.uint8),
                            iterations=1).astype(bool)
    print(f"components classified:")
    print(f"  hot (small + compact):    {n_hot}  ({int(hot_mask.sum())} px)")
    print(f"  arcs (large):             {n_arc}")
    print(f"  other (small but linear): {n_other}")
    print(f"hot mask after 1px dilate:  {int(hot_mask_d.sum())} px")

    np.save(args.out, hot_mask_d)
    print(f"wrote {args.out}")

    if args.out_overlay:
        bg = cv2.cvtColor(img, cv2.COLOR_GRAY2BGR)
        bg[hot_mask_d] = (40, 40, 220)
        cv2.imwrite(str(args.out_overlay), bg,
                    [cv2.IMWRITE_JPEG_QUALITY, 88])
        print(f"wrote {args.out_overlay}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
