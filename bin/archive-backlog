#!/usr/bin/env python3
"""archive-backlog — push KEEPER astro nights to S3 Deep Archive, raw,
oldest first.

Policy (project-deep-archive-backlog memory, refined 2026-06-30):
  - Deep Archive is the default cold tier; archive RAW frames.
  - Only KEEPERS go to Glacier: the clearest CLEAR night of each ISO week,
    per camera (same rule as the /astro/storage page). Weeks with no clear
    night get no keeper. Non-keeper nights stay local raw on bigdisk until
    it's under pressure, then squashed LOCALLY (a separate step, not here).
  - One tar per (camera, mode): cold/<camera>/<mode>/<night>/...tar
    (matches the existing convention + astro.locate registry).
  - Archiving only; freeing the local/puppy copy is a SEPARATE step.

Run on muppet (bigdisk is local there). Dry-run by default.

    archive-backlog                       # dry-run: the keeper plan
    archive-backlog --limit 1 --go        # archive the oldest keeper, for real
    archive-backlog --night 2026-06-09 --go
    archive-backlog --all                 # (rare) every warm-only night
"""
from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

import boto3

REPO = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(REPO))
from astro.config import CameraConfig          # noqa: E402
from astro import locate                        # noqa: E402

REGION = "eu-west-1"
BUCKET = "astro-berrylands-eu-west-1"
INV_TABLE = "astro-storage-inventory"
CAMERAS = ["astrocam", "eclipticam-v1", "eclipticam-v3w"]
COLD_ARCHIVE = str(REPO / "bin" / "cold-archive-night")


def verdict_of(night_dir: Path) -> str:
    """clear | cloudy | no-data | unknown — from summary.json if present."""
    f = night_dir / "summary.json"
    if not f.is_file():
        return "unknown"
    try:
        return (json.load(f.open()).get("verdict") or "unknown").lower()
    except Exception:
        return "unknown"


def mode_of(camera: str, night_dir: Path) -> str:
    """night vs day — astro raw lives under HH/ (we archive the night dir as
    a whole). Mode here just names the S3 key; default 'night'."""
    return "night"


def already_cold(s3, camera: str, mode: str, night: str) -> bool:
    key = f"cold/{camera}/{mode}/{night}/{camera}-{mode}-{night}.tar"
    try:
        s3.head_object(Bucket=BUCKET, Key=key)
        return True
    except Exception:
        return False


def warm_only_nights():
    """[(night, [(camera, Located), ...])] for nights with real local data
    not yet in Deep Archive, oldest first. Uses the inventory table to know
    what's already cold."""
    s3 = boto3.client("s3", region_name=REGION)
    by_night = {}
    for cam in CAMERAS:
        try:
            cfg = CameraConfig.load(cam)
        except FileNotFoundError:
            continue
        for night, loc in locate.list_nights(cfg):
            if not loc.online or not loc.path.is_dir():
                continue
            # real data only (skip empty shadows)
            try:
                size = sum(p.stat().st_size for p in loc.path.rglob("*")
                           if p.is_file())
            except OSError:
                size = 0
            if size < 50 * (1 << 20):
                continue
            if already_cold(s3, cam, mode_of(cam, loc.path), night):
                continue
            by_night.setdefault(night, []).append((cam, loc, size))
    return sorted(by_night.items())


def squash_night(night_dir: Path) -> Path:
    """Run pair-sum over each HH/ (sum8) and HHb/ (sum2) dir; return a
    sibling <dir>-squashed tree to archive. (cloudy-night path.)"""
    out = night_dir.parent / (night_dir.name + "-squashed")
    out.mkdir(parents=True, exist_ok=True)
    pair_sum = str(REPO / "bin" / "pair-sum")
    for hh in sorted(night_dir.glob("[0-9][0-9]")):
        subprocess.run([pair_sum, str(hh), "--n", "8",
                        "--out", str(out / (hh.name + "-sum8"))], check=True)
    for hhb in sorted(night_dir.glob("[0-9][0-9]b")):
        subprocess.run([pair_sum, str(hhb), "--n", "2",
                        "--out", str(out / (hhb.name + "-sum2"))], check=True)
    return out


def keeper_nights(by_night):
    """Per camera, the clearest CLEAR night of each ISO week is a keeper
    (raw → Glacier). Weeks with verdicts but no clear night get no keeper;
    weeks with no verdict info fall back to biggest. Returns a set of
    (camera, night) keeper pairs. Mirrors the /astro/storage page rule.

    by_night: {night: [(camera, Located, size), ...]}
    """
    import datetime as _dt
    from collections import defaultdict
    per_cam_week = defaultdict(list)  # (camera, isoweek) -> [(night, size, verdict)]
    for night, locs in by_night.items():
        try:
            wk = _dt.date.fromisoformat(night).isocalendar()[:2]
        except ValueError:
            continue
        for cam, loc, size in locs:
            per_cam_week[(cam, wk)].append((night, size, verdict_of(loc.path)))
    keepers = set()
    for (cam, wk), nights in per_cam_week.items():
        clear = [n for n in nights if n[2] == "clear"]
        if clear:
            keepers.add((cam, max(clear, key=lambda n: n[1])[0]))
        elif not any(n[2] for n in nights):
            keepers.add((cam, max(nights, key=lambda n: n[1])[0]))
    return keepers


def archive_one(camera, mode, night, src, go):
    cmd = [sys.executable, COLD_ARCHIVE, night,
           "--camera", camera, "--mode", mode, "--src", str(src)]
    if go:
        cmd.append("--go")
    print(f"  $ {' '.join(cmd)}")
    return subprocess.run(cmd).returncode == 0


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__)
    ap.add_argument("--limit", type=int, default=None,
                    help="archive only the N oldest (camera,night) keepers")
    ap.add_argument("--night", default=None, help="just this night")
    ap.add_argument("--all", action="store_true",
                    help="archive ALL warm-only nights, not just keepers "
                         "(the old behaviour; rarely wanted under the keeper "
                         "policy)")
    ap.add_argument("--go", action="store_true",
                    help="actually upload (default dry-run)")
    args = ap.parse_args()

    nights = dict(warm_only_nights())  # {night: [(cam, loc, size), ...]}
    if args.night:
        nights = {n: v for n, v in nights.items() if n == args.night}

    if not nights:
        print("nothing to archive — backlog clear (or all already cold).")
        return 0

    # Policy default: archive only KEEPERS (raw → Glacier). The clearest
    # clear night per ISO week per camera. Non-keepers stay local raw until
    # bigdisk is under pressure (then squashed locally — a separate step).
    keepers = keeper_nights(nights)

    # Build the per-(camera,night) work list, oldest first.
    work = []  # (night, cam, loc, size)
    for night, locs in sorted(nights.items()):
        for cam, loc, size in locs:
            if args.all or (cam, night) in keepers:
                work.append((night, cam, loc, size))
    if args.limit:
        work = work[:args.limit]

    if not work:
        print("no keepers to archive (use --all to archive everything).")
        return 0

    GB = 1 << 30
    mode_word = "ALL warm-only" if args.all else "KEEPER"
    print(f"=== {len(work)} {mode_word} (camera,night) tar(s), oldest first ===")
    for night, cam, loc, size in work:
        mode = mode_of(cam, loc.path)
        vd = verdict_of(loc.path) or "?"
        print(f"\n{night}  {cam}/{mode}  {size/GB:.1f}G  verdict={vd}")
        ok = archive_one(cam, mode, night, loc.path, args.go)
        print(f"  {'ok' if ok else 'FAILED'}")
    if not args.go:
        print("\nDRY RUN — pass --go to upload.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
