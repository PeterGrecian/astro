#!/usr/bin/env python3
"""cover-controller — single owner of the starcam observing state.

Cover-open and camera-capturing are ONE state: when the cover opens we start
the capture daemon; when it closes we stop it. One 5-minute systemd timer on
starcam drives this; the controller decides, moves the servo locally, and
starts/stops the capture service in lockstep.

State machine (time window bounds it; brightness decides within):
  CLOSED (not capturing):
      read SKYCAM crop brightness (NFS) — dark enough for N reads?
          yes -> cover OPEN  + start capture
  OPEN (capturing):
      read newest starcam .npy from the LOCAL tmpfs buffer, take .mean() —
      bright for N reads (cloud / dawn / moon)?
          yes -> cover CLOSE + stop capture
      (also sample skycam each tick and log the pair, for later calibration
       of the two brightness scales)
  05:00 hard cover-close.timer (separate unit on starcam) is the safety
  backstop and is independent of this controller.

Why these sources:
  - CLOSE uses starcam's OWN frames, read LOCALLY from /var/lib/starcam-buffer
    (numpy only — no astropy, no NFS, no journal). The close decision must not
    depend on puppy/storage being reachable. The starcam-uploader drains the
    buffer to puppy asynchronously for processing; that is storage, not logic.
  - OPEN uses skycam because starcam is blind behind a closed cover.
"""
from __future__ import annotations

import os
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path
from zoneinfo import ZoneInfo

import numpy as np
from PIL import Image

LONDON = ZoneInfo("Europe/London")

STARCAM_BUFFER = Path(os.environ.get("STARCAM_BUFFER", "/var/lib/starcam-buffer/night"))
STARCAM_ROOT = Path(os.environ.get("STARCAM_ROOT", str(Path.home() / "starcam-frames")))
STATE_PATH = STARCAM_ROOT / ".cover-state"
SKYCAM_MOUNT = Path(os.environ.get("SKYCAM_MOUNT", str(Path.home() / "skycam-frames")))

COVER = Path.home() / "astro" / "bin" / "cover"
CAPTURE_UNIT = "starcam-capture.service"

# Bounds: never open before dusk-ish or after the morning safety close. Inside
# this the brightness rules decide. Window straddles midnight.
ACT_AFTER = (21, 0)    # 21:00 local
ACT_BEFORE = (4, 30)   # 04:30 local

# Brightness thresholds — first calibration from the clear night of 2026-05-27
# (paired starcam-journal mean vs skycam crop, dusk + overnight):
#   starcam (fixed 2.9s exposure, AE off): clear-night baseline ~48-52 (NEVER
#     below 45 all night), dusk twilight 55-108, a bright cloud/moon event ~226.
#   skycam crop: floors at ~25-27 within ~2 min of dusk (61->27), so it has no
#     dynamic range in the dark — it's effectively a day/night gate only.
# Hence: CLOSE on starcam well ABOVE the clear baseline+twilight (45 would have
# closed every clear night immediately); OPEN on skycam safely past its cliff.
# Refine with more nights, especially a cloudy one (see the paired log below).
CLOUDY_STARCAM_MEAN = 120.0  # starcam mean >= this for N reads -> close (clear<=108)
DARK_SKYCAM_CROP = 40.0      # skycam crop_mean <= this for N reads -> open (cliff ~38)
CONSEC_NEEDED = 3
LOCKOUT_S = 3600             # no flip within 1 hour of the last flip


def log(msg: str) -> None:
    print(f"cover-controller: {msg}", flush=True)


def in_act_window(now: datetime) -> bool:
    t = (now.hour, now.minute)
    return t >= ACT_AFTER or t < ACT_BEFORE


def read_cover_state() -> tuple[str, int]:
    """Return (label, epoch_s_of_last_move). ('unknown', 0) if no state file."""
    if not STATE_PATH.exists():
        return ("unknown", 0)
    lines = STATE_PATH.read_text().splitlines()
    label = lines[0].strip() if lines else "unknown"
    ts = 0
    if len(lines) >= 3:
        try:
            ts = int(lines[2].strip())
        except ValueError:
            pass
    return (label, ts)


def recent_starcam_means(n: int) -> list[float]:
    """Mean pixel value of the most-recent n .npy frames in the LOCAL buffer.

    The capture daemon writes flat <epoch_ms>.npy into STARCAM_BUFFER. We read
    them with numpy locally — no astropy, no NFS, no journal. Skips the single
    newest file (the daemon may still be writing it), matching the uploader's
    'never touch the newest' rule."""
    if not STARCAM_BUFFER.is_dir():
        return []
    files = sorted(STARCAM_BUFFER.glob("*.npy"))
    if len(files) >= 2:
        files = files[:-1]  # drop the in-flight newest
    means: list[float] = []
    for p in files[-n:]:
        try:
            means.append(float(np.load(p, mmap_mode="r").mean()))
        except Exception as e:
            log(f"failed to read {p.name}: {e}")
    return means


def latest_skycam_jpgs(n: int) -> list[Path]:
    """Most-recent n .jpg files from the NFS-mounted skycam frames tree."""
    if not SKYCAM_MOUNT.is_dir():
        return []
    date_dirs = sorted([p for p in SKYCAM_MOUNT.iterdir()
                        if p.is_dir() and len(p.name) == 10])[-2:]
    files: list[Path] = []
    for dd in date_dirs:
        for hd in sorted([p for p in dd.iterdir()
                          if p.is_dir() and len(p.name) == 2])[-2:]:
            files.extend(sorted(hd.glob("*.jpg")))
    return files[-n:]


def skycam_crop_mean(path: Path) -> float | None:
    try:
        img = np.asarray(Image.open(path).convert("L"))
        h, w = img.shape
        crop = img[h // 4:3 * h // 4, w // 4:3 * w // 4]
        return float(crop.mean())
    except Exception as e:
        log(f"failed to read {path.name}: {e}")
    return None


def skycam_latest_crop() -> float | None:
    frames = latest_skycam_jpgs(1)
    return skycam_crop_mean(frames[0]) if frames else None


def move_cover(action: str) -> bool:
    """Drive the servo via `cover`. A failed move is logged but not raised, so
    a transient error never fails the unit and stops the 5-min retry loop."""
    log(f"invoking: cover {action}")
    try:
        subprocess.run([str(COVER), action], check=True)
        return True
    except subprocess.CalledProcessError as e:
        log(f"cover {action} FAILED (exit {e.returncode}); will retry next tick")
        return False


def set_capture(running: bool) -> bool:
    """Start or stop the capture daemon. Best-effort; logged, never raised."""
    verb = "start" if running else "stop"
    log(f"capture: systemctl {verb} {CAPTURE_UNIT}")
    try:
        subprocess.run(["sudo", "-n", "systemctl", verb, CAPTURE_UNIT], check=True)
        return True
    except subprocess.CalledProcessError as e:
        log(f"capture {verb} FAILED (exit {e.returncode}); will retry next tick")
        return False


def main() -> int:
    now = datetime.now(LONDON)
    if not in_act_window(now):
        log(f"outside act window ({now.strftime('%H:%M')}); no-op")
        return 0

    state, last_ts = read_cover_state()
    age = int(time.time()) - last_ts if last_ts else 10**9
    log(f"state={state} age={age}s")
    if age < LOCKOUT_S:
        log(f"within {LOCKOUT_S}s lockout; no-op")
        return 0

    if state == "open":
        # CLOSE decision: starcam's own brightness, read locally from buffer.
        means = recent_starcam_means(CONSEC_NEEDED)
        sky = skycam_latest_crop()  # sample for calibration, not for deciding
        log(f"starcam means={means} skycam_crop={sky} (paired, for calibration)")
        if len(means) < CONSEC_NEEDED:
            log(f"only {len(means)} starcam means; need {CONSEC_NEEDED}; no-op")
            return 0
        if all(m >= CLOUDY_STARCAM_MEAN for m in means):
            log(f"all >= {CLOUDY_STARCAM_MEAN}: bright -> CLOSE + stop capture")
            if move_cover("close"):
                set_capture(False)
        else:
            log("not all bright; keep open")
        return 0

    if state in ("closed", "weather-closed", "unknown"):
        # OPEN decision: skycam (starcam is blind behind the cover).
        frames = latest_skycam_jpgs(CONSEC_NEEDED)
        if len(frames) < CONSEC_NEEDED:
            log(f"only {len(frames)} skycam frames; need {CONSEC_NEEDED}; no-op")
            return 0
        crops = [skycam_crop_mean(p) for p in frames]
        log(f"skycam crop_means: {crops}")
        if any(c is None for c in crops):
            log("missing skycam reads; no-op")
            return 0
        if all(c <= DARK_SKYCAM_CROP for c in crops):
            log(f"all <= {DARK_SKYCAM_CROP}: dark -> OPEN + start capture")
            if move_cover("open"):
                set_capture(True)
        else:
            log("not all dark; keep closed")
        return 0

    log(f"unhandled state {state!r}; no-op")
    return 0


if __name__ == "__main__":
    sys.exit(main())
