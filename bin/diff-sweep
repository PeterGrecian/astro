#!/usr/bin/env python3
"""diff-sweep — sliding-window (max-stack - mean) -> JPEG sequence.

Third deliverable alongside window-stack-sweep (max) and sum-sweep (sum):

    pixel_out = max(frame[i])  -  mean(frame[i])   over window i

i.e. the per-pixel max-stack of the window minus the per-pixel mean.
Bright transients (single-frame or persistent) end up in the max and
survive the mean subtraction; the pedestal, hot pixels, and average
sky cancel.

Optional knobs:
- --noise-floor-mult M (default 0): subtract M × σ × √(2 ln N) per
  pixel, where σ is the per-pixel std across the window and N is
  the number of frames. √(2 ln N) is the expected position of the
  max of N standard Gaussians above the mean — i.e. for pure noise,
  max-mean already sits this high without any signal. Setting M=1
  cancels that statistical floor exactly; M>1 is conservative,
  M<1 keeps faint speckle visible.
- --signed: don't clip negative output to zero. Useful when you want
  to see darkening events (dust eclipse, dimming source).
- --neg-blue: implies --signed. Render negatives as a blue lobe and
  positives as the usual asinh greys.
- --colour: process per RGB plane (de-bayered). With --neg-blue,
  the "negative" decision is global luminance (sum of planes), not
  per-channel.

Single-process streaming: each FITS frame is decoded ONCE and stashed
in a deque of recent binned frames. When a window closes we look back
over the deque, compute max + mean (+ std if noise floor enabled)
over that window. The deque is pruned of frames older than the oldest
still-open window.

--synthetic mode: a single bright pixel walking diagonally on a
constant background. Bg subtracts to zero; trail survives.
"""
import argparse
import os
import sys
from collections import deque
from datetime import datetime, timedelta, timezone
from pathlib import Path

import numpy as np

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
from astro.config import CameraConfig
from astro.frames import list_night_frames
from astro.process import bayer
from astro.present.render import (
    render_asinh_jpeg, render_asinh_jpeg_rgb,
    render_signed_asinh_jpeg, render_signed_asinh_jpeg_rgb,
)


# --- trail line-filter (--line-filter) --------------------------------------
# Keep the star trails, suppress the dense single-pixel dots (noise/hot pixels)
# and the non-linear fuzzy cloud — both make the mp4 noisy + high-bandwidth.
# Per-pixel oriented morphological open ALONG the analytic local trail
# direction, minus the open ACROSS it:
#   trails  -> bright along, dark across  -> survive
#   dots    -> smaller than the kernel    -> erased by the open at any angle
#   cloud   -> isotropic                  -> along ~= across -> cancels
# The local trail direction is ANALYTIC (from k1,k2 + the detrans motion
# angle), NOT estimated — diff-sweep frames are distorted binned, so the
# barrel distortion bends the uniform sky-motion into a per-pixel curved
# field. See design/trail-line-filter.md.
def trail_angle_field(H, W, k1, k2, motion_angle_deg):
    """Per-pixel star-trail orientation (deg, mod 180) in the DISTORTED frame:
    the undistort map's inverse Jacobian applied to the motion unit vector."""
    cx, cy = (W - 1) / 2.0, (H - 1) / 2.0
    Rn = 0.5 * np.hypot(W, H)

    def undistort(X, Y):
        dx, dy = X - cx, Y - cy
        rt = np.sqrt(dx * dx + dy * dy) / Rn
        s = np.ones_like(rt)
        for _ in range(12):
            rd = rt / s
            s = 1 + k1 * rd * rd + k2 * rd ** 4
        return cx + dx / s, cy + dy / s

    ys, xs = np.mgrid[0:H, 0:W].astype(np.float64)
    eps = 2.0
    ux0, uy0 = undistort(xs, ys)
    uxx, uyx = undistort(xs + eps, ys)
    uxy, uyy = undistort(xs, ys + eps)
    a = (uxx - ux0) / eps; b = (uxy - ux0) / eps
    c = (uyx - uy0) / eps; d = (uyy - uy0) / eps
    det = a * d - b * c
    det[np.abs(det) < 1e-9] = 1e-9
    th0 = np.radians(motion_angle_deg)
    u0, u1 = np.cos(th0), np.sin(th0)
    # distorted dir = inv(J_undist) . motion
    vx = (d * u0 - b * u1) / det
    vy = (-c * u0 + a * u1) / det
    return np.degrees(np.arctan2(vy, vx)) % 180.0


def _oriented_open(gray_u8, angle_deg, L):
    import cv2
    k = np.zeros((L, L), np.uint8)
    cv2.line(k, (0, L // 2), (L - 1, L // 2), 1, 1)
    kr = cv2.warpAffine(k, cv2.getRotationMatrix2D((L / 2, L / 2), angle_deg, 1.0),
                        (L, L))
    return cv2.morphologyEx(gray_u8, cv2.MORPH_OPEN, kr.astype(np.uint8)).astype(np.float32)


def line_filter(img, angle_field, L=7, nang=12, thresh=25):
    """Suppress dots + non-linear cloud, keep trails. img: float HxW (or HxWx3).
    angle_field: per-pixel trail orientation (deg) at img's resolution."""
    import cv2
    # operate on a single luminance channel; reapply to colour at the end
    is_rgb = img.ndim == 3
    lum = img.max(axis=2) if is_rgb else img
    lo, hi = float(lum.min()), float(lum.max())
    u8 = np.clip((lum - lo) / max(hi - lo, 1e-6) * 255, 0, 255).astype(np.uint8)
    H, W = u8.shape
    bins = np.arange(0, 180, 180 / nang)
    opens = np.stack([_oriented_open(u8, a, L) for a in bins])  # (nang, H, W)
    idx = (np.round(angle_field / (180 / nang)).astype(int)) % nang
    perp = (idx + nang // 2) % nang
    ii, jj = np.indices((H, W))
    along = opens[idx, ii, jj]
    across = opens[perp, ii, jj]
    mask = np.clip(along - across, 0, 255)
    mask[mask < thresh] = 0
    keep = (mask > 0).astype(np.float32)
    return img * (keep[..., None] if is_rgb else keep)


def parse_hhmm_to_utc(night: str, hhmm: str) -> datetime:
    nd = datetime.strptime(night, "%Y-%m-%d").date()
    h, m = (int(x) for x in hhmm.split(":"))
    day = nd if h >= 12 else nd + timedelta(days=1)
    return datetime.combine(day, datetime.min.time(),
                            tzinfo=timezone.utc).replace(hour=h, minute=m)


def list_windows(sweep_start, sweep_end, window, step):
    out, t, i = [], sweep_start, 0
    while t + window <= sweep_end:
        out.append((i, t, t + window))
        i += 1
        t += step
    return out


def synthetic_frames(n_frames, H, W, cadence_s, sweep_start):
    for i in range(n_frames):
        f = np.full((H, W), 100, dtype=np.uint16)
        y = int(round((H - 1) * i / max(n_frames - 1, 1)))
        x = int(round((W - 1) * i / max(n_frames - 1, 1)))
        f[y, x] = 60000
        yield sweep_start + timedelta(seconds=i * cadence_s), f


def load_fits_binned(path, rgb_pattern):
    from astropy.io import fits
    with fits.open(path) as h:
        d = h[1].data
    if rgb_pattern is not None:
        return bayer.bin2x2_rgb(d, rgb_pattern)
    return bayer.bin2x2(d)


def close_window(idx, w_start, w_end, recent, rgb_pattern,
                 frames_dir, rotate_180,
                 noise_floor_mult=0.0, mean_mult=1.0,
                 signed=False, neg_blue=False,
                 line_field=None, line_L=7):
    """Find the frames in [w_start, w_end), compute (max - k·mean)
    optionally minus a noise floor, render."""
    in_win = [(t, f) for (t, f) in recent if w_start <= t < w_end]
    if not in_win:
        print(f"  skip window {idx:05d}: no frames in deque "
              f"(possible drain edge)")
        return
    stack = np.stack([f for (_, f) in in_win]).astype(np.float32)
    N = stack.shape[0]
    mean = stack.mean(axis=0)
    max_ = stack.max(axis=0)
    out_img = max_ - mean_mult * mean
    if noise_floor_mult > 0 and N >= 2:
        # Expected max of N Gaussians sits at mean + sigma * sqrt(2 ln N).
        # Subtract that, scaled by user multiplier, to suppress pure-noise
        # speckle without erasing real signal.
        sigma = stack.std(axis=0, ddof=1)
        floor = noise_floor_mult * sigma * float(np.sqrt(2.0 * np.log(N)))
        out_img = out_img - floor
    if not signed:
        np.maximum(out_img, 0, out=out_img)
    # Trail line-filter: keep linear star trails, suppress dots + cloud.
    if line_field is not None:
        out_img = line_filter(out_img, line_field, L=line_L)
    out_path = frames_dir / f"frame_{idx:05d}.jpg"
    if signed or neg_blue:
        if rgb_pattern is not None:
            render_signed_asinh_jpeg_rgb(out_img, out_path,
                                         neg_blue=neg_blue,
                                         rotate_180=rotate_180)
        else:
            render_signed_asinh_jpeg(out_img, out_path,
                                     neg_blue=neg_blue,
                                     rotate_180=rotate_180)
    elif rgb_pattern is not None:
        render_asinh_jpeg_rgb(out_img, out_path, rotate_180=rotate_180)
    else:
        render_asinh_jpeg(out_img, out_path, rotate_180=rotate_180)
    print(f"  closed window {idx:05d}  ({len(in_win)} frames)")


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__.split("\n", 1)[0])
    ap.add_argument("--camera", required=True)
    ap.add_argument("--night", required=True, metavar="YYYY-MM-DD")
    ap.add_argument("--sweep-start", required=True, metavar="HH:MM")
    ap.add_argument("--sweep-end", required=True, metavar="HH:MM")
    ap.add_argument("--window-min", type=int, default=10)
    ap.add_argument("--step-min", type=int, default=1)
    ap.add_argument("--out-dir", required=True, type=Path)
    ap.add_argument("--rgb", action="store_true",
                    help="alias for --colour (operate per RGB plane)")
    ap.add_argument("--colour", action="store_true",
                    help="operate per RGB plane (de-bayered)")
    ap.add_argument("--noise-floor-mult", type=float, default=0.0,
                    metavar="M",
                    help="subtract M × σ × sqrt(2 ln N) per pixel before "
                         "rendering (M=0 disables, M=1 cancels the "
                         "statistical max-of-N-Gaussians floor exactly)")
    ap.add_argument("--mean-mult", type=float, default=1.0,
                    metavar="K",
                    help="multiply the subtracted mean by K (default 1.0). "
                         "K>1 pushes residual sky-glow into the negatives "
                         "for an 'extra dark sky' aesthetic; K<1 leaves "
                         "more pedestal in.")
    ap.add_argument("--signed", action="store_true",
                    help="keep negative values instead of clipping at 0")
    ap.add_argument("--neg-blue", action="store_true",
                    help="render negative values as a blue lobe; implies "
                         "--signed")
    ap.add_argument("--fps", type=int, default=60)
    ap.add_argument("--no-mp4", action="store_true")
    ap.add_argument("--synthetic", type=int, default=0, metavar="N")
    ap.add_argument("--line-filter", action="store_true",
                    help="keep star trails, suppress dots + non-linear cloud "
                         "via a per-pixel oriented open along the analytic "
                         "(k1,k2 + detrans angle) trail direction. Cleaner, "
                         "lower-bandwidth diff mp4. Needs distortion+detrans "
                         "in camera.json.")
    ap.add_argument("--line-L", type=int, default=7,
                    help="line-filter kernel length (px, ~trail length).")
    args = ap.parse_args()
    if args.neg_blue:
        args.signed = True
    if args.colour:
        args.rgb = True

    window = timedelta(minutes=args.window_min)
    step = timedelta(minutes=args.step_min)
    sweep_start = parse_hhmm_to_utc(args.night, args.sweep_start)
    sweep_end = parse_hhmm_to_utc(args.night, args.sweep_end)
    windows = list_windows(sweep_start, sweep_end, window, step)

    rotate_180 = False
    if args.synthetic:
        H, W = 200, 200
        cadence_s = (sweep_end - sweep_start).total_seconds() / args.synthetic
        frames_iter = synthetic_frames(args.synthetic, H, W,
                                       cadence_s, sweep_start)
        rgb_pattern = None
    else:
        cfg = CameraConfig.load(args.camera)
        rgb_pattern = None
        if args.rgb:
            rgb_pattern = bayer.pattern(cfg.get("bayer") or "")
        rotate_180 = bool(cfg.get("rotate_180"))
        all_frames = list_night_frames(cfg, args.night)
        all_frames = [(t, f) for (t, f) in all_frames
                      if sweep_start <= t < sweep_end + window]
        if not all_frames:
            print("no frames in sweep range", file=sys.stderr)
            return 1

        def gen():
            for t, p in all_frames:
                yield t, load_fits_binned(p, rgb_pattern)
        frames_iter = gen()

    args.out_dir.mkdir(parents=True, exist_ok=True)
    frames_dir = args.out_dir / "frames"
    frames_dir.mkdir(exist_ok=True)

    pending = list(windows)
    recent = deque()  # (t, binned_frame)

    # Trail line-filter setup: build the analytic per-pixel orientation field
    # once from camera.json (distortion k1,k2 + detrans motion angle). Built
    # lazily on the first frame so we know the binned (H, W).
    line_field = None
    line_ready = [False]  # mutable flag for the lazy build

    def ensure_line_field(frame):
        if line_ready[0] or not args.line_filter:
            return line_field
        dist = (cfg.get("distortion") or {}) if not args.synthetic else {}
        detr = (cfg.get("detrans") or {}) if not args.synthetic else {}
        if not dist or "angle_deg" not in detr:
            print("--line-filter: camera has no distortion+detrans block; "
                  "skipping the filter", file=sys.stderr)
            line_ready[0] = True
            return None
        h, w = frame.shape[:2]
        field = trail_angle_field(h, w, dist["k1"], dist["k2"],
                                  detr["angle_deg"])
        print(f"line-filter: analytic orientation field {w}x{h} "
              f"(angle {detr['angle_deg']}deg, k1={dist['k1']})")
        line_ready[0] = True
        return field

    n = 0
    for t, frame in frames_iter:
        recent.append((t, frame))
        n += 1
        if args.line_filter and not line_ready[0]:
            line_field = ensure_line_field(frame)

        # Close every window whose end has passed.
        while pending and pending[0][2] <= t:
            idx, ws, we = pending.pop(0)
            close_window(idx, ws, we, recent, rgb_pattern,
                         frames_dir, rotate_180,
                         noise_floor_mult=args.noise_floor_mult,
                         mean_mult=args.mean_mult,
                         signed=args.signed, neg_blue=args.neg_blue,
                         line_field=line_field, line_L=args.line_L)

        # Prune deque: drop frames older than the oldest still-open
        # window's start.
        oldest_needed = pending[0][1] if pending else None
        while recent and oldest_needed is not None \
                and recent[0][0] < oldest_needed:
            recent.popleft()

        if n % 100 == 0:
            print(f"  frame {n}  pending={len(pending)} deque={len(recent)}")

    # Drain remaining windows whose end didn't quite arrive.
    while pending:
        idx, ws, we = pending.pop(0)
        close_window(idx, ws, we, recent, rgb_pattern,
                     frames_dir, rotate_180,
                     noise_floor_mult=args.noise_floor_mult,
                     signed=args.signed, neg_blue=args.neg_blue,
                     line_field=line_field, line_L=args.line_L)

    print(f"diff-sweep: {n} frames in, {len(windows)} JPEGs written")

    if not args.no_mp4:
        import subprocess
        out_mp4 = args.out_dir / "sweep.mp4"
        # frame_%05d uses the *window* index, which is sparse (skipped
        # windows leave gaps and the first frame is rarely 00000), so the
        # image2 demuxer's contiguous-from-start_number assumption fails.
        # Glob the frames that actually exist instead.
        # x264 memory scales with preset/threads (decoded frames held
        # resident) — -preset medium OOM'd the 1GB Pi. Honour the host-aware
        # FFMPEG_PRESET/THREADS set by publish-night-cam; default safe.
        _preset = os.environ.get("FFMPEG_PRESET", "veryfast")
        _threads = os.environ.get("FFMPEG_THREADS", "1")
        rc = subprocess.run(["ffmpeg", "-y", "-loglevel", "error",
                             "-threads", str(_threads),
                             "-framerate", str(args.fps),
                             "-pattern_type", "glob",
                             "-i", str(frames_dir / "frame_*.jpg"),
                             "-c:v", "libx264", "-pix_fmt", "yuv420p",
                             "-crf", "20", "-preset", _preset,
                             str(out_mp4)], check=False).returncode
        if rc != 0 or not out_mp4.exists():
            print(f"ffmpeg failed (rc={rc}); no {out_mp4}", file=sys.stderr)
            return 1
        print(f"wrote {out_mp4}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
