#!/usr/bin/env python3
"""photon-sum — accumulate the darkest K% of frames in a time window.

The "photon sum" of dark frames is the canonical first product:
abs-diff dark sky cancels, hot pixels cancel, real arcs accumulate.
The 2026-05-20 session's photon_dark50.jpg (50% darkest, 22:30–03:00)
revealed 50+ visible star arcs.

Inputs:
  brightness CSV from scan-brightness
  time window (UTC HH:MM, may wrap midnight)
  percentile to keep (default 50)

Outputs:
  .npy of the int64 accumulator (canonical, lossless)
  .jpg with linear stretch (target-median grey)

Usage:
    photon-sum --csv night.csv --window 22:30-03:00
    photon-sum --csv night.csv --window 22:30-03:00 --pct 25
    photon-sum --csv night.csv --window 22:30-03:00 --out-prefix dark50
"""
from __future__ import annotations

import argparse
import csv
import os
import sys
import time
from datetime import datetime
from pathlib import Path

import numpy as np
import cv2
from astropy.io import fits


def load_frame(path: Path) -> np.ndarray:
    if path.suffix == ".npy":
        return np.load(path)
    with fits.open(path, memmap=False) as h:
        for hdu in h:
            if hdu.data is not None and hdu.data.ndim == 2:
                return hdu.data.copy()
    raise SystemExit(f"no 2D image in {path}")


def parse_window(s: str) -> tuple[int, int, bool]:
    """'HH:MM-HH:MM' → (start_minutes, end_minutes, wraps_midnight)."""
    a, b = s.split("-")
    def to_min(x):
        h, m = x.split(":")
        return int(h) * 60 + int(m)
    sm = to_min(a)
    em = to_min(b)
    return sm, em, em <= sm


def in_window(iso: str, sm: int, em: int, wraps: bool) -> bool:
    dt = datetime.fromisoformat(iso)
    m = dt.hour * 60 + dt.minute
    if wraps:
        return m >= sm or m < em
    return sm <= m < em


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__.split("\n", 1)[0])
    ap.add_argument("--csv", required=True, type=Path)
    ap.add_argument("--window", required=True,
                    help="UTC range as HH:MM-HH:MM (may wrap midnight)")
    ap.add_argument("--pct", type=float, default=50,
                    help="keep darkest N%% of frames in window (default 50)")
    ap.add_argument("--out-prefix", default=None,
                    help="output basename (default: photon_<window>_<pct>)")
    ap.add_argument("--target-median", type=int, default=50,
                    help="JPG stretch target median grey 0–255 (default 50)")
    args = ap.parse_args()

    if not args.csv.exists():
        sys.stderr.write(f"no csv: {args.csv}\n")
        return 2

    sm, em, wraps = parse_window(args.window)

    # Filter CSV → (filename, mean) in window
    rows: list[tuple[Path, float]] = []
    with open(args.csv) as f:
        for r in csv.DictReader(f):
            if in_window(r["iso_utc"], sm, em, wraps):
                rows.append((Path(r["filename"]), float(r["mean"])))
    print(f"in window {args.window} UTC: {len(rows)} frames")
    if not rows:
        return 1

    rows.sort(key=lambda x: x[1])
    k = int(len(rows) * args.pct / 100)
    selected = rows[:k]
    print(f"darkest {args.pct}%: {len(selected)} frames "
          f"(brightest kept: mean={selected[-1][1]:.2f})")

    # Accumulate
    h, w = load_frame(selected[0][0]).shape
    acc = np.zeros((h, w), dtype=np.int64)
    t0 = time.time()
    for i, (fn, _) in enumerate(selected):
        acc += load_frame(fn).astype(np.int32)
        if i == 0 or i % 200 == 0:
            elapsed = time.time() - t0
            rate = (i + 1) / max(0.001, elapsed)
            print(f"  [{i}/{len(selected)}] ({rate:.1f} fps)", flush=True)
    elapsed = time.time() - t0
    print(f"summed in {elapsed:.1f}s "
          f"({len(selected)/max(0.001,elapsed):.1f} fps)")
    print(f"acc: min={int(acc.min())} max={int(acc.max())} "
          f"mean={acc.mean():.1f} median={int(np.median(acc))}")

    # Output names
    prefix = args.out_prefix
    if prefix is None:
        win = args.window.replace(":", "").replace("-", "_")
        prefix = f"photon_{win}_p{int(args.pct)}"

    out_npy = Path(f"{prefix}.npy")
    out_jpg = Path(f"{prefix}.jpg")
    np.save(out_npy, acc)
    print(f"wrote {out_npy} ({os.path.getsize(out_npy)/1e6:.1f} MB)")

    med = float(np.median(acc.astype(np.float32)))
    scale = args.target_median / max(1.0, med)
    print(f"stretch: median {med:.1f} → grey {args.target_median} "
          f"(scale {scale:.4f})")
    img8 = np.clip(acc.astype(np.float32) * scale,
                   0, 255).astype(np.uint8)
    cv2.imwrite(str(out_jpg), img8, [cv2.IMWRITE_JPEG_QUALITY, 92])
    print(f"wrote {out_jpg} ({os.path.getsize(out_jpg)/1024:.0f} KB)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
