#!/usr/bin/env python3
"""photon-sum — accumulate the darkest K% of frames in a time window.

The "photon sum" of dark frames is the canonical first product:
abs-diff dark sky cancels, hot pixels cancel, real arcs accumulate.
The 2026-05-20 session's photon_dark50.jpg (50% darkest, 22:30–03:00)
revealed 50+ visible star arcs.

Inputs:
  brightness CSV from scan-brightness
  time window (UTC HH:MM, may wrap midnight)
  percentile to keep (default 50)

Outputs:
  .npy of the int64 accumulator (canonical, lossless)
  .jpg with linear stretch (target-median grey)

Usage:
    photon-sum --csv night.csv --window 22:30-03:00
    photon-sum --csv night.csv --window 22:30-03:00 --pct 25
    photon-sum --csv night.csv --window 22:30-03:00 --out-prefix dark50
"""
from __future__ import annotations

import argparse
import csv
import os
import sys
import time
from datetime import datetime
from pathlib import Path

import numpy as np
import cv2
from astropy.io import fits


def load_frame(path: Path) -> np.ndarray:
    if path.suffix == ".npy":
        return np.load(path)
    with fits.open(path, memmap=False) as h:
        for hdu in h:
            if hdu.data is not None and hdu.data.ndim == 2:
                return hdu.data.copy()
    raise SystemExit(f"no 2D image in {path}")


def parse_window(s: str) -> tuple[int, int, bool]:
    """'HH:MM-HH:MM' → (start_minutes, end_minutes, wraps_midnight)."""
    a, b = s.split("-")
    def to_min(x):
        h, m = x.split(":")
        return int(h) * 60 + int(m)
    sm = to_min(a)
    em = to_min(b)
    return sm, em, em <= sm


def in_window(iso: str, sm: int, em: int, wraps: bool) -> bool:
    dt = datetime.fromisoformat(iso)
    m = dt.hour * 60 + dt.minute
    if wraps:
        return m >= sm or m < em
    return sm <= m < em


EXAMPLES = """\
Examples:
  photon-sum --csv ~/starcam-frames/night/2026-05-21/brightness.csv \\
             --window 22:30-03:00
      → reproduce last session's photon_dark50 (default pct=50)
        outputs: photon_2230_0300_p50.npy + .jpg

  photon-sum --csv .../brightness.csv --window 22:30-03:00 --pct 25
      → only the darkest 25% (cleaner, fewer frames, less SNR)

  photon-sum --csv .../brightness.csv --window 00:00-01:00 \\
             --out-prefix midnight --stretch-lo 60 --stretch-hi 99.9
      → 1-hour window, custom output name, more aggressive stretch
        (only the very top 0.1% mapped to white = arcs vs floor)

  photon-sum --csv .../brightness.csv --window 22:30-03:00 \\
             --target-median 50
      → legacy linear stretch (median → grey 50). Use only for
        reproducing pre-2026-05-22 outputs.

Window wraps midnight automatically if end < start.

The default percentile stretch puts p50 at black and p99.5 at white
— maps the noise floor to black so faint arcs are visible. This is
what made last session's photon_dark50.jpg work; the early
'median → grey 50' linear stretch crushed the data.

The .npy contains the full int64 accumulator (lossless, ~40 MB).
The .jpg is 8-bit with the stretch applied.
"""


def main() -> int:
    ap = argparse.ArgumentParser(
        description=__doc__.split("\n", 1)[0],
        epilog=EXAMPLES,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    ap.add_argument("--csv", required=True, type=Path,
                    help="brightness CSV from scan-brightness")
    ap.add_argument("--window", required=True,
                    help="UTC range as HH:MM-HH:MM (may wrap midnight)")
    ap.add_argument("--pct", type=float, default=50,
                    help="keep darkest N%% of frames in window (default 50)")
    ap.add_argument("--out-prefix", default=None,
                    help="output basename (default: photon_<window>_p<pct>)")
    ap.add_argument("--stretch-lo", type=float, default=50,
                    help="lower-bound percentile for JPG stretch (default 50; "
                         "this is mapped to black). Higher = darker, more contrast.")
    ap.add_argument("--stretch-hi", type=float, default=99.5,
                    help="upper-bound percentile for JPG stretch (default 99.5; "
                         "this is mapped to white)")
    ap.add_argument("--target-median", type=int, default=0,
                    help="[DEPRECATED] legacy 'median → grey N' stretch. "
                         "If non-zero, overrides --stretch-lo/hi.")
    args = ap.parse_args()

    if not args.csv.exists():
        sys.stderr.write(f"no csv: {args.csv}\n")
        return 2

    sm, em, wraps = parse_window(args.window)

    # Filter CSV → (filename, mean) in window
    rows: list[tuple[Path, float]] = []
    with open(args.csv) as f:
        for r in csv.DictReader(f):
            if in_window(r["iso_utc"], sm, em, wraps):
                rows.append((Path(r["filename"]), float(r["mean"])))
    print(f"in window {args.window} UTC: {len(rows)} frames")
    if not rows:
        return 1

    rows.sort(key=lambda x: x[1])
    k = int(len(rows) * args.pct / 100)
    selected = rows[:k]
    print(f"darkest {args.pct}%: {len(selected)} frames "
          f"(brightest kept: mean={selected[-1][1]:.2f})")

    # Accumulate
    h, w = load_frame(selected[0][0]).shape
    acc = np.zeros((h, w), dtype=np.int64)
    t0 = time.time()
    for i, (fn, _) in enumerate(selected):
        acc += load_frame(fn).astype(np.int32)
        if i == 0 or i % 200 == 0:
            elapsed = time.time() - t0
            rate = (i + 1) / max(0.001, elapsed)
            print(f"  [{i}/{len(selected)}] ({rate:.1f} fps)", flush=True)
    elapsed = time.time() - t0
    print(f"summed in {elapsed:.1f}s "
          f"({len(selected)/max(0.001,elapsed):.1f} fps)")
    print(f"acc: min={int(acc.min())} max={int(acc.max())} "
          f"mean={acc.mean():.1f} median={int(np.median(acc))}")

    # Output names
    prefix = args.out_prefix
    if prefix is None:
        win = args.window.replace(":", "").replace("-", "_")
        prefix = f"photon_{win}_p{int(args.pct)}"

    out_npy = Path(f"{prefix}.npy")
    out_jpg = Path(f"{prefix}.jpg")
    np.save(out_npy, acc)
    print(f"wrote {out_npy} ({os.path.getsize(out_npy)/1e6:.1f} MB)")

    acc_f = acc.astype(np.float32)
    if args.target_median > 0:
        # legacy: median → target grey
        med = float(np.median(acc_f))
        scale = args.target_median / max(1.0, med)
        print(f"stretch (legacy): median {med:.1f} → grey "
              f"{args.target_median} (scale {scale:.4f})")
        img8 = np.clip(acc_f * scale, 0, 255).astype(np.uint8)
    else:
        lo = float(np.percentile(acc_f, args.stretch_lo))
        hi = float(np.percentile(acc_f, args.stretch_hi))
        print(f"stretch: p{args.stretch_lo}={lo:.1f} → black, "
              f"p{args.stretch_hi}={hi:.1f} → white")
        if hi <= lo:
            print("  (warning: hi <= lo; image will be flat)")
            hi = lo + 1
        img8 = np.clip(
            (acc_f - lo) * 255.0 / (hi - lo),
            0, 255).astype(np.uint8)
    cv2.imwrite(str(out_jpg), img8, [cv2.IMWRITE_JPEG_QUALITY, 92])
    print(f"wrote {out_jpg} ({os.path.getsize(out_jpg)/1024:.0f} KB)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
