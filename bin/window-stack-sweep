#!/usr/bin/env python3
"""window-stack-sweep — sliding-window max-stack JPEG sequence + mp4.

Drives bin/window-stack across a span like 23:00 → 04:00 UTC with a
fixed window length (default 10 min) sliding by a fixed step (default
1 min). Concurrent rendering via multiprocessing. Stitches the JPEGs
into a 60fps mp4 with ffmpeg.

Was a bash script with embedded Python heredocs. The heredocs broke
in subtle bash-y ways (silent failures, line-number mis-reporting on
errors) and the structure made the autostart/autoend logic hard to
test. Rewritten as straight Python — same CLI surface.

Usage:
    window-stack-sweep --camera eclipticam-v3w \\
        --night 2026-06-09 \\
        --sweep-start 23:00 --sweep-end 04:00 \\
        --window-min 10 --step-min 1 \\
        --out-dir ~/tmp/v3w-video \\
        [--fps 60] [--jobs 8] [--no-mp4] [--force]

Frames land at <out-dir>/frames/frame_NNNNN.jpg, video at <out-dir>/sweep.mp4.
Already-rendered frames are skipped unless --force is given.
"""
from __future__ import annotations

import argparse
import os
import subprocess
import sys
from concurrent.futures import ProcessPoolExecutor, as_completed
from datetime import datetime, timedelta, timezone
from pathlib import Path
from zoneinfo import ZoneInfo

REPO = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(REPO))

import numpy as np

from astro.config import CameraConfig


def hhmm_to_utc(hhmm: str, night: datetime.date) -> datetime:
    """Resolve HH:MM UTC inside the noon-rollover night-of date."""
    h, m = (int(x) for x in hhmm.split(":"))
    day = night if h >= 12 else night + timedelta(days=1)
    return datetime.combine(day, datetime.min.time(),
                            tzinfo=timezone.utc).replace(hour=h, minute=m)


def load_brightness_csv(csv_path: Path):
    """Returns (times: list[datetime], means: np.ndarray, per_s_or_None).
    None if the file is missing / unreadable."""
    import csv as _csv
    from astropy.io import fits as _fits
    if not csv_path.exists():
        return None, None, None
    rows_t, means, per_s = [], [], []
    seen_exp_gain = None
    with open(csv_path) as fh:
        for row in _csv.DictReader(fh):
            try:
                t = datetime.fromisoformat(row["iso_utc"])
                if t.tzinfo is None:
                    t = t.replace(tzinfo=timezone.utc)
                m = float(row["mean"])
            except (KeyError, ValueError):
                continue
            if seen_exp_gain is None:
                try:
                    with _fits.open(row["filename"]) as h:
                        hdr = h[1].header
                    seen_exp_gain = (
                        float(hdr.get("EXPTIME", 1.0) or 1.0),
                        float(hdr.get("GAIN", 1.0) or 1.0))
                except (OSError, KeyError, ValueError):
                    seen_exp_gain = (1.0, 1.0)
            exp, gain = seen_exp_gain
            rows_t.append(t)
            means.append(m)
            per_s.append(m / (exp * gain) if exp * gain > 0 else m)
    if not rows_t:
        return None, None, None
    order = sorted(range(len(rows_t)), key=lambda i: rows_t[i])
    times = [rows_t[i] for i in order]
    return times, np.array([means[i] for i in order]), \
        np.array([per_s[i] for i in order])


def autostart(times, means, pedestal, start, end, window, step,
              auto_start_stops):
    """Shift start later: must be AFTER the last pre-dark flap (frames
    below -2 stops) AND inside a 30-min stable dark stretch (mean per
    window stays below auto_start_stops). Returns the chosen start."""
    FLAP_STOPS = -2.0
    BUFFER = timedelta(minutes=5)
    STABLE_MIN = 30
    per_frame_stops = np.log2(np.maximum(means - pedestal, 0.5))

    first_dark_t = None
    t = start
    while t + window <= end:
        ok = True
        t_check = t
        while t_check <= t + timedelta(minutes=STABLE_MIN):
            w_end = t_check + window
            in_win = [i for i, ti in enumerate(times)
                      if t_check <= ti < w_end]
            if not in_win:
                ok = False
                break
            mc = float(means[in_win].mean())
            stops_w = float(np.log2(max(mc - pedestal, 0.5)))
            if stops_w >= auto_start_stops:
                ok = False
                break
            t_check += step
        if ok:
            first_dark_t = t
            break
        t += step

    flap_idx = [i for i, ti in enumerate(times)
                if per_frame_stops[i] < FLAP_STOPS
                and (first_dark_t is None or ti <= first_dark_t + window)]
    last_flap_t = times[flap_idx[-1]] if flap_idx else None

    sys.stderr.write(
        f"auto-start: first window <{auto_start_stops:+.1f} stops = "
        f"{first_dark_t.strftime('%H:%M') if first_dark_t else 'never'} UTC; "
        f"last pre-dark flap = "
        f"{last_flap_t.strftime('%H:%M:%S') if last_flap_t else 'none'} UTC\n")

    candidates = [c for c in (first_dark_t,
                              last_flap_t + BUFFER if last_flap_t else None)
                  if c is not None]
    if candidates:
        chosen = max(candidates)
        sys.stderr.write(
            f"auto-start: shifted from {start.strftime('%H:%M')} to "
            f"{chosen.strftime('%H:%M')} UTC\n")
        return chosen
    sys.stderr.write(
        f"auto-start: no window matched, keeping {start.strftime('%H:%M')}\n")
    return start


def autoend(times, means, pedestal, start, end, window, step,
            auto_end_stops):
    """Stop at the first window AFTER start whose mean rises above the
    threshold. Dawn is monotonic so a single trigger is enough."""
    t = start + window
    while t + window <= end:
        w_end = t + window
        in_win = [i for i, ti in enumerate(times) if t <= ti < w_end]
        if in_win:
            mc = float(means[in_win].mean())
            stops_w = float(np.log2(max(mc - pedestal, 0.5)))
            if stops_w > auto_end_stops:
                sys.stderr.write(
                    f"auto-end: stopping at {w_end.strftime('%H:%M')} UTC "
                    f"(first window above +{auto_end_stops:.1f} stops)\n")
                return w_end
        t += step
    return end


def window_label(w_start, w_end, times, means, pedestal, tz):
    centre = w_start + (w_end - w_start) / 2
    hhmm_local = centre.astimezone(tz).strftime("%H:%M")
    if times is None or pedestal is None:
        return hhmm_local
    in_win = [i for i, t in enumerate(times) if w_start <= t < w_end]
    if not in_win:
        return hhmm_local
    mean_count = float(means[in_win].mean())
    signal = max(mean_count - pedestal, 0.5)
    stops = float(np.log2(signal))
    return f"{hhmm_local}   {stops:+.1f} stops"


def render_one(args):
    """Worker: render one window via bin/window-stack."""
    (idx, camera, night, w_start_hhmm, w_end_hhmm, label, out_path,
     rgb, force, here_py, here_bin) = args
    if not force and out_path.exists() and out_path.stat().st_size > 0:
        return idx, "skip"
    cmd = [here_py, str(here_bin / "window-stack"),
           "--camera", camera, "--night", night,
           "--window-start", w_start_hhmm, "--window-end", w_end_hhmm,
           "--out", str(out_path), "--quiet"]
    if label:
        cmd += ["--label", label]
    if rgb:
        cmd += ["--rgb"]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.returncode == 0:
            return idx, "ok"
        return idx, f"FAIL rc={result.returncode}: {result.stderr.strip()[-200:]}"
    except OSError as e:
        return idx, f"FAIL exec: {e}"


def main() -> int:
    ap = argparse.ArgumentParser(
        description=__doc__.split("\n", 1)[0],
        formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("--camera", required=True)
    ap.add_argument("--night", required=True, metavar="YYYY-MM-DD")
    ap.add_argument("--sweep-start", required=True, metavar="HH:MM")
    ap.add_argument("--sweep-end", required=True, metavar="HH:MM")
    ap.add_argument("--window-min", type=int, default=10)
    ap.add_argument("--step-min", type=int, default=1)
    ap.add_argument("--out-dir", required=True, type=Path)
    ap.add_argument("--fps", type=int, default=60)
    ap.add_argument("--jobs", type=int, default=8)
    ap.add_argument("--no-mp4", action="store_true")
    ap.add_argument("--force", action="store_true")
    ap.add_argument("--brightness-csv", default=None, type=Path,
                    help="Per-frame brightness CSV. Used by auto-start/end "
                         "and to burn a stops-above-pedestal value into "
                         "each frame's label.")
    ap.add_argument("--stagger-s", type=float, default=0.0,
                    help="(unused, retained for shell-script CLI compat)")
    ap.add_argument("--rgb", action="store_true")
    ap.add_argument("--no-label", action="store_true")
    ap.add_argument("--auto-start-stops", type=float, default=None)
    ap.add_argument("--auto-end-stops", type=float, default=None)
    ap.add_argument("--label-tz", default="Europe/London")
    args = ap.parse_args()

    out_dir = args.out_dir
    frames_dir = out_dir / "frames"
    frames_dir.mkdir(parents=True, exist_ok=True)

    night_d = datetime.strptime(args.night, "%Y-%m-%d").date()
    tz = ZoneInfo(args.label_tz)
    start = hhmm_to_utc(args.sweep_start, night_d)
    end = hhmm_to_utc(args.sweep_end, night_d)
    window = timedelta(minutes=args.window_min)
    step = timedelta(minutes=args.step_min)

    cfg = CameraConfig.load(args.camera)
    fixed_pedestal = cfg.get("pedestal")

    times = means = per_s = pedestal = None
    if args.brightness_csv:
        times, means, per_s = load_brightness_csv(args.brightness_csv)
        if means is not None:
            pedestal = (float(fixed_pedestal) if fixed_pedestal is not None
                        else float(np.percentile(means, 1)))

    if args.auto_start_stops is not None and times is not None:
        start = autostart(times, means, pedestal, start, end, window, step,
                          args.auto_start_stops)
    if args.auto_end_stops is not None and times is not None:
        end = autoend(times, means, pedestal, start, end, window, step,
                      args.auto_end_stops)

    # Build job list
    jobs = []
    here_bin = REPO / "bin"
    here_py = sys.executable
    n = 0
    t = start
    while t + window <= end:
        w_end = t + window
        label = ("" if args.no_label
                 else window_label(t, w_end, times, means, pedestal, tz))
        out_path = frames_dir / f"frame_{n:05d}.jpg"
        jobs.append((n, args.camera, args.night,
                     t.strftime("%H:%M"), w_end.strftime("%H:%M"),
                     label, out_path, args.rgb, args.force,
                     here_py, here_bin))
        n += 1
        t += step

    if not jobs:
        sys.stderr.write("no windows to render — sweep range yields zero jobs\n")
        return 1

    print(f"sweep: {args.sweep_start} - {args.sweep_end}  "
          f"window={args.window_min}min  step={args.step_min}min")
    print(f"frames: {len(jobs)}  jobs={args.jobs}")
    if args.brightness_csv:
        print(f"brightness CSV: {args.brightness_csv} "
              f"({len(times) if times else 0} rows, "
              f"pedestal={pedestal})")

    t0 = datetime.now(timezone.utc)
    n_ok = n_skip = n_fail = 0
    failed = []
    with ProcessPoolExecutor(max_workers=args.jobs) as pool:
        for idx, status in pool.map(render_one, jobs):
            if status == "ok":
                n_ok += 1
            elif status == "skip":
                n_skip += 1
            else:
                n_fail += 1
                failed.append((idx, status))
    dt = (datetime.now(timezone.utc) - t0).total_seconds()
    print(f"rendered {n_ok} new, {n_skip} skipped, {n_fail} failed in {dt:.1f}s")
    for idx, status in failed[:5]:
        print(f"  frame {idx:05d}: {status}")
    if n_fail and not (n_ok + n_skip):
        return 1

    if args.no_mp4:
        return 0

    out_mp4 = out_dir / "sweep.mp4"
    # x264 memory scales with preset (lookahead depth) and thread count:
    # each holds decoded full-res frames resident. -preset medium on a 1 GB
    # Pi OOM'd assembling a ~250-frame 2304x1064 sweep (ffmpeg swapped hard,
    # then the box rebooted). Pick preset + threads by available RAM so big
    # hosts (puppy 8 GB) keep quality and small hosts stay alive. Override
    # with FFMPEG_PRESET / FFMPEG_THREADS env.
    import os as _os
    try:
        with open("/proc/meminfo") as _mi:
            _mem_gib = int(next(l for l in _mi if l.startswith("MemTotal")).split()[1]) / 1024 / 1024
    except (OSError, StopIteration, ValueError):
        _mem_gib = 4.0
    if _mem_gib < 2:
        _preset, _threads = "veryfast", "1"   # 1 GB Pi: minimal lookahead/buffers
    elif _mem_gib < 6:
        _preset, _threads = "fast", "2"
    else:
        _preset, _threads = "medium", "0"      # 0 = ffmpeg auto (big hosts)
    _preset = _os.environ.get("FFMPEG_PRESET", _preset)
    _threads = _os.environ.get("FFMPEG_THREADS", _threads)
    # The real memory lever is x264's frame queues: the lookahead buffer
    # holds many decoded frames at once. Cap it hard on small hosts (and let
    # publish-night-cam override). rc-lookahead=10 + sync-lookahead=0 + bf=0
    # bounds the resident frame count to a handful regardless of clip length.
    _default_x264 = ("rc-lookahead=10:sync-lookahead=0:bframes=0"
                     if _mem_gib < 2 else "")
    _x264 = _os.environ.get("FFMPEG_X264_PARAMS", _default_x264)
    print(f"stitching {out_mp4} at {args.fps}fps "
          f"(preset={_preset} threads={_threads} mem={_mem_gib:.1f}G "
          f"x264='{_x264}')...")
    cmd = ["ffmpeg", "-y", "-loglevel", "error",
           "-threads", str(_threads),
           "-framerate", str(args.fps),
           "-i", str(frames_dir / "frame_%05d.jpg"),
           "-c:v", "libx264", "-pix_fmt", "yuv420p",
           "-crf", "20", "-preset", _preset]
    if _x264:
        cmd += ["-x264-params", _x264]
    cmd += [str(out_mp4)]
    rc = subprocess.call(cmd)
    if rc != 0:
        sys.stderr.write(f"ffmpeg failed rc={rc}\n")
        return 1
    print(f"wrote {out_mp4}  ({out_mp4.stat().st_size // 1024} KB)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
