#!/usr/bin/env bash
# window-stack-sweep — generate a sliding-window JPEG sequence + mp4.
#
# Drives bin/window-stack across a span like 23:00 → 04:00 UTC with a
# fixed window length (default 10 min) sliding by a fixed step (default
# 1 min). 8-way concurrent via xargs -P. Stitches the JPEGs into a
# 60fps mp4 with ffmpeg.
#
# Usage:
#     window-stack-sweep --camera eclipticam --subcam v3w \
#         --night 2026-06-09 \
#         --sweep-start 23:00 --sweep-end 04:00 \
#         --window-min 10 --step-min 1 \
#         --out-dir ~/tmp/v3w-video \
#         [--fps 60] [--jobs 8] [--no-mp4] [--force]
#
# Frames land at <out-dir>/frames/frame_NNNN.jpg, video at <out-dir>/sweep.mp4.
# Already-rendered frames are skipped unless --force is given.
set -euo pipefail

CAMERA=""; SUBCAM=""; NIGHT=""; SWEEP_START=""; SWEEP_END=""
WINDOW_MIN=10; STEP_MIN=1; OUT_DIR=""; FPS=60; JOBS=8
NO_MP4=0; FORCE=0; BRIGHTNESS_CSV=""; STAGGER_S=0
LABEL_TZ="Europe/London"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --camera)       CAMERA="$2";       shift 2;;
        --subcam)       SUBCAM="$2";       shift 2;;
        --night)        NIGHT="$2";        shift 2;;
        --sweep-start)  SWEEP_START="$2";  shift 2;;
        --sweep-end)    SWEEP_END="$2";    shift 2;;
        --window-min)   WINDOW_MIN="$2";   shift 2;;
        --step-min)     STEP_MIN="$2";     shift 2;;
        --out-dir)      OUT_DIR="$2";      shift 2;;
        --fps)          FPS="$2";          shift 2;;
        --jobs)         JOBS="$2";         shift 2;;
        --no-mp4)       NO_MP4=1;          shift;;
        --force)        FORCE=1;           shift;;
        --brightness-csv) BRIGHTNESS_CSV="$2"; shift 2;;
        --stagger-s)    STAGGER_S="$2";    shift 2;;
        -h|--help)      sed -n '1,/^set -euo/p' "$0" | head -n -1; exit 0;;
        *)              echo "unknown arg: $1" >&2; exit 2;;
    esac
done

for arg in CAMERA NIGHT SWEEP_START SWEEP_END OUT_DIR; do
    [[ -n "${!arg}" ]] || { echo "--${arg,,} required" >&2; exit 2; }
done

HERE="$(cd "$(dirname "$0")" && pwd)"
REPO="$(cd "$HERE/.." && pwd)"
PY="${ASTRO_VENV_PY:-$REPO/.venv/bin/python}"
[[ -x "$PY" ]] || PY="$HOME/astro/.venv/bin/python"  # puppy convention

mkdir -p "$OUT_DIR/frames"

# Build the job list with python (cross-midnight, noon-rollover math).
JOBS_LIST=$(mktemp)
trap "rm -f '$JOBS_LIST'" EXIT
"$PY" - <<PYEOF > "$JOBS_LIST"
import csv, os
from datetime import datetime, timedelta, timezone
from zoneinfo import ZoneInfo
import numpy as np

night_d = datetime.strptime("$NIGHT", "%Y-%m-%d").date()
TZ = ZoneInfo("$LABEL_TZ")

def hhmm_to_utc(hhmm):
    h, m = (int(x) for x in hhmm.split(":"))
    day = night_d if h >= 12 else night_d + timedelta(days=1)
    return datetime.combine(day, datetime.min.time(),
                            tzinfo=timezone.utc).replace(hour=h, minute=m)

start = hhmm_to_utc("$SWEEP_START")
end   = hhmm_to_utc("$SWEEP_END")
window = timedelta(minutes=$WINDOW_MIN)
step   = timedelta(minutes=$STEP_MIN)

# Load brightness CSV if given, build sorted (utc_dt, per_s) arrays.
csv_path = "$BRIGHTNESS_CSV"
times_arr = vals_per_s = pedestal = None
if csv_path:
    rows_t, rows_per_s, means = [], [], []
    # Need EXPTIME/GAIN per row — pull from FITS header lazily; if all
    # frames share the same exposure (the eclipticam case) one peek is
    # enough. Fall back to mean if exposure unknown.
    from astropy.io import fits as _fits
    seen_exp_gain = None
    with open(csv_path) as fh:
        for row in csv.DictReader(fh):
            try:
                t = datetime.fromisoformat(row["iso_utc"])
                if t.tzinfo is None:
                    t = t.replace(tzinfo=timezone.utc)
                m = float(row["mean"])
            except (KeyError, ValueError):
                continue
            if seen_exp_gain is None:
                try:
                    with _fits.open(row["filename"]) as h:
                        hdr = h[1].header
                    seen_exp_gain = (float(hdr.get("EXPTIME", 1.0) or 1.0),
                                     float(hdr.get("GAIN", 1.0) or 1.0))
                except (OSError, KeyError, ValueError):
                    seen_exp_gain = (1.0, 1.0)
            exp, gain = seen_exp_gain
            rows_t.append(t)
            means.append(m)
            rows_per_s.append(m / (exp * gain) if exp * gain > 0 else m)
    if rows_t:
        order = sorted(range(len(rows_t)), key=lambda i: rows_t[i])
        times_arr = [rows_t[i] for i in order]
        vals_per_s = np.array([rows_per_s[i] for i in order])
        means_arr = np.array([means[i] for i in order])
        # Robust pedestal: 1st percentile of per-frame means.
        pedestal = float(np.percentile(means_arr, 1))

def window_label(w_start, w_end):
    centre = w_start + (w_end - w_start) / 2
    hhmm_local = centre.astimezone(TZ).strftime("%H:%M")
    if times_arr is None or pedestal is None:
        return hhmm_local
    in_win = [i for i, t in enumerate(times_arr) if w_start <= t < w_end]
    if not in_win:
        return hhmm_local
    mean_count = float(means_arr[in_win].mean())
    signal = max(mean_count - pedestal, 1e-3)
    stops = float(np.log2(signal))
    return f"{hhmm_local}   {stops:+.1f} stops"

n = 0
t = start
while t + window <= end:
    w_end = t + window
    lbl = window_label(t, w_end)
    # NUL-separate fields AND rows so labels with spaces survive xargs.
    import sys
    sys.stdout.write(f"{n:05d}\0{t.strftime('%H:%M')}\0"
                     f"{w_end.strftime('%H:%M')}\0{lbl}\0")
    n += 1
    t += step
PYEOF

# Job list is NUL-separated; row count = nulls / 4.
N_NULLS=$(tr -cd '\0' < "$JOBS_LIST" | wc -c)
N_FRAMES=$((N_NULLS / 4))
echo "sweep: $SWEEP_START - $SWEEP_END  window=${WINDOW_MIN}min  step=${STEP_MIN}min"
echo "frames: $N_FRAMES  (concurrent: $JOBS, stagger=${STAGGER_S}s)"

# Run window-stack per row, 8-way concurrent. xargs -P with -n3 -I gives
# us up to JOBS workers each chewing one (idx, start, end) triple.
export CAMERA SUBCAM NIGHT OUT_DIR PY HERE FORCE STAGGER_S
worker() {
    local idx="$1" w_start="$2" w_end="$3" label="$4"
    local out="$OUT_DIR/frames/frame_${idx}.jpg"
    if [[ "$FORCE" -eq 0 && -s "$out" ]]; then
        return 0
    fi
    local args=(--camera "$CAMERA" --night "$NIGHT"
                --window-start "$w_start" --window-end "$w_end"
                --out "$out" --quiet)
    [[ -n "$SUBCAM" ]] && args+=(--subcam "$SUBCAM")
    [[ -n "$label" ]] && args+=(--label "$label")
    "$PY" "$HERE/window-stack" "${args[@]}"
}
export -f worker

# Stagger: each of the first $JOBS workers sleeps slot_index*STAGGER_S
# at start, so Python/import I/O is spread out. After warm-up the pool
# stays at JOBS-wide. xargs hands us process_slot 1..JOBS via
# --process-slot-var; we sleep that-many seconds on first invocation.
SLOT_STATE_DIR=$(mktemp -d)
trap "rm -f '$JOBS_LIST'; rm -rf '$SLOT_STATE_DIR'" EXIT
export SLOT_STATE_DIR
worker_stagger() {
    local slot="${XARGS_PROCESS_SLOT:-1}"
    # Stagger only the first batch of workers: slot N waits (N-1) * STAGGER_S
    # seconds on its first invocation, so 8 Python imports don't collide
    # on cold cache. Subsequent invocations of the same slot run flat-out.
    if [[ "$STAGGER_S" != "0" && ! -e "$SLOT_STATE_DIR/$slot" ]]; then
        touch "$SLOT_STATE_DIR/$slot" 2>/dev/null || true
        local delay
        delay=$(awk -v s="$slot" -v g="$STAGGER_S" 'BEGIN { d = (s-1)*g; if (d<0) d=0; print d }')
        [[ "$delay" != "0" ]] && sleep "$delay"
    fi
    worker "$@"
}
export -f worker_stagger

t0=$(date +%s)
< "$JOBS_LIST" xargs -0 -n4 -P "$JOBS" \
    --process-slot-var=XARGS_PROCESS_SLOT \
    bash -c 'worker_stagger "$@"' _
t1=$(date +%s)
echo "rendered $N_FRAMES frames in $((t1 - t0))s wall"

if [[ "$NO_MP4" -eq 0 ]]; then
    out_mp4="$OUT_DIR/sweep.mp4"
    echo "stitching $out_mp4 at ${FPS}fps..."
    ffmpeg -y -loglevel error -framerate "$FPS" \
        -i "$OUT_DIR/frames/frame_%05d.jpg" \
        -c:v libx264 -pix_fmt yuv420p -crf 20 -preset medium \
        "$out_mp4"
    echo "wrote $out_mp4  ($(du -h "$out_mp4" | cut -f1))"
fi
