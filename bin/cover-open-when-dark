#!/usr/bin/env python3
"""cover-open-when-dark — open the lens cover the moment skycam confirms
it's dark enough, at any time of day.

Replaces the fixed 20:30 cover-open.timer. Reads the most recent N skycam
JPGs (NFS-mounted from puppy), takes the centre-crop mean of each, and if
all N are <= DARK_SKYCAM_CROP it issues `cover open`. The N-frame
consensus suppresses single-frame flicker (we saw raw skycam wobble 24..92
within a smooth twilight on 2026-05-27).

Threshold rationale (2026-05-27): paired starcam mean vs skycam crop_mean
during evening twilight had skycam ~= 60..65 when starcam was ~100 (the
'no stars yet' floor). 60 is the open trigger; we open as soon as skycam
is at least as dark as that. Recalibrate if the cameras or lenses change.

Host coupling: must run where skycam-frames is a local filesystem (today:
puppy). Issues `cover open` which ssh's to starcam.

No act window — fires at any hour. A `cover-close.timer` on starcam still
guards the morning end of the session and is independent of this script.
"""
from __future__ import annotations

import os
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path
from zoneinfo import ZoneInfo

import numpy as np
from PIL import Image

LONDON = ZoneInfo("Europe/London")

STARCAM_ROOT = Path(os.environ.get("STARCAM_ROOT", str(Path.home() / "starcam-frames")))
STATE_PATH = STARCAM_ROOT / ".cover-state"
SKYCAM_MOUNT = Path(os.environ.get("SKYCAM_MOUNT", "/mnt/skycam-frames"))

COVER = Path.home() / "astro" / "bin" / "cover"

DARK_SKYCAM_CROP = 60.0   # <= means safe to open
CONSEC_NEEDED = 3
LOCKOUT_S = 3600          # no flip within 1 hour of last flip


def log(msg: str) -> None:
    print(f"cover-open-when-dark: {msg}", flush=True)


def read_cover_state() -> tuple[str, int]:
    if not STATE_PATH.exists():
        return ("unknown", 0)
    lines = STATE_PATH.read_text().splitlines()
    label = lines[0].strip() if lines else "unknown"
    ts = 0
    if len(lines) >= 3:
        try:
            ts = int(lines[2].strip())
        except ValueError:
            pass
    return (label, ts)


def latest_skycam_jpgs(n: int) -> list[Path]:
    if not SKYCAM_MOUNT.is_dir():
        return []
    date_dirs = sorted([p for p in SKYCAM_MOUNT.iterdir()
                        if p.is_dir() and len(p.name) == 10])[-2:]
    files: list[Path] = []
    for dd in date_dirs:
        for hd in sorted([p for p in dd.iterdir()
                          if p.is_dir() and len(p.name) == 2])[-2:]:
            files.extend(sorted(hd.glob("*.jpg")))
    return files[-n:]


def skycam_crop_mean(path: Path) -> float | None:
    try:
        img = np.asarray(Image.open(path).convert("L"))
        h, w = img.shape
        crop = img[h // 4:3 * h // 4, w // 4:3 * w // 4]
        return float(crop.mean())
    except Exception as e:
        log(f"failed to read {path.name}: {e}")
        return None


def main() -> int:
    state, last_ts = read_cover_state()
    age = int(time.time()) - last_ts if last_ts else 10**9
    log(f"state={state} age={age}s")

    if state == "open":
        log("already open; no-op")
        return 0
    if age < LOCKOUT_S:
        log(f"within {LOCKOUT_S}s lockout; no-op")
        return 0

    frames = latest_skycam_jpgs(CONSEC_NEEDED)
    if len(frames) < CONSEC_NEEDED:
        log(f"only {len(frames)} skycam frames; need {CONSEC_NEEDED}; no-op")
        return 0
    crops = [skycam_crop_mean(p) for p in frames]
    log(f"skycam crop_means: {crops}")
    if any(c is None for c in crops):
        log("missing skycam reads; no-op")
        return 0
    if all(c <= DARK_SKYCAM_CROP for c in crops):
        log(f"all <= {DARK_SKYCAM_CROP}: dark -> OPEN")
        subprocess.run([str(COVER), "open"], check=True)
    else:
        log(f"not all <= {DARK_SKYCAM_CROP}; keep closed")
    return 0


if __name__ == "__main__":
    sys.exit(main())
