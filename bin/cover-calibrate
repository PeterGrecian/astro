#!/usr/bin/env python3
"""cover-calibrate — pair starcam vs skycam brightness for one night and fit.

Builds the calibration table behind the cover-controller thresholds. starcam
brightness comes from the capture daemon's journal (mean= per frame); skycam
crop_mean is computed from the NFS jpg tree. We pair by minute, write a CSV
that accumulates across nights, and print clear/cloud stats + a linear fit.

Usage:
  # on a host that can read the skycam NFS tree (pip via /mnt/puppy, or puppy):
  #   first capture the night's starcam means into a file, BST 'HH:MM:SS val':
  #   ssh starcam "sudo journalctl -u starcam-capture.service \\
  #       --since '<night> 21:00' --until '<next> 05:30' -q --no-pager \\
  #       | grep -oE '[0-9]{2}:[0-9]{2}:[0-9]{2}.*mean=[0-9.]+' \\
  #       | sed -E 's/([0-9:]{8}).*mean=([0-9.]+)/\\1 \\2/'" > star.txt
  cover-calibrate --night 2026-05-27 --starcam star.txt \\
      --skycam-root /mnt/puppy/skycam-frames --moon "waxing gibbous 86%"

Notes:
  - skycam frames are UTC-bucketed (YYYY-MM-DD/HH); a night spans two UTC dates.
  - Output CSV: ~/astro/calibration/cover-brightness.csv (appended, deduped by
    night+minute). One row per paired minute.
"""
from __future__ import annotations

import argparse
import csv
import sys
from datetime import datetime, timedelta
from pathlib import Path
from zoneinfo import ZoneInfo

import numpy as np
from PIL import Image

LON = ZoneInfo("Europe/London")
UTC = ZoneInfo("UTC")
CSV_PATH = Path.home() / "astro" / "calibration" / "cover-brightness.csv"


def skycam_crop_mean(path: Path) -> float | None:
    try:
        img = np.asarray(Image.open(path).convert("L"))
        h, w = img.shape
        return float(img[h // 4:3 * h // 4, w // 4:3 * w // 4].mean())
    except Exception:
        return None


def load_starcam(path: Path) -> dict[str, float]:
    """Map BST HH:MM -> mean (last sample wins within a minute)."""
    out: dict[str, float] = {}
    for line in path.read_text().splitlines():
        parts = line.split()
        if len(parts) != 2:
            continue
        try:
            out[parts[0][:5]] = float(parts[1])
        except ValueError:
            pass
    return out


def load_skycam(root: Path, night: str) -> dict[str, float]:
    """Map BST HH:MM -> mean skycam crop. Scans the two UTC date dirs the
    Europe/London night spans."""
    d0 = datetime.strptime(night, "%Y-%m-%d")
    by_min: dict[str, list[float]] = {}
    for dd in (d0.strftime("%Y-%m-%d"), (d0 + timedelta(days=1)).strftime("%Y-%m-%d")):
        date_dir = root / dd
        if not date_dir.is_dir():
            continue
        for hd in sorted(p for p in date_dir.iterdir() if p.is_dir() and len(p.name) == 2):
            for p in sorted(hd.glob("*.jpg")):
                head = p.name.split("_", 1)[0].split(".")[0]
                if not head.isdigit():
                    continue
                b = datetime.fromtimestamp(int(head) / 1000, UTC).astimezone(LON)
                if b.strftime("%Y-%m-%d") not in (night, ):  # keep noon-rollover night
                    if not (b.hour < 12 and (b - timedelta(days=1)).strftime("%Y-%m-%d") == night):
                        continue
                c = skycam_crop_mean(p)
                if c is not None:
                    by_min.setdefault(b.strftime("%H:%M"), []).append(c)
    return {k: float(np.mean(v)) for k, v in by_min.items()}


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--night", required=True, help="noon-rollover date, YYYY-MM-DD")
    ap.add_argument("--starcam", required=True, type=Path, help="file of 'HH:MM:SS mean' (BST)")
    ap.add_argument("--skycam-root", required=True, type=Path)
    ap.add_argument("--moon", default="", help="moon phase note, e.g. 'waxing gibbous 86%'")
    args = ap.parse_args()

    star = load_starcam(args.starcam)
    sky = load_skycam(args.skycam_root, args.night)
    mins = sorted(set(star) & set(sky))
    if not mins:
        print("no overlapping minutes between starcam and skycam", file=sys.stderr)
        return 1

    rows = [(m, star[m], sky[m]) for m in mins]
    CSV_PATH.parent.mkdir(parents=True, exist_ok=True)
    existing: set[tuple[str, str]] = set()
    if CSV_PATH.exists():
        with CSV_PATH.open() as f:
            for r in csv.reader(f):
                if len(r) >= 2:
                    existing.add((r[0], r[1]))
    write_header = not CSV_PATH.exists()
    with CSV_PATH.open("a", newline="") as f:
        w = csv.writer(f)
        if write_header:
            w.writerow(["night", "bst_hhmm", "starcam_mean", "skycam_crop", "moon"])
        for m, sc, sk in rows:
            if (args.night, m) in existing:
                continue
            w.writerow([args.night, m, f"{sc:.1f}", f"{sk:.1f}", args.moon])

    sc = np.array([r[1] for r in rows])
    sk = np.array([r[2] for r in rows])
    print(f"night {args.night}  moon: {args.moon or '(unrecorded)'}  paired minutes: {len(rows)}")
    print(f"starcam: min={sc.min():.0f} max={sc.max():.0f}   skycam: min={sk.min():.0f} max={sk.max():.0f}")
    print(f"Pearson r: {np.corrcoef(sc, sk)[0, 1]:.3f}")
    a, b = np.polyfit(sc, sk, 1)
    print(f"linear fit: skycam = {a:.3f} * starcam + {b:.1f}")
    print(f"CSV: {CSV_PATH}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
