#!/usr/bin/env python3
"""storage-report — scan this host's astro data and report it to DynamoDB.

Walks each camera's frames (via the layout-aware astro.locate, so it finds
data whether it's in the canonical YYYY/MM/DD tree or the flat YYYY-MM-DD
tree), measures per-night disk usage, detects whether a night has been
shrunk (squashed sum8/sum2 products present per COLD_STORAGE.md), and
upserts one inventory item per (night x this-host-path) into
astro-storage-inventory. Also reports this host's disk capacity for the
relevant filesystems into astro-host-capacity.

Run on each host (puppy, muppet, eclipticam) — typically from cron. The
mywebsite /astro/storage page reads these tables. See
astro/design/storage-status-and-inventory.md.

    storage-report                 # scan + write to DynamoDB
    storage-report --dry-run       # print what would be written
    storage-report --cameras astrocam eclipticam-v3w   # subset
"""
from __future__ import annotations

import argparse
import shutil
import socket
import subprocess
import sys
import time
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(REPO))

from astro.config import CameraConfig          # noqa: E402
from astro import locate                       # noqa: E402

REGION = "eu-west-1"
INVENTORY_TABLE = "astro-storage-inventory"
CAPACITY_TABLE = "astro-host-capacity"

# Cameras scanned via locate.list_nights (flat/canonical single-dir-per-night
# layouts) when --cameras isn't given. eclipticam-v1/v3w are NOT here — they
# use the <mode>/<date>/ layout and are scanned by scan_mode_dated instead
# (locate would undercount them). starcam is NOT here either: locate can't
# discover its night/<date>/HH layout (no per-camera subdir), so its local
# copies are scanned via EXTRA_STREAMS roots below.
DEFAULT_CAMERAS = ["astrocam"]

# Extra roots holding plain <root>/YYYY-MM-DD night dirs that the locate
# scan can't reach: puppy's remaining raw starcam nights and muppet's two
# backup copies (squashed sum8/sum2, some raw). Scanning them here matters
# because the prune step deletes any local row this host's scan doesn't
# emit — CSV-loaded local rows do NOT survive without a scanner backing
# them. skycam was removed 2026-07-05 (peter: the astro storage page is
# for astro data only); its rows are pruned on the next run since we no
# longer emit them. camera-name -> list of root dirs (globbed, ~ expanded).
EXTRA_STREAMS = {
    "starcam": ["~/starcam-frames/night", "~/starcam-backup",
                "/mnt/bigdisk/starcam-backup"],
}

# Cameras whose frames live in a <root>/<mode>/<date>/... tree (day AND night
# modes, possibly with v1/v3w subcams below). locate.list_nights only resolves
# ONE dir per night (night/<date>/<subcam>), so it misses the day/ mode and the
# date-level deliverables — undercounting the disk. For these we scan the whole
# <mode>/<date>/ subtree per night instead. camera -> root dirs (globbed).
MODE_DATED_STREAMS = {
    "eclipticam": ["~/eclipticam-frames"],
}
MODES = ("day", "night")

# A "night" must hold at least this many bytes of real data to be inventoried.
# Excludes the metadata-only stubs of the incomplete hierarchical migration:
# the canonical YYYY/MM/DD/<camera>/ dirs currently hold only brightness.csv +
# state.json (~500 B) while the real frames live in the flat YYYY-MM-DD tree.
# Smallest real night observed is ~36 MB; canonical stubs are <25 KB — 1 MB
# cleanly separates them. (Revisit at "the day of the great migration".)
MIN_REAL_BYTES = 1 << 20  # 1 MiB


# Frame-file extensions, in the order we prefer them as the night's
# "primary" format when several are present (raw science data first).
FRAME_EXTS = (".fits.fz", ".fits", ".dng", ".jpg", ".jpeg", ".png")


def _ext_of(name: str) -> str:
    """Extension for format purposes — keeps the compound '.fits.fz'."""
    low = name.lower()
    if low.endswith(".fits.fz"):
        return ".fits.fz"
    i = low.rfind(".")
    return low[i:] if i >= 0 else ""


def scan_tree(path: Path) -> dict:
    """One walk of a night dir: total bytes, per-extension frame counts,
    a sample file per frame extension, and the mtime span of the frames
    (for cadence). Skips broken symlinks."""
    total = 0
    exts: dict[str, int] = {}
    sample: dict[str, Path] = {}
    mt_min = mt_max = None
    for p in path.rglob("*"):
        try:
            if not p.is_file():
                continue
            st = p.stat()
        except OSError:
            continue
        total += st.st_size
        ext = _ext_of(p.name)
        if ext in FRAME_EXTS:
            exts[ext] = exts.get(ext, 0) + 1
            sample.setdefault(ext, p)
            mt = st.st_mtime
            mt_min = mt if mt_min is None else min(mt_min, mt)
            mt_max = mt if mt_max is None else max(mt_max, mt)
    return {"bytes": total, "exts": exts, "sample": sample,
            "mt_min": mt_min, "mt_max": mt_max}


def du_bytes(path: Path) -> int:
    """Total bytes under path (follows the tree; skips broken symlinks)."""
    return scan_tree(path)["bytes"]


def fits_dims(path: Path):
    """(width, height) of the image in a FITS / fpacked .fits.fz — parsed
    from the ASCII header cards, no astropy needed. For .fz the image dims
    are ZNAXIS1/ZNAXIS2 in the compressed extension header; for plain FITS
    they're NAXIS1/NAXIS2. Reads at most the first 64 KiB."""
    try:
        head = path.open("rb").read(64 * 1024)
    except OSError:
        return None
    kv = {}
    for key in (b"ZNAXIS1", b"ZNAXIS2", b"NAXIS1", b"NAXIS2"):
        # header card: KEYWORD padded to 8 chars, then '= value'
        i = head.find(key.ljust(8) + b"=")
        if i >= 0:
            try:
                kv[key] = int(head[i + 9:i + 30].split(b"/")[0])
            except ValueError:
                pass
    w = kv.get(b"ZNAXIS1") or kv.get(b"NAXIS1")
    h = kv.get(b"ZNAXIS2") or kv.get(b"NAXIS2")
    return (w, h) if w and h else None


def jpeg_dims(path: Path):
    """(width, height) from a JPEG's SOF marker, stdlib only."""
    try:
        with path.open("rb") as f:
            if f.read(2) != b"\xff\xd8":
                return None
            while True:
                b = f.read(1)
                if not b:
                    return None
                if b != b"\xff":
                    continue
                marker = f.read(1)
                if marker in (b"\xd8", b"\x01") or b"\xd0" <= marker <= b"\xd7":
                    continue
                seg = int.from_bytes(f.read(2), "big")
                if marker in (b"\xc0", b"\xc1", b"\xc2", b"\xc3",
                              b"\xc5", b"\xc6", b"\xc7", b"\xc9",
                              b"\xca", b"\xcb", b"\xcd", b"\xce", b"\xcf"):
                    f.read(1)  # precision
                    h = int.from_bytes(f.read(2), "big")
                    w = int.from_bytes(f.read(2), "big")
                    return (w, h)
                f.seek(seg - 2, 1)
    except OSError:
        return None


def fmt_of(scan: dict, native=None):
    """Format summary for an inventory item, from a scan_tree() result.

    {ext, n_frames, dims: [w, h]?, res_class?, cadence_s?}

    res_class compares the sampled frame dims to the camera's native
    resolution: 'full mosaic' (raw Bayer at native res) or 'bin2'
    (2x2 sum-binned — the binning merges the Bayer channels, so it is
    no longer a mosaic; don't call it one). JPEGs are demosaiced so
    they get 'full' / 'half' instead. cadence_s is the mean seconds
    between frames, from the frames' mtime span, snapped to the capture
    interval (see _nice_cadence)."""
    counts = scan["exts"]
    if not counts:
        return None
    ext = max(counts, key=lambda e: (counts[e], -FRAME_EXTS.index(e)))
    fmt = {"ext": ext, "n_frames": counts[ext]}
    raw = ext in (".fits.fz", ".fits", ".dng")
    dims = (fits_dims if ext in (".fits.fz", ".fits") else jpeg_dims)(
        scan["sample"][ext]) if ext != ".dng" else None
    if dims:
        w, h = dims
        fmt["dims"] = [w, h]
        if native:
            nw, nh = native
            if (w, h) == (nw, nh):
                fmt["res_class"] = "full mosaic" if raw else "full"
            elif (w * 2, h * 2) == (nw, nh):
                fmt["res_class"] = "bin2" if raw else "half"
    if counts[ext] >= 2 and scan["mt_min"] is not None:
        span = scan["mt_max"] - scan["mt_min"]
        if span > 0:
            fmt["cadence_s"] = _nice_cadence(span / (counts[ext] - 1))
    return fmt


def _nice_cadence(c: float) -> int:
    """Snap a measured cadence to the capture interval it wobbles around:
    mtime spans come out a second or two off (~59/61 s for a 60 s cadence),
    so minute-scale values within 3% of a multiple of 60 s snap to it.
    Sub-minute cadences (3 s raw, 24 s sum8) are reported as measured."""
    if c >= 45:
        target = round(c / 60) * 60
        if target and abs(c - target) / target <= 0.03:
            return target
    return int(round(c))


def is_shrunk(path: Path) -> bool:
    """A night is 'shrunk' if it carries squashed per-frame products —
    HH-sumN / HHb-sumN dirs (COLD_STORAGE.md naming)."""
    for d in path.rglob("*-sum*"):
        if d.is_dir():
            return True
    return False


def verdict_of(night_dir: Path) -> str:
    """clear | cloudy | no-data | '' — from summary.json if present.
    summary.json may sit at the night dir or one level up (canonical
    <date>/<camera>/ vs flat <date>/). Check both."""
    import json
    for f in (night_dir / "summary.json", night_dir.parent / "summary.json"):
        if f.is_file():
            try:
                return (json.load(f.open()).get("verdict") or "").lower()
            except Exception:
                return ""
    return ""


def scan_host(cameras, host):
    """Yield inventory item dicts for every resolvable night on this host."""
    for cam in cameras:
        try:
            cfg = CameraConfig.load(cam)
        except FileNotFoundError:
            continue
        for night, loc in locate.list_nights(cfg):
            # Only report nights that physically live here (online/local);
            # registry-only (USB/cold) rows are owned by cold-archive-night.
            if not loc.online or not loc.path.is_dir():
                continue
            # Skip nights on a REMOTE filesystem (e.g. muppet NFS-mounts
            # puppy's ~/starcam-frames) — that data belongs to its origin
            # host and would be double-counted here.
            try:
                if _is_remote(str(mount_point_of(loc.path))):
                    continue
            except OSError:
                continue
            scan = scan_tree(loc.path)
            size = scan["bytes"]
            # Skip stubs/shadows: when both a canonical metadata-only dir and a
            # real flat/percam copy exist, locate can land on the metadata one.
            # The incomplete hierarchical-migration stubs (canonical
            # YYYY/MM/DD/<camera>/ holding just brightness.csv + state.json,
            # ~500 B) are not data — require real frame bytes. See MIN_REAL_BYTES.
            if size < MIN_REAL_BYTES:
                continue
            item = {
                "night": night,
                "loc": f"{cam}#{host}#{loc.path}",
                "camera": cam,
                "host": host,
                "path": str(loc.path),
                "storage_class": "local",
                "online": True,
                "layout": loc.layout,
                "bytes": {"on_disk": size},
                "shrunk": is_shrunk(loc.path),
                "updated_at": int(time.time()),
            }
            fmt = fmt_of(scan, native=cfg.get("resolution"))
            if fmt:
                item["fmt"] = fmt
            # verdict (clear/cloudy/no-data) from summary.json drives the
            # keeper policy on the web page; record it when present.
            v = verdict_of(loc.path)
            if v:
                item["verdict"] = v
            yield item


import re as _re

_DATED = _re.compile(r"(\d{4}-\d{2}-\d{2})$")


def scan_extra_streams(host):
    """Yield inventory items for EXTRA_STREAMS roots by finding dated
    subdirs under them. One item per (stream, night, root) so the storage
    page shows each physical copy (e.g. muppet's two starcam-backup
    copies on different disks)."""
    import glob as _glob
    for stream, roots in EXTRA_STREAMS.items():
        try:
            native = CameraConfig.load(stream).get("resolution")
        except FileNotFoundError:
            native = None
        for root in roots:
            for rp in _glob.glob(Path(root).expanduser().as_posix()):
                rootp = Path(rp)
                if not rootp.is_dir():
                    continue
                # Skip roots on a REMOTE filesystem — e.g. muppet NFS-mounts
                # puppy's ~/skycam-processed, so scanning it here would double-
                # count puppy's data under muppet. That disk belongs to puppy.
                try:
                    mp = mount_point_of(rootp)
                    if _is_remote(str(mp)):
                        continue
                except OSError:
                    continue
                # flat dated dirs: <root>/YYYY-MM-DD
                for d in rootp.glob("[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]"):
                    if not d.is_dir():
                        continue
                    scan = scan_tree(d)
                    size = scan["bytes"]
                    if size < MIN_REAL_BYTES:
                        continue
                    fmt = fmt_of(scan, native=native)
                    yield {
                        "night": d.name,
                        "loc": f"{stream}#{host}#{d}",
                        "camera": stream,
                        "host": host,
                        "path": str(d),
                        "storage_class": "local",
                        "online": True,
                        "layout": f"flat:{rootp.name}",
                        "bytes": {"on_disk": size},
                        "shrunk": is_shrunk(d),
                        "updated_at": int(time.time()),
                        **({"fmt": fmt} if fmt else {}),
                    }


def scan_mode_dated(host):
    """Yield inventory items for cameras stored as
    <root>/<mode>/<date>/<subcam>/... (eclipticam: day+night, v1/v3w subcams).

    One row per (subcam, mode, night): the subcam becomes a distinct camera
    (e.g. 'eclipticam-v1', 'eclipticam-v3w'), so the page shows the v1/v3w
    split — including that v1 is day-only while v3w runs day+night. Captures
    the day mode + deliverables that locate.list_nights misses."""
    for stem, roots in MODE_DATED_STREAMS.items():
        for root in roots:
            rootp = Path(root).expanduser()
            if not rootp.is_dir():
                continue
            try:
                if _is_remote(str(mount_point_of(rootp))):
                    continue
            except OSError:
                continue
            for mode in MODES:
                mdir = rootp / mode
                if not mdir.is_dir():
                    continue
                for d in sorted(mdir.glob(
                        "[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]")):
                    if not d.is_dir():
                        continue
                    subcam_bytes = 0
                    # Real subcams are named v1, v3w, v<N>... — NOT the
                    # deliverable frame dirs (sweep-colour, sweep-diff, ...).
                    for sub in sorted(d.glob("v[0-9]*")):
                        if not sub.is_dir():
                            continue
                        cam = f"{stem}-{sub.name}"   # eclipticam-v1 / -v3w
                        scan = scan_tree(sub)
                        size = scan["bytes"]
                        subcam_bytes += size
                        if size < MIN_REAL_BYTES:
                            continue
                        try:
                            native = CameraConfig.load(cam).get("resolution")
                        except FileNotFoundError:
                            native = None
                        item = {
                            "night": d.name,
                            "loc": f"{cam}#{host}#{sub}",
                            "camera": cam,
                            "host": host,
                            "path": str(sub),
                            "storage_class": "local",
                            "online": True,
                            "layout": f"mode:{mode}",
                            "bytes": {"on_disk": size},
                            "shrunk": is_shrunk(sub),
                            "updated_at": int(time.time()),
                        }
                        fmt = fmt_of(scan, native=native)
                        if fmt:
                            item["fmt"] = fmt
                        v = verdict_of(sub) or verdict_of(d)
                        if v:
                            item["verdict"] = v
                        yield item
                    # Date-level deliverables (sweep mp4s, posters) live at
                    # <mode>/<date>/ outside the subcam dirs — don't lose them.
                    date_total = du_bytes(d)
                    remainder = date_total - subcam_bytes
                    if remainder >= MIN_REAL_BYTES:
                        yield {
                            "night": d.name,
                            "loc": f"{stem}-deliverables#{host}#{d}",
                            "camera": f"{stem}-deliverables",
                            "host": host,
                            "path": str(d),
                            "storage_class": "local",
                            "online": True,
                            "layout": f"mode:{mode}",
                            "bytes": {"on_disk": remainder},
                            "shrunk": False,
                            "updated_at": int(time.time()),
                        }


def dedup_aliases(inv: list[dict]) -> list[dict]:
    """Collapse rows that are the SAME storage seen through different
    names — symlinks, bind mounts (e.g. eclipticam's ~/eclipticam-frames
    is a bind mount of /mnt/ssd), or overlapping scan roots. Identity is
    the resolved path's (st_dev, st_ino) per (night, camera); anything
    that resolves to the same inode is one copy, not two. Of the aliases,
    keep the home-dir path (reported as ~/... on the page — preferred)."""
    home = str(Path.home())
    by_key: dict[tuple, dict] = {}
    out = []
    for it in inv:
        try:
            st = Path(it["path"]).resolve().stat()
            key = (it["night"], it["camera"], st.st_dev, st.st_ino)
        except OSError:
            out.append(it)
            continue
        cur = by_key.get(key)
        if cur is None:
            by_key[key] = it
            out.append(it)
        elif it["path"].startswith(home) and not cur["path"].startswith(home):
            # same storage, nicer name — swap the kept row's identity
            cur.update(it)
    return out


def mount_point_of(path: Path) -> Path:
    """The mount point of the filesystem holding `path` (walk up until the
    device id changes). Resolves symlinks first."""
    path = path.resolve()
    dev = path.stat().st_dev
    cur = path
    while cur.parent != cur and cur.parent.stat().st_dev == dev:
        cur = cur.parent
    return cur


# Local astro storage mounts to always report if present (in addition to
# the camera roots). bigdisk2 holds no camera root yet but is astro warm
# space; /mnt/ssd is eclipticam's astro disk. Globbed, so absent ones are
# skipped silently.
EXTRA_MOUNT_GLOBS = ["/mnt/bigdisk", "/mnt/bigdisk2", "/mnt/ssd"]

# Filesystem types that belong to ANOTHER host — don't report them as this
# host's capacity (e.g. muppet NFS-mounts puppy's starcam-frames; that disk
# is puppy's and is reported under puppy). "autofs" isn't itself remote but
# it typically fronts an NFS mount, which findmnt reports as a second line.
REMOTE_FSTYPES = {"nfs", "nfs4", "cifs", "smbfs", "fuse.sshfs"}


def _is_remote(mount: str) -> bool:
    """True if the filesystem(s) at `mount` are remote. findmnt can return
    MULTIPLE fstypes for a stacked mount (e.g. 'autofs\\nnfs4' when autofs
    fronts NFS) — treat it as remote if ANY line is a remote type."""
    try:
        out = subprocess.run(["findmnt", "-no", "FSTYPE", mount],
                             capture_output=True, text=True).stdout
        types = {t.strip() for t in out.split() if t.strip()}
        return bool(types & REMOTE_FSTYPES) or "autofs" in types
    except Exception:
        return False


def scan_capacity(host, paths):
    """Capacity items for the LOCAL filesystems that hold astro data.

    Reports the mount point (not device name) of each camera-root path, plus
    the known astro mounts in EXTRA_MOUNT_GLOBS (bigdisk/bigdisk2/ssd), deduped
    by mount point. Excludes:
      - '/' unless a camera root actually lives on it (a Pi root SD card is
        not astro storage),
      - REMOTE filesystems (NFS/CIFS) — that disk belongs to its origin host.
    """
    import glob as _glob
    seen = {}  # device id -> item  (dedup by DEVICE, so bind mounts collapse)
    gb = 1 << 30
    candidates = list(paths)
    for g in EXTRA_MOUNT_GLOBS:
        candidates += _glob.glob(g)
    for p in candidates:
        p = Path(p).expanduser()
        try:
            if not p.exists():
                continue
            mp = mount_point_of(p)
            dev = mp.stat().st_dev
            usage = shutil.disk_usage(mp)
        except OSError:
            continue
        if _is_remote(str(mp)):
            continue  # remote disk — belongs to its origin host
        # Same physical filesystem reached via >1 path (e.g. eclipticam's
        # ~/eclipticam-frames is a bind mount of /mnt/ssd) — dedup by device.
        # Prefer a canonical /mnt/... name over a home-dir path for display.
        existing = seen.get(dev)
        fs = str(mp)
        if existing:
            if fs.startswith("/mnt/") and not existing["fs"].startswith("/mnt/"):
                existing["fs"] = fs      # upgrade to the nicer mount name
            continue
        seen[dev] = {
            "host": host,
            "fs": fs,                       # mount point, not device
            "size_gb": usage.total // gb,
            "used_gb": usage.used // gb,
            "avail_gb": usage.free // gb,
            "pct": round(100 * usage.used / usage.total) if usage.total else 0,
            "updated_at": int(time.time()),
        }
    return list(seen.values())


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__)
    ap.add_argument("--cameras", nargs="+", default=DEFAULT_CAMERAS)
    ap.add_argument("--host", default=socket.gethostname().split(".")[0])
    ap.add_argument("--dry-run", action="store_true")
    args = ap.parse_args()

    inv = list(scan_host(args.cameras, args.host))
    inv += list(scan_extra_streams(args.host))   # starcam backup roots
    inv += list(scan_mode_dated(args.host))      # eclipticam day+night
    inv = dedup_aliases(inv)
    # capacity: the roots each camera searches (+ known astro mounts, see
    # scan_capacity); NFS-mounted remote disks are excluded.
    roots = []
    for cam in args.cameras:
        try:
            roots += [str(r) for r in CameraConfig.load(cam).search_roots]
        except FileNotFoundError:
            pass
    cap = scan_capacity(args.host, roots)

    print(f"host={args.host}: {len(inv)} night-locations, {len(cap)} filesystems")
    if args.dry_run:
        for it in inv:
            sz = it["bytes"]["on_disk"]
            f = it.get("fmt") or {}
            fdesc = " ".join(str(x) for x in (
                f.get("ext"), "x".join(map(str, f.get("dims", []))) or None,
                f.get("res_class"), f.get("n_frames") and f"{f['n_frames']}fr",
                f.get("cadence_s") and f"~{f['cadence_s']}s") if x)
            print(f"  {it['night']}  {it['camera']:14} {it['layout']:9} "
                  f"{sz/(1<<30):6.2f} GB  shrunk={it['shrunk']}  "
                  f"[{fdesc}]  {it['path']}")
        for c in cap:
            print(f"  CAP {c['fs']:22} {c['used_gb']}/{c['size_gb']} GB ({c['pct']}%)")
        return 0

    import boto3
    from boto3.dynamodb.conditions import Attr
    ddb = boto3.resource("dynamodb", region_name=REGION)
    it_tbl = ddb.Table(INVENTORY_TABLE)
    cap_tbl = ddb.Table(CAPACITY_TABLE)

    for it in inv:
        # DynamoDB wants ints, not the floats du could produce.
        it["bytes"] = {k: int(v) for k, v in it["bytes"].items()}

    # PRUNE stale rows: any LOCAL row for THIS host that we didn't emit this
    # run represents a path that has moved or vanished (layout churn, data
    # deleted, stream removed). Delete it so the page reflects reality.
    # Only touch this host's local rows — never other hosts' or cold/USB rows.
    fresh_locs = {it["loc"] for it in inv}
    resp = it_tbl.scan(FilterExpression=Attr("host").eq(args.host)
                       & Attr("storage_class").eq("local"))
    existing = resp.get("Items", [])
    while "LastEvaluatedKey" in resp:
        resp = it_tbl.scan(FilterExpression=Attr("host").eq(args.host)
                           & Attr("storage_class").eq("local"),
                           ExclusiveStartKey=resp["LastEvaluatedKey"])
        existing += resp.get("Items", [])
    stale = [e for e in existing if e["loc"] not in fresh_locs]

    with it_tbl.batch_writer() as bw:
        for it in inv:
            bw.put_item(Item=it)
        for e in stale:
            bw.delete_item(Key={"night": e["night"], "loc": e["loc"]})

    # Same for capacity: drop this host's mount rows we no longer report.
    fresh_fs = {c["fs"] for c in cap}
    cresp = cap_tbl.scan(FilterExpression=Attr("host").eq(args.host))
    cexisting = cresp.get("Items", [])
    while "LastEvaluatedKey" in cresp:
        cresp = cap_tbl.scan(FilterExpression=Attr("host").eq(args.host),
                             ExclusiveStartKey=cresp["LastEvaluatedKey"])
        cexisting += cresp.get("Items", [])
    # Never prune removable-media rows (USB sticks): they're written
    # statically (the stick is usually unplugged, so the reporter can't read
    # its capacity) and must survive runs when the stick is absent.
    cstale = [c for c in cexisting
              if c["fs"] not in fresh_fs and not c.get("removable")]

    with cap_tbl.batch_writer() as bw:
        for c in cap:
            bw.put_item(Item=c)
        for c in cstale:
            bw.delete_item(Key={"host": c["host"], "fs": c["fs"]})

    print(f"wrote {len(inv)} inventory + {len(cap)} capacity items; "
          f"pruned {len(stale)} stale inventory + {len(cstale)} capacity")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
