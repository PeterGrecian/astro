#!/usr/bin/env python3
"""annotate-pole — write a DS9 region file marking the predicted
positions of named stars near the celestial pole on an unrotated stack.

Calibration is anchored on a single observed star (Polaris by default):
given its known pixel location, we solve for the sky->image rotation
and re-use it to predict the pixel position of every other star in
the input catalogue. Plate scale is taken as a fixed on-axis value
(no distortion correction; predictions degrade radially).

Emits a sidecar .reg next to the source FITS (or at --out). Splay /
DS9 / Siril can overlay it without modifying the FITS itself.

Usage:
    annotate-pole <stack.fits.fz>
                  --pole-x 937 --pole-y 172
                  --epoch-ms 1779753600093
                  [--lat 51.39 --lon -0.31]
                  [--scale 0.0413]
                  [--anchor-name Polaris --anchor-x 953 --anchor-y 160]
                  [--catalog stars.csv]   # name,ra,dec,V
                  [--out pole.reg]
"""
from __future__ import annotations

import argparse
import csv
from pathlib import Path

import numpy as np
from astropy.coordinates import AltAz, EarthLocation, SkyCoord
from astropy.io import fits
from astropy.time import Time
import astropy.units as u


# Default near-pole catalogue. RA/Dec strings; ICRS.
DEFAULT_STARS = [
    ("Polaris", "02h31m49.09s", "+89d15m50.8s", 1.98),
    ("Yildun",  "17h32m12.99s", "+86d35m11.2s", 4.36),
    ("Kochab",  "14h50m42.33s", "+74d09m19.8s", 2.08),
    ("Pherkad", "15h20m43.72s", "+71d50m02.5s", 3.05),
]

COLOURS = {
    "Polaris": "cyan",
    "Yildun":  "magenta",
    "Kochab":  "yellow",
    "Pherkad": "orange",
}


def load_catalog(path: Path):
    out = []
    with open(path) as f:
        for row in csv.DictReader(f):
            out.append((row["name"], row["ra"], row["dec"], float(row["V"])))
    return out


def offset_altaz_deg(c: SkyCoord, ncp_aa: AltAz, aa_frame: AltAz):
    """Return (east, up) offset in degrees from NCP, small-angle."""
    cp = c.transform_to(aa_frame)
    A_n, h_n = ncp_aa.az.deg, ncp_aa.alt.deg
    daz = ((cp.az.deg - A_n + 180) % 360) - 180
    dh  = cp.alt.deg - h_n
    return daz * np.cos(np.radians(h_n)), dh


def main():
    ap = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("fits", type=Path, help="source FITS (used only to "
                    "default --epoch-ms from EPOCH_MS header)")
    ap.add_argument("--pole-x", type=float, required=True)
    ap.add_argument("--pole-y", type=float, required=True)
    ap.add_argument("--epoch-ms", type=int, default=None,
                    help="UTC ms; default = FITS EPOCH_MS header")
    ap.add_argument("--lat", type=float, default=51.39)
    ap.add_argument("--lon", type=float, default=-0.31)
    ap.add_argument("--scale", type=float, default=0.0413,
                    help="deg/px, on-axis, binned (default 0.0413)")
    ap.add_argument("--anchor-name", default="Polaris")
    ap.add_argument("--anchor-x", type=float, required=True,
                    help="observed pixel x of anchor star")
    ap.add_argument("--anchor-y", type=float, required=True)
    ap.add_argument("--catalog", type=Path, default=None,
                    help="CSV name,ra,dec,V; default = built-in near-pole list")
    ap.add_argument("--out", type=Path, default=None,
                    help="output .reg (default: <fits>.reg)")
    ap.add_argument("--radius", type=float, default=12,
                    help="marker circle radius in px")
    args = ap.parse_args()

    # Resolve epoch
    if args.epoch_ms is None:
        hdr = fits.open(args.fits)[1].header
        args.epoch_ms = int(hdr["EPOCH_MS"])

    stars = load_catalog(args.catalog) if args.catalog else DEFAULT_STARS
    by_name = {n: (ra, dec, V) for n, ra, dec, V in stars}
    if args.anchor_name not in by_name:
        raise SystemExit(f"anchor {args.anchor_name!r} not in catalogue")

    # Set up frames
    t = Time(args.epoch_ms / 1000.0, format="unix")
    loc = EarthLocation(lat=args.lat * u.deg, lon=args.lon * u.deg, height=20*u.m)
    aa = AltAz(obstime=t, location=loc)
    ncp = SkyCoord("0d", "+90d", unit="deg", frame="icrs")
    ncp_aa = ncp.transform_to(aa)

    # Solve rotation from anchor
    a_ra, a_dec, _ = by_name[args.anchor_name]
    anchor = SkyCoord(a_ra, a_dec, frame="icrs")
    dE, dN = offset_altaz_deg(anchor, ncp_aa, aa)
    dx_obs = args.anchor_x - args.pole_x
    dy_obs = args.anchor_y - args.pole_y
    img_brg_obs = (np.degrees(np.arctan2(dx_obs, -dy_obs)) + 360) % 360
    sky_brg     = (np.degrees(np.arctan2(dE, dN)) + 360) % 360
    rot = (img_brg_obs - sky_brg) % 360

    # Header
    out_path = args.out or args.fits.with_suffix(".reg")
    lines = [
        "# DS9 region file",
        f"# generated by annotate-pole; epoch_ms={args.epoch_ms} "
        f"({t.iso} UTC)",
        f"# anchor={args.anchor_name} obs=({args.anchor_x},{args.anchor_y}) "
        f"sky->image rot={rot:.2f}deg scale={args.scale} deg/px",
        'global font="helvetica 10 normal roman" select=1',
        "image",
        f"point({args.pole_x + 1:.2f},{args.pole_y + 1:.2f}) "
        "# point=cross color=red text={pole}",
    ]

    for name, ra, dec, V in stars:
        c = SkyCoord(ra, dec, frame="icrs")
        dE, dN = offset_altaz_deg(c, ncp_aa, aa)
        sep_deg = c.separation(ncp).deg
        r_px = sep_deg / args.scale
        sky_brg_i = (np.degrees(np.arctan2(dE, dN)) + 360) % 360
        img_brg = (sky_brg_i + rot) % 360
        px = args.pole_x + r_px * np.sin(np.radians(img_brg))
        py = args.pole_y - r_px * np.cos(np.radians(img_brg))
        col = COLOURS.get(name, "green")
        # DS9 is 1-indexed
        lines.append(
            f"circle({px + 1:.2f},{py + 1:.2f},{args.radius}) "
            f"# color={col} text={{{name} V={V}}}")

    out_path.write_text("\n".join(lines) + "\n")
    print(f"wrote {out_path}")


if __name__ == "__main__":
    main()
