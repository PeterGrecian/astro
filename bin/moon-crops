#!/usr/bin/env python3
"""Emit 300x300 crops around predicted sun/moon position for a day's frames.

Reads ~/eclipticam-frames/series/<day>/log.csv and writes one crop per row
where pred_x,pred_y are populated and inside the frame.
"""
import argparse
import csv
from pathlib import Path
import cv2

FRAMES = Path.home() / "eclipticam-frames" / "series"
CROP = 300


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("day", help="YYYY-MM-DD")
    ap.add_argument("--body", choices=["sun", "moon", "both"], default="both")
    args = ap.parse_args()

    day_dir = FRAMES / args.day
    log = day_dir / "log.csv"
    if not log.exists():
        raise SystemExit(f"no log.csv at {log}")
    out_dir = day_dir / "crops"
    out_dir.mkdir(exist_ok=True)

    n_written = n_skipped = 0
    for r in csv.DictReader(log.open()):
        body = r.get("detected_body") or ""
        if not body:
            continue
        if args.body != "both" and body != args.body:
            continue
        try:
            px = float(r["pred_x"]); py = float(r["pred_y"])
        except (KeyError, ValueError):
            continue
        frame_path = FRAMES.parent / r["file"]
        img = cv2.imread(str(frame_path))
        if img is None:
            n_skipped += 1
            continue
        h, w = img.shape[:2]
        if not (0 <= px < w and 0 <= py < h):
            n_skipped += 1
            continue
        half = CROP // 2
        x0 = max(0, int(round(px)) - half)
        y0 = max(0, int(round(py)) - half)
        x1 = min(w, x0 + CROP)
        y1 = min(h, y0 + CROP)
        crop = img[y0:y1, x0:x1].copy()
        cx = int(round(px)) - x0
        cy = int(round(py)) - y0
        cv2.drawMarker(crop, (cx, cy), (0, 255, 255), cv2.MARKER_CROSS, 24, 1)
        # detected centroid if available
        try:
            dx = float(r["det_x"]); dy = float(r["det_y"])
            score = float(r.get("match_score") or 0)
            cv2.drawMarker(crop, (int(round(dx)) - x0, int(round(dy)) - y0),
                           (0, 255, 0), cv2.MARKER_TILTED_CROSS, 24, 1)
            label = f"{r['utc']} {body} score={score:.2f}"
        except (KeyError, ValueError):
            label = f"{r['utc']} {body}"
        cv2.putText(crop, label, (4, crop.shape[0] - 6),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.4, (255, 255, 255), 1, cv2.LINE_AA)

        utc_compact = r["utc"].replace(":", "").replace("-", "")
        out = out_dir / f"{utc_compact}_{r['camera']}_{body}.jpg"
        cv2.imwrite(str(out), crop, [cv2.IMWRITE_JPEG_QUALITY, 88])
        n_written += 1

    print(f"wrote {n_written} crops to {out_dir} (skipped {n_skipped})")


if __name__ == "__main__":
    main()
