#!/usr/bin/env python3
"""cover-watch — close the lens cover when the sky goes bright (cloudy / dawn),
reopen it when skycam reports clear sky again.

Designed for one-shot invocation by a 5-minute systemd timer on starcam, which
owns the cover decision. Runs only inside the operational night window. Writes
decisions to the journal and (on a real flip) drives the servo via `cover`.

Brightness sources, chosen so the CLOSE decision needs nothing off-host:
  - CLOSE (cover open): starcam's own brightness, read from the capture
    daemon's journal ('mean=N.N' per raw Bayer frame). Local, no FITS/astropy,
    no NFS — survives a puppy/storage outage.
  - REOPEN (cover closed): starcam is blind behind the cover, so use skycam
    crop brightness from the NFS-mounted skycam frames (PIL, no astropy).

The hard 05:00 cover-close.timer on starcam is independent of this and
survives any outage.

Brightness rules (calibrated 2026-05-26, near-full moon, north-facing cams):
    starcam mean >= CLOUDY_STARCAM_MEAN     for 3 reads -> close
    skycam crop_mean <  CLEAR_SKYCAM_CROP   for 3 reads -> reopen
"""
from __future__ import annotations

import os
import re
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path
from zoneinfo import ZoneInfo

import numpy as np
from PIL import Image

LONDON = ZoneInfo("Europe/London")

STARCAM_ROOT = Path(os.environ.get("STARCAM_ROOT", str(Path.home() / "starcam-frames")))
STATE_PATH = STARCAM_ROOT / ".cover-state"

SKYCAM_MOUNT = Path(os.environ.get("SKYCAM_MOUNT", "/mnt/skycam-frames"))

COVER = Path.home() / "astro" / "bin" / "cover"

# Window: cover-open.timer fires 20:30, cover-close.timer fires 05:00.
# We don't act in the first hour after dusk (still bright everywhere) nor
# in the last 30 minutes before the hard close (let timer handle it).
ACT_AFTER = (21, 30)   # 21:30 local
ACT_BEFORE = (4, 30)   # 04:30 local

CLOUDY_STARCAM_MEAN = 45.0   # >= means cover should close
CLEAR_SKYCAM_CROP = 35.0     # < means safe to reopen
CONSEC_NEEDED = 3
LOCKOUT_S = 3600             # no flip within 1 hour of last flip


def log(msg: str) -> None:
    print(f"cover-watch: {msg}", flush=True)


def in_act_window(now: datetime) -> bool:
    t = (now.hour, now.minute)
    # window straddles midnight: 21:30 -> 04:30
    return t >= ACT_AFTER or t < ACT_BEFORE


def read_cover_state() -> tuple[str, int]:
    """Return (label, epoch_s_of_last_move). ('unknown', 0) if no state file."""
    if not STATE_PATH.exists():
        return ("unknown", 0)
    lines = STATE_PATH.read_text().splitlines()
    label = lines[0].strip() if lines else "unknown"
    ts = 0
    if len(lines) >= 3:
        try:
            ts = int(lines[2].strip())
        except ValueError:
            pass
    return (label, ts)


_MEAN_RE = re.compile(r"\bmean=([0-9]+(?:\.[0-9]+)?)")


def recent_starcam_means(n: int) -> list[float]:
    """Most-recent n starcam frame brightness values, read from the capture
    daemon's own journal (it logs 'mean=N.N' per the raw Bayer frame).

    This reads brightness LOCALLY on starcam — no FITS, no astropy, no NFS.
    The cover decision must not depend on puppy storage being reachable; the
    daemon already does the .mean() and prints it, so we just parse it back."""
    try:
        out = subprocess.run(
            ["journalctl", "-u", "starcam-capture.service",
             "--no-pager", "-q", "-n", str(n * 30)],
            capture_output=True, text=True, timeout=20,
        ).stdout
    except Exception as e:
        log(f"failed to read capture journal: {e}")
        return []
    means: list[float] = []
    for line in out.splitlines():
        m = _MEAN_RE.search(line)
        if m:
            means.append(float(m.group(1)))
    return means[-n:]


def latest_skycam_jpgs(n: int) -> list[Path]:
    """Most-recent n .jpg files from the NFS-mounted skycam frames tree."""
    if not SKYCAM_MOUNT.is_dir():
        return []
    # skycam uses YYYY-MM-DD/HH/<epoch>_label.jpg (UTC date+hour).
    date_dirs = sorted([p for p in SKYCAM_MOUNT.iterdir() if p.is_dir() and len(p.name) == 10])[-2:]
    files: list[Path] = []
    for dd in date_dirs:
        for hd in sorted([p for p in dd.iterdir() if p.is_dir() and len(p.name) == 2])[-2:]:
            files.extend(sorted(hd.glob("*.jpg")))
    return files[-n:]


def skycam_crop_mean(path: Path) -> float | None:
    try:
        img = np.asarray(Image.open(path).convert("L"))
        h, w = img.shape
        crop = img[h // 4:3 * h // 4, w // 4:3 * w // 4]
        return float(crop.mean())
    except Exception as e:
        log(f"failed to read {path.name}: {e}")
    return None


def move_cover(action: str) -> bool:
    """Invoke the cover servo. Returns True on success. A failed move is
    logged but never propagated: a transient error (e.g. SSH host-key churn
    after an IP change) must not fail the unit, or the 5-minute timer stops
    retrying and weather-close is silently disabled for the rest of the night."""
    log(f"invoking: cover {action}")
    try:
        subprocess.run([str(COVER), action], check=True)
        return True
    except subprocess.CalledProcessError as e:
        log(f"cover {action} FAILED (exit {e.returncode}); will retry next tick")
        return False


def main() -> int:
    now = datetime.now(LONDON)
    if not in_act_window(now):
        log(f"outside act window ({now.strftime('%H:%M')}); no-op")
        return 0

    state, last_ts = read_cover_state()
    age = int(time.time()) - last_ts if last_ts else 10**9
    log(f"state={state} age={age}s")
    if age < LOCKOUT_S:
        log(f"within {LOCKOUT_S}s lockout; no-op")
        return 0

    if state == "open":
        # Decide whether to close based on starcam brightness (from its own
        # capture-daemon journal — local, no NFS/astropy dependency).
        means = recent_starcam_means(CONSEC_NEEDED)
        if len(means) < CONSEC_NEEDED:
            log(f"only {len(means)} starcam means available; need {CONSEC_NEEDED}; no-op")
            return 0
        log(f"starcam means: {means}")
        if all(m >= CLOUDY_STARCAM_MEAN for m in means):
            log(f"all >= {CLOUDY_STARCAM_MEAN}: cloudy -> CLOSE")
            move_cover("close")
        else:
            log("not all cloudy; keep open")
        return 0

    if state in ("closed", "weather-closed", "unknown"):
        # Decide whether to reopen based on skycam brightness.
        frames = latest_skycam_jpgs(CONSEC_NEEDED)
        if len(frames) < CONSEC_NEEDED:
            log(f"only {len(frames)} skycam frames available; need {CONSEC_NEEDED}; no-op")
            return 0
        crops = [skycam_crop_mean(p) for p in frames]
        log(f"skycam crop_means: {crops}")
        if any(c is None for c in crops):
            log("missing skycam reads; no-op")
            return 0
        if all(c < CLEAR_SKYCAM_CROP for c in crops):
            log(f"all < {CLEAR_SKYCAM_CROP}: clear -> OPEN")
            move_cover("open")
        else:
            log("not all clear; keep closed")
        return 0

    log(f"unhandled state {state!r}; no-op")
    return 0


if __name__ == "__main__":
    sys.exit(main())
