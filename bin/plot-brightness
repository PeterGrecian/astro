#!/usr/bin/env python3
"""plot-brightness — overlay log2(mean brightness) vs time-of-day.

Reads per-HH brightness.csv files produced by scan-brightness, groups
rows by night (noon-noon, Europe/London), and plots one line per night
on a shared 12:00 → 12:00 x-axis.

Skycam CSVs (from scan-skycam-brightness: iso_utc,crop_mean) can be
overlaid on the same log2 axis with --skycam. Skycam crop_mean switches
between ~40 (dark) and ~80 (cloud-lit) — log2 puts it on the same scale
as starcam so the two cameras read directly against each other. Starcam
nights draw solid, skycam dash-dot.

Usage:
    plot-brightness <night-dir> [<night-dir> ...]
    plot-brightness <parent-dir>            # auto-discovers night dirs
    plot-brightness --skycam sky.csv [...] <night-dir> ...
    plot-brightness --out path.png ...
"""
from __future__ import annotations

import argparse
import csv
import sys
from datetime import datetime, time, timedelta, timezone
from pathlib import Path
from zoneinfo import ZoneInfo

import numpy as np
import matplotlib
matplotlib.use("Agg")
import matplotlib.pyplot as plt
import matplotlib.dates as mdates

LONDON = ZoneInfo("Europe/London")


def load_night(night_dir: Path) -> tuple[np.ndarray, np.ndarray] | None:
    """Return (times_local, mean_arr) for all brightness.csv under night_dir.

    Times are Europe/London datetimes; mean is float ADU. (Mean rather
    than median because median collapses to 0 on dark-sky frames where
    >50% of pixels are sub-LSB — mean still tracks signal from stars
    and the bright tail.)
    """
    rows: list[tuple[datetime, float]] = []
    # Only the raw (un-binned) HH brightness CSVs. The binned dirs
    # (<HH>b) carry 4x ADU values and would inflate / double-plot.
    csv_paths = sorted(p for p in night_dir.rglob("brightness.csv")
                       if not p.parent.name.endswith("b"))
    for csv_path in csv_paths:
        with open(csv_path) as f:
            r = csv.DictReader(f)
            for row in r:
                try:
                    t_utc = datetime.fromisoformat(row["iso_utc"])
                    if t_utc.tzinfo is None:
                        t_utc = t_utc.replace(tzinfo=timezone.utc)
                    val = float(row["mean"])
                except (KeyError, ValueError):
                    continue
                rows.append((t_utc.astimezone(LONDON), val))
    if not rows:
        return None
    rows.sort(key=lambda x: x[0])
    times = np.array([r[0] for r in rows])
    vals = np.array([r[1] for r in rows], dtype=float)
    return times, vals


def load_skycam(csv_path: Path) -> tuple[np.ndarray, np.ndarray] | None:
    """Return (times_local, crop_mean) from a scan-skycam-brightness CSV."""
    rows: list[tuple[datetime, float]] = []
    with open(csv_path) as f:
        for row in csv.DictReader(f):
            try:
                t = datetime.fromisoformat(row["iso_utc"])
                if t.tzinfo is None:
                    t = t.replace(tzinfo=timezone.utc)
                rows.append((t.astimezone(LONDON), float(row["crop_mean"])))
            except (KeyError, ValueError):
                continue
    if not rows:
        return None
    rows.sort(key=lambda x: x[0])
    times = np.array([r[0] for r in rows])
    vals = np.array([r[1] for r in rows], dtype=float)
    return times, vals


def to_noon_axis(times: np.ndarray, anchor_date) -> np.ndarray:
    """Map real datetimes to a shared 12:00→12:00 axis anchored on anchor_date.

    A time of 14:00 on night N becomes anchor_date 14:00.
    A time of 03:00 on night N+1 becomes (anchor_date + 1 day) 03:00.
    """
    out = np.empty(len(times), dtype=object)
    anchor_noon = datetime.combine(anchor_date, time(12, 0), tzinfo=LONDON)
    next_noon = anchor_noon + timedelta(days=1)
    for i, t in enumerate(times):
        # Hour-of-day relative to noon
        if t.hour >= 12:
            # Same calendar day as the "night N" start
            out[i] = anchor_noon.replace(hour=t.hour, minute=t.minute,
                                         second=t.second)
        else:
            out[i] = next_noon.replace(hour=t.hour, minute=t.minute,
                                       second=t.second)
    return out


def discover_nights(arg: Path) -> list[Path]:
    """If arg looks like a parent dir of night dirs, return its children;
    otherwise return [arg]."""
    if any(arg.rglob("brightness.csv")) and not (arg / "brightness.csv").exists():
        # Has CSVs somewhere below. Treat immediate subdirs as nights if
        # the arg itself doesn't look like a night dir (no HH children
        # with frames directly under it).
        children = sorted(d for d in arg.iterdir()
                          if d.is_dir() and any(d.rglob("brightness.csv")))
        # If the arg itself is a night dir (has HH/brightness.csv directly),
        # children of arg are HH dirs not nights — return [arg].
        if children and all(
                any(c.glob("brightness.csv")) for c in children):
            # children are HH dirs of a single night
            return [arg]
        return children or [arg]
    return [arg]


def main() -> int:
    ap = argparse.ArgumentParser(
        description=__doc__.split("\n", 1)[0],
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    ap.add_argument("paths", type=Path, nargs="+",
                    help="night dirs, or a parent dir of nights")
    ap.add_argument("--skycam", type=Path, nargs="+", default=[],
                    metavar="CSV", help="scan-skycam-brightness CSV(s) to "
                    "overlay (log2 crop_mean, dash-dot)")
    ap.add_argument("--cover", type=Path, default=None, metavar="CSV",
                    help="cover events CSV (iso_utc,state); plotted as "
                    "vertical lines (green=open, red=closed)")
    ap.add_argument("--out", type=Path,
                    default=Path(__file__).resolve().parent.parent
                    / "brightness.png",
                    help="output PNG (default: <repo>/brightness.png)")
    args = ap.parse_args()

    night_dirs: list[Path] = []
    for p in args.paths:
        night_dirs.extend(discover_nights(p))
    night_dirs = sorted(set(night_dirs))
    if not night_dirs:
        print("no night dirs found", file=sys.stderr)
        return 1

    # Default selection: first + middle + last 3. Overlaying every night
    # turns into spaghetti once N>6; picking boundary samples plus recent
    # context keeps the plot readable. Order: first, middle, last3.
    if len(night_dirs) > 5:
        first = night_dirs[0]
        middle = night_dirs[len(night_dirs) // 2]
        last3 = night_dirs[-3:]
        picked = [first, middle] + [n for n in last3 if n not in (first, middle)]
        night_dirs = picked
        print(f"selected {len(night_dirs)} of available nights: "
              f"{', '.join(n.name for n in night_dirs)}", file=sys.stderr)

    fig, ax = plt.subplots(figsize=(14, 6))
    anchor_date = datetime(2000, 1, 1).date()  # arbitrary; only shape matters
    # tab10: categorical palette, max distinctness for a handful of nights.
    # Default selection caps N at 5; if a caller overrides with more, colours
    # wrap (tab10 has 10) — still distinct up to 10.
    cmap = plt.get_cmap("tab10")
    colors = [cmap(i % 10) for i in range(len(night_dirs))]

    plotted = 0
    for nd, color in zip(night_dirs, colors):
        loaded = load_night(nd)
        if loaded is None:
            print(f"  {nd}: no data, skipping", file=sys.stderr)
            continue
        times, vals = loaded
        xs = to_noon_axis(times, anchor_date)
        # Mask sub-1 values so log2 stays defined without flooring the floor.
        ys = np.where(vals > 0, np.log2(np.maximum(vals, 1e-3)), np.nan)
        ax.scatter(xs, ys, label=nd.name, color=color, s=2, linewidths=0)
        print(f"  {nd}: {len(times)} frames, "
              f"mean range {vals.min():.3f}..{vals.max():.1f}")
        plotted += 1

    # Skycam overlay: same log2 axis, dash-dot lines so the two cameras
    # are visually distinct. crop_mean ~40 (dark) / ~80 (cloud-lit) maps
    # to log2 ~5.3 / ~6.3, well below starcam's daytime range. Hand-picked
    # accent colours that don't collide with tab10 (which the starcam
    # nights use): magenta, cyan, lime, gold.
    sky_palette = ["#ff00aa", "#00bcd4", "#bfff00", "#ffd700"]
    for i, csv_path in enumerate(args.skycam):
        loaded = load_skycam(csv_path)
        if loaded is None:
            print(f"  {csv_path}: no skycam data, skipping", file=sys.stderr)
            continue
        times, vals = loaded
        xs = to_noon_axis(times, anchor_date)
        ys = np.log2(np.maximum(vals, 1e-3))
        ax.plot(xs, ys, label=f"skycam {csv_path.stem}", ls="-.", lw=1.5,
                color=sky_palette[i % len(sky_palette)])
        print(f"  {csv_path.name}: {len(times)} pts, "
              f"crop_mean {vals.min():.1f}..{vals.max():.1f}")
        plotted += 1

    if not plotted:
        print("no data plotted", file=sys.stderr)
        return 1

    # Cover events: vertical lines on the noon-anchored axis.
    if args.cover is not None and args.cover.exists():
        n_open = n_close = 0
        with open(args.cover) as f:
            for row in csv.DictReader(f):
                try:
                    t_utc = datetime.fromisoformat(row["iso_utc"].replace("Z", "+00:00"))
                except (KeyError, ValueError):
                    continue
                t_local = t_utc.astimezone(LONDON)
                x = to_noon_axis(np.array([t_local]), anchor_date)[0]
                state = row.get("state", "").strip()
                if state == "open":
                    ax.axvline(x, color="#2ca02c", ls=":", lw=1.2, alpha=0.7)
                    n_open += 1
                elif state == "closed":
                    ax.axvline(x, color="#d62728", ls=":", lw=1.2, alpha=0.7)
                    n_close += 1
        print(f"  cover: {n_open} open, {n_close} close events")

    ax.set_xlabel("local time (Europe/London, GMT/BST)")
    ax.set_ylabel("log2(mean ADU)")
    ax.set_title(f"starcam (solid) vs skycam (dash-dot) — {plotted} curve(s)")
    # Replace scatter's tiny dot markers with proper lines; keep skycam's
    # dashed line handles as-is.
    from matplotlib.lines import Line2D
    from matplotlib.collections import PathCollection
    handles, labels = ax.get_legend_handles_labels()
    legend_handles = []
    for h in handles:
        if isinstance(h, PathCollection):  # scatter (starcam)
            legend_handles.append(Line2D([0], [0],
                                         color=h.get_facecolor()[0], lw=2))
        else:  # Line2D (skycam, dash-dot)
            legend_handles.append(Line2D([0], [0], color=h.get_color(),
                                         lw=1.5, ls="-."))
    ax.legend(legend_handles, labels, loc="upper right", fontsize=9)
    ax.grid(True, alpha=0.2)
    ax.xaxis.set_major_locator(mdates.HourLocator(interval=1))
    ax.xaxis.set_major_formatter(mdates.DateFormatter("%H:%M"))
    # 22:00 (night N) → 05:15 (next morning). The 05:15 right-edge gives
    # the 05:00 BST cover-close.service safety close room to be visible
    # rather than landing right on the axis edge.
    ax.set_xlim(datetime.combine(anchor_date, time(22, 0), tzinfo=LONDON),
                datetime.combine(anchor_date + timedelta(days=1),
                                 time(5, 15), tzinfo=LONDON))
    fig.autofmt_xdate()

    plt.tight_layout()
    args.out.parent.mkdir(parents=True, exist_ok=True)
    plt.savefig(args.out, dpi=120)
    print(f"wrote {args.out}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
