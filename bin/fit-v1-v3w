#!/usr/bin/env python3
"""fit-v1-v3w — pin the eclipticam v1<->v3w relationship from simultaneous
moon sightings.

Both cameras share a Pi and see the same sky. When the moon is marked in
BOTH cameras' moon-net.json at the same instant, that pair is a direct
v1_pixel <-> v3w_pixel correspondence (same moon => same az/alt => same
sky point). Enough time-matched pairs pin an affine map v1 -> v3w.

This does NOT need a per-camera pointing model — it's a direct pixel
correspondence, valid over the sky region the matched points cover (today
the moon's low SW arc, az ~194-218). Extrapolating far outside that band
(e.g. to the daytime sun at az ~235-260) is unsafe; the fit's validity is
bounded by its input spread.

Writes the affine (2x3, v1->v3w full-res pixels) + provenance to
eclipticam-v1/v1_to_v3w.json. Rerun as more matched nights accumulate to
widen validity and tighten the fit.

Usage:
    fit-v1-v3w                      # all shared nights, write the transform
    fit-v1-v3w --max-dt 90          # time-match tolerance (s)
    fit-v1-v3w --dry-run            # fit + report residuals, write nothing
"""
from __future__ import annotations

import argparse
import json
import sys
from datetime import datetime, timezone
from pathlib import Path

import numpy as np

ROOT = Path(__file__).resolve().parent.parent


def _points(net_path):
    net = json.loads(net_path.read_text())
    out = []
    for t in net["threads"]:
        # day-space threads only (the "<night>-night" crop threads live in a
        # different, offset pixel space and must not be mixed in).
        if t["night"].endswith("-night"):
            continue
        for p in t["points"]:
            out.append((datetime.fromisoformat(p["utc"]),
                        float(p["x"]), float(p["y"]),
                        p.get("az"), p.get("alt")))
    return out


def _match(v1, v3, max_dt):
    """Time-match v1 to nearest v3w point within max_dt seconds."""
    pairs = []
    for t1, x1, y1, a1, _ in v1:
        if not v3:
            break
        t3, x3, y3, a3, _ = min(v3, key=lambda r: abs((r[0] - t1).total_seconds()))
        dt = abs((t3 - t1).total_seconds())
        if dt <= max_dt:
            pairs.append((x1, y1, x3, y3, a1, a3, dt))
    return pairs


def _fit_affine(P, Q):
    """Least-squares affine Q = M[:, :2] @ P + M[:, 2]. Returns (M 2x3, res)."""
    n = len(P)
    A = np.c_[P, np.ones(n)]
    sol, *_ = np.linalg.lstsq(A, Q, rcond=None)   # 3x2
    M = sol.T                                       # 2x3
    res = np.hypot(*((A @ sol) - Q).T)
    return M, res


# --- polynomial warp: register v1 onto v3w's (distorted) image directly ----
# Both cameras see the same sky, so the tie-points (moon+sun at matched times)
# are like matched scene features between two photos. A bivariate polynomial
# v1_pixel -> v3w_pixel ABSORBS both lenses' distortion + scale + rotation at
# once — no camera model needed. Degree 1 = affine (needs a spread of >=3
# non-collinear pts); degree 2 bends for distortion (needs the SUN points, high
# in v3w's distorted edge, to constrain the curvature). Normalise coords to
# keep the Vandermonde well-conditioned.
def _poly_terms(x, y, deg):
    """Design-matrix columns for a bivariate poly of total degree `deg`."""
    cols = []
    for i in range(deg + 1):
        for j in range(deg + 1 - i):
            cols.append((x ** i) * (y ** j))
    return np.stack(cols, axis=-1)


def _fit_poly(P, Q, deg):
    """Fit v1->v3w as two polynomials of total degree `deg`.
    Returns (coeffs, residuals, norm) where norm=(mean,scale) rescales input."""
    mean = P.mean(0)
    scale = P.std(0).mean() or 1.0
    Pn = (P - mean) / scale
    A = _poly_terms(Pn[:, 0], Pn[:, 1], deg)
    if A.shape[0] < A.shape[1]:
        return None   # under-determined for this degree
    cx, *_ = np.linalg.lstsq(A, Q[:, 0], rcond=None)
    cy, *_ = np.linalg.lstsq(A, Q[:, 1], rcond=None)
    pred = np.c_[A @ cx, A @ cy]
    res = np.hypot(*(pred - Q).T)
    return (np.c_[cx, cy], res, (mean.tolist(), float(scale)))


def main():
    ap = argparse.ArgumentParser(description=__doc__.split("\n", 1)[0])
    ap.add_argument("--max-dt", type=float, default=90,
                    help="max seconds between a v1 and v3w frame to call them "
                         "simultaneous (default 90 — capture cadence is ~1/min)")
    ap.add_argument("--dry-run", action="store_true")
    args = ap.parse_args()

    # Correspondences come from BOTH bodies: moon (low in the frame) and sun
    # (high) marked in both cameras. Pooling them spans the whole field, so the
    # fit pins scale + rotation from data rather than leaning on the published
    # FOV scale. Each net is loaded if present; a body with no v3w counterpart
    # simply contributes nothing.
    def _load(name):
        f1 = ROOT / "eclipticam-v1" / f"{name}.json"
        f3 = ROOT / "eclipticam-v3w" / f"{name}.json"
        return (_points(f1) if f1.exists() else [],
                _points(f3) if f3.exists() else [])
    v1_moon, v3_moon = _load("moon-net")
    v1_sun, v3_sun = _load("sun-net")
    # match within each body separately (a moon point must pair with a moon
    # point), then pool. Timestamps are unique per instant so this is safe.
    moon_pairs = _match(v1_moon, v3_moon, args.max_dt)
    sun_pairs = _match(v1_sun, v3_sun, args.max_dt)
    pairs = moon_pairs + sun_pairs
    print(f"v1 pts: moon {len(v1_moon)} sun {len(v1_sun)}   "
          f"v3w pts: moon {len(v3_moon)} sun {len(v3_sun)}")
    print(f"time-matched pairs (<= {args.max_dt:.0f}s): "
          f"{len(moon_pairs)} moon + {len(sun_pairs)} sun = {len(pairs)}")
    if len(pairs) < 3:
        sys.stderr.write("\nneed >=3 matched pairs for an affine fit — mark "
                         "the moon in BOTH cameras on a shared night\n")
        return 1

    P = np.array([(a, b) for a, b, *_ in pairs], float)
    Q = np.array([(c, d) for _, _, c, d, *_ in pairs], float)
    M, res = _fit_affine(P, Q)
    rms = float(np.sqrt((res ** 2).mean()))
    scale = float(np.sqrt(abs(M[0, 0] * M[1, 1] - M[0, 1] * M[1, 0])))
    az = [a for *_, a, b, dt in pairs if a is not None]
    print(f"affine fit: rms={rms:.1f}px  median={np.median(res):.1f}  "
          f"max={res.max():.1f}  scale={scale:.3f}")
    print(f"  az coverage {min(az):.0f}..{max(az):.0f} deg "
          f"(fit valid ~here; extrapolation beyond is unverified)")
    for (x1, y1, x3, y3, a1, a3, dt), r in zip(pairs, res):
        print(f"    v1({x1:5.0f},{y1:5.0f}) -> v3w({x3:5.0f},{y3:5.0f})  "
              f"az={a1:.1f}  resid={r:.1f}px  dt={dt:.0f}s")

    # --- polynomial warp: register v1 onto v3w's distorted image ----------
    # Pick the highest degree the tie-points support. Degree 2 needs the points
    # SPREAD across the frame (both moon AND sun) to constrain curvature — with
    # only the moon arc it would over-fit, so gate degree 2 on having a real
    # 2D spread (sun pairs present) and enough points. This is the map that
    # bends for v3w's strong barrel; moon-overlay uses it when present.
    warp = None
    Psd = P.std(0)
    spread_2d = (len(pairs) >= 8 and len(sun_pairs) >= 3
                 and Psd.min() > 0.15 * Psd.max())
    if spread_2d:
        got = _fit_poly(P, Q, 2)
        if got is not None:
            coeffs, wres, norm = got
            wrms = float(np.sqrt((wres ** 2).mean()))
            warp = {"degree": 2, "coeffs": coeffs.tolist(), "norm": norm,
                    "rms_px": round(wrms, 1), "max_px": round(float(wres.max()), 1),
                    "n_pairs": len(pairs)}
            print(f"poly warp (deg 2, distortion-bending): rms={wrms:.1f}px "
                  f"max={wres.max():.1f}  ({len(sun_pairs)} sun + "
                  f"{len(moon_pairs)} moon)")
    if warp is None:
        print("poly warp: SKIPPED — need a 2D spread of tie-points (mark the "
              "v3w SUN too); using the linear models only for now.")

    # --- FOV-scale + rotation model (for the v1-FOV BOX and sun trail) ---
    # Peter's approach: the size ratio is KNOWN from published RPi FOV specs
    # (trust the physical spec, not the arc-fit scale — the moon points span
    # only a narrow arc, so a fitted scale is easily biased). FIX scale to the
    # FOV ratio, then fit ROTATION + translation from the matched points (the
    # data says there IS a small ~-3.7deg roll between the cameras). This maps
    # the whole v1 frame — incl. the daytime SUN, far from the moon anchor —
    # rotation-aware, so the sun lands sensibly in the upper v1 patch.
    # Decomposing the affine confirmed: mean scale ~0.90, roll ~-3.7deg;
    # empirical scale (~0.745) disagrees with FOV (0.9325) — the v1 lens may be
    # wider than spec (or v3w narrower). Kept FOV scale per Peter; the gap is
    # flagged in _comment for a later plate-scale check.
    V1_FOV_H, V3_FOV_H = 53.50, 102.0        # deg, published (OV5647 / Mod3 Wide)
    V1_W, V3_W = 2592, 4608                   # full-res widths
    s_fov = (V1_FOV_H / V1_W) / (V3_FOV_H / V3_W)   # v3w px per v1 px
    # fixed-scale Procrustes: best rotation R + translation t at scale s_fov
    Pm, Qm = P.mean(0), Q.mean(0)
    Hm = (s_fov * (P - Pm)).T @ (Q - Qm)
    Uu, _, Vv = np.linalg.svd(Hm)
    Rr = Vv.T @ Uu.T
    if np.linalg.det(Rr) < 0:                 # guard against reflection
        Vv[-1] *= -1
        Rr = Vv.T @ Uu.T
    t_fov = Qm - s_fov * (Rr @ Pm)
    fov_theta = float(np.degrees(np.arctan2(Rr[1, 0], Rr[0, 0])))
    fov_pred = (s_fov * P @ Rr.T) + t_fov
    fov_res = np.hypot(*(fov_pred - Q).T)
    fov_rms = float(np.sqrt((fov_res ** 2).mean()))
    print(f"FOV-box model (s={s_fov:.4f} from published FOV, rot={fov_theta:.2f}deg): "
          f"rms={fov_rms:.0f}px max={fov_res.max():.0f}")

    if args.dry_run:
        print("\n[dry-run] nothing written")
        return 0

    out = {
        "_comment": "v1 pixel -> v3w pixel maps (both full-res). Tie-points are "
                    "the moon+sun marked in BOTH cameras at matched times — like "
                    "registering two photos of the same sky. THREE models: "
                    "affine (linear), fov_box (published-FOV scale + rotation), "
                    "and 'warp' (bivariate polynomial that BENDS for v3w's strong "
                    "barrel — the correct map at the distorted edge where the sun "
                    "is). moon-overlay uses warp when present, else fov_box. NOTE: "
                    "the warp needs the SUN tie-points (v3w sun-net) to fit the "
                    "curvature; absent them it stays None.",
        "from": "eclipticam-v1", "to": "eclipticam-v3w",
        "from_full_res": [2592, 1944], "to_full_res": [4608, 2592],
        "affine_2x3": M.tolist(),
        "warp": warp,
        "fit": {"n_pairs": len(pairs), "rms_px": round(rms, 2),
                "max_px": round(float(res.max()), 2),
                "scale": round(scale, 4),
                "az_deg": [round(min(az), 1), round(max(az), 1)],
                "max_dt_s": args.max_dt},
        "fov_box": {
            "_comment": "q = scale * R @ p + translate. scale from published "
                        "horizontal FOV (v1 53.5deg, v3w 102deg); R fitted "
                        "(rotation only) from the matched moon points.",
            "scale": round(float(s_fov), 4),
            "rotation_2x2": Rr.tolist(),
            "rotation_deg": round(fov_theta, 2),
            "translate": [round(float(t_fov[0]), 1), round(float(t_fov[1]), 1)],
            "fov_deg": {"v1_h": V1_FOV_H, "v3w_h": V3_FOV_H},
            "rms_px": round(fov_rms, 1)},
        "fitted_at": datetime.now(timezone.utc).isoformat(timespec="seconds"),
    }
    path = ROOT / "eclipticam-v1" / "v1_to_v3w.json"
    path.write_text(json.dumps(out, indent=2) + "\n")
    print(f"\nwrote {path}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
