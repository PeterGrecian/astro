#!/usr/bin/env bash
# cover — drive the lens cover servo on starcam.
#
# Usage:
#   cover open       # smoothly rotate to OPEN_ANGLE
#   cover close      # smoothly rotate to CLOSE_ANGLE
#   cover status     # read state from NFS, no servo touched
#
# Angles characterised 2026-05-25 (see ~/cover-sweep.csv on starcam):
#   open  = +60°    well inside the open plateau
#   close = -60°    minimum-leakage block position
#
# State is written by starcam after a successful move to
# ~/starcam-frames/.cover-state which appears on every NFS client
# (e.g. /mnt/puppy/starcam-frames/.cover-state on pip), so `cover
# status` works from any host without needing to reach starcam.
set -euo pipefail

STARCAM=peter@starcam.local
# $STARCAM_ROOT is set by ~/astro/activate; fall back via the
# starcam-frames helper so this works in any shell.
ROOT="${STARCAM_ROOT:-$(starcam-frames 2>/dev/null || echo /mnt/puppy/starcam-frames)}"
STATE_PATH_LOCAL="$ROOT/.cover-state"
# cover-move lives in the astro repo, cloned to ~/astro on starcam by
# the astro-camera ansible role.
HELPER_REMOTE="/home/peter/astro/bin/cover-move"

OPEN_ANGLE=60
CLOSE_ANGLE=-60

usage() {
    cat <<EOF
usage: cover {open|close|status}

  open    move cover to +${OPEN_ANGLE}° (lens unobstructed)
  close   move cover to ${CLOSE_ANGLE}° (lens blocked)
  status  print current state ('open', 'closed', 'unknown')
EOF
}

cmd_move() {
    local angle="$1" label="$2"
    ssh "$STARCAM" "python3 $HELPER_REMOTE $angle $label"
}

cmd_status() {
    if [ ! -e "$STATE_PATH_LOCAL" ]; then
        echo "unknown"
        return 0
    fi
    local state ts age_s
    state=$(sed -n '1p' "$STATE_PATH_LOCAL")
    ts=$(sed -n '3p' "$STATE_PATH_LOCAL")
    if [ -n "${ts:-}" ]; then
        age_s=$(( $(date +%s) - ts ))
        printf '%s  (last moved %s ago)\n' "$state" "$(date -u -d "@$age_s" +'%Hh%Mm%Ss')"
    else
        echo "$state"
    fi
}

case "${1:-}" in
    open)   cmd_move "$OPEN_ANGLE" open ;;
    close)  cmd_move "$CLOSE_ANGLE" closed ;;
    status) cmd_status ;;
    -h|--help|"") usage; exit 0 ;;
    *) echo "unknown: $1" >&2; usage; exit 2 ;;
esac
