#!/usr/bin/env bash
# cover — drive the lens cover servo on starcam.
#
# Usage:
#   cover open [--no-alert]    # smoothly rotate to OPEN_ANGLE
#   cover close [--no-alert]   # smoothly rotate to CLOSE_ANGLE
#   cover status               # read state from starcam, no servo touched
#
# Angles characterised 2026-05-25 (see ~/cover-sweep.csv on starcam):
#   open  = +60°    well inside the open plateau
#   close = -60°    minimum-leakage block position
#
# State is written by cover-move to ~/.cover-state on starcam (local
# disk, NOT NFS). Keeping the state local removes the puppy/NFS
# dependency from the cover-status path — the IP-change incident on
# 2026-05-27 broke status reads via NFS. Reading remotely from pip
# costs an SSH round-trip; acceptable for an interactive query.
set -euo pipefail

STARCAM=peter@starcam.local
STATE_PATH_LOCAL="$HOME/.cover-state"
# cover-move lives in the astro repo, cloned to ~/astro on starcam by
# the astro-camera ansible role. When this script already runs ON
# starcam (the cover logic now lives there), call cover-move directly
# and skip SSH entirely — that removes the cross-host host-key/IP
# fragility that disabled weather-close on 2026-05-27.
HELPER="/home/peter/astro/bin/cover-move"

OPEN_ANGLE=60
CLOSE_ANGLE=-60

usage() {
    cat <<EOF
usage: cover {open|close} [--no-alert]
       cover status

  open    move cover to +${OPEN_ANGLE}° (lens unobstructed)
  close   move cover to ${CLOSE_ANGLE}° (lens blocked)
  status  print current state ('open', 'closed', 'unknown')

options:
  --no-alert   skip the Slack/xMatters state-change notification
EOF
}

cmd_move() {
    local angle="$1" label="$2"
    shift 2
    if [ "$(hostname)" = starcam ]; then
        python3 "$HELPER" "$angle" "$label" "$@"
    else
        ssh "$STARCAM" "python3 $HELPER $angle $label $*"
    fi
}

cmd_status() {
    local raw
    if [ "$(hostname)" = starcam ]; then
        if [ ! -e "$STATE_PATH_LOCAL" ]; then
            echo "unknown"
            return 0
        fi
        raw=$(cat "$STATE_PATH_LOCAL")
    else
        raw=$(ssh "$STARCAM" 'cat ~/.cover-state 2>/dev/null' || true)
        if [ -z "$raw" ]; then
            echo "unknown"
            return 0
        fi
    fi
    local state ts age_s
    state=$(printf '%s\n' "$raw" | sed -n '1p')
    ts=$(printf '%s\n' "$raw" | sed -n '3p')
    if [ -n "${ts:-}" ]; then
        age_s=$(( $(date +%s) - ts ))
        printf '%s  (last moved %s ago)\n' "$state" "$(date -u -d "@$age_s" +'%Hh%Mm%Ss')"
    else
        echo "$state"
    fi
}

cmd="${1:-}"
shift || true
case "$cmd" in
    open)   cmd_move "$OPEN_ANGLE" open "$@" ;;
    close)  cmd_move "$CLOSE_ANGLE" closed "$@" ;;
    status) cmd_status ;;
    -h|--help|"") usage; exit 0 ;;
    *) echo "unknown: $cmd" >&2; usage; exit 2 ;;
esac
