#!/usr/bin/env bash
# cover — drive the lens cover servo on starcam.
#
# Usage:
#   cover open       # smoothly rotate to OPEN_ANGLE
#   cover close      # smoothly rotate to CLOSE_ANGLE
#   cover status     # read state from NFS, no servo touched
#
# Angles characterised 2026-05-25 (see ~/cover-sweep.csv on starcam):
#   open  = +60°    well inside the open plateau
#   close = -60°    minimum-leakage block position
#
# State is written by starcam after a successful move to
# ~/starcam-frames/.cover-state which appears on every NFS client
# (e.g. /mnt/puppy/starcam-frames/.cover-state on pip), so `cover
# status` works from any host without needing to reach starcam.
set -euo pipefail

STARCAM=peter@192.168.4.128
STATE_PATH_LOCAL="/mnt/puppy/starcam-frames/.cover-state"
STATE_PATH_REMOTE="/home/peter/starcam-frames/.cover-state"
HELPER_REMOTE="/home/peter/astro-cover-move"

OPEN_ANGLE=60
CLOSE_ANGLE=-60

usage() {
    cat <<EOF
usage: cover {open|close|status}

  open    move cover to +${OPEN_ANGLE}° (lens unobstructed)
  close   move cover to ${CLOSE_ANGLE}° (lens blocked)
  status  print current state ('open', 'closed', 'unknown')
EOF
}

helper_script() {
    cat <<'PY'
#!/usr/bin/env python3
"""Drive SG90 to a target angle smoothly and write state file."""
import sys, time
from pathlib import Path
from gpiozero import Servo
from gpiozero.pins.pigpio import PiGPIOFactory

SIGNAL_PIN = 18
DEG_PER_SEC = 30.0
STEP_HZ = 50
STATE_PATH = Path.home() / "starcam-frames" / ".cover-state"

if len(sys.argv) != 3:
    print("usage: helper <angle_deg> <state_label>", file=sys.stderr)
    sys.exit(2)
target_deg = float(sys.argv[1])
state_label = sys.argv[2]

servo = Servo(SIGNAL_PIN, pin_factory=PiGPIOFactory())
# Always start sweep from 0 so behaviour is reproducible; the
# previous state-file value isn't trusted as the servo's true position.
current = 0.0
servo.value = 0.0
time.sleep(0.3)

dt = 1.0 / STEP_HZ
step = DEG_PER_SEC * dt
while abs(current - target_deg) > step / 2:
    current += step if target_deg > current else -step
    servo.value = max(-1.0, min(1.0, current / 90.0))
    time.sleep(dt)
servo.value = max(-1.0, min(1.0, target_deg / 90.0))
time.sleep(0.5)
servo.detach()

STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
STATE_PATH.write_text(f"{state_label}\n{target_deg}\n{int(time.time())}\n")
print(f"cover now {state_label} (angle={target_deg})")
PY
}

deploy_helper_if_needed() {
    # Copy helper script to starcam if missing or stale.
    local local_sha remote_sha
    local_sha=$(helper_script | sha256sum | awk '{print $1}')
    remote_sha=$(ssh "$STARCAM" "sha256sum $HELPER_REMOTE 2>/dev/null | awk '{print \$1}'" || true)
    if [ "$local_sha" != "$remote_sha" ]; then
        helper_script | ssh "$STARCAM" "cat > $HELPER_REMOTE && chmod +x $HELPER_REMOTE"
    fi
}

cmd_move() {
    local angle="$1" label="$2"
    deploy_helper_if_needed
    ssh "$STARCAM" "python3 $HELPER_REMOTE $angle $label"
}

cmd_status() {
    if [ ! -e "$STATE_PATH_LOCAL" ]; then
        echo "unknown"
        return 0
    fi
    local state ts age_s
    state=$(sed -n '1p' "$STATE_PATH_LOCAL")
    ts=$(sed -n '3p' "$STATE_PATH_LOCAL")
    if [ -n "${ts:-}" ]; then
        age_s=$(( $(date +%s) - ts ))
        printf '%s  (last moved %s ago)\n' "$state" "$(date -u -d "@$age_s" +'%Hh%Mm%Ss')"
    else
        echo "$state"
    fi
}

case "${1:-}" in
    open)   cmd_move "$OPEN_ANGLE" open ;;
    close)  cmd_move "$CLOSE_ANGLE" closed ;;
    status) cmd_status ;;
    -h|--help|"") usage; exit 0 ;;
    *) echo "unknown: $1" >&2; usage; exit 2 ;;
esac
