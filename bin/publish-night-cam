#!/usr/bin/env bash
# publish-night-cam — full deliverables for one camera/night, publish to S3.
#
# 1. nightly-cam : stacks, badpix, brightness CSV/PNG, summary.json
# 2. window-stack-sweep --rgb : colour sliding-window mp4 + label overlay
# 3. publish: upload everything to s3://<bucket>/<camera>/nights/<night>/
#
# Usage:
#   publish-night-cam --camera eclipticam-v3w --night 2026-06-09
#   publish-night-cam --camera eclipticam-v3w --night 2026-06-09 \
#                     --no-sweep         # skip the (slow) sweep render
#                     --no-publish       # leave artefacts on local disk only
set -euo pipefail

CAMERA=""; NIGHT=""
NO_SWEEP=0; NO_PUBLISH=0; WEB_ONLY=0
WINDOW_MIN=10; STEP_MIN=1; FPS=60
# Sweeps are re-rendered with --force by default (a live nightly run wants a
# fresh render). For BACKFILL, where valid sweep frames already exist on
# disk, --reuse-frames drops --force so window-stack-sweep SKIPS frames that
# are already rendered (line "Already-rendered frames are skipped unless
# --force") — only the mp4 re-encode + web version are redone. ~2x faster.
REUSE_FRAMES=0
AUTO_START_STOPS=12; AUTO_END_STOPS=13
# detrans render resolution: n×n sum-bin of the (now full-res 4608×2592)
# capture. Full res is ~4h/night on the Pi and shows undistort moiré on
# uniform sky; 2×2 is ~4× faster (~1h/night), high-res, and cleaner. The
# detrans velocity scales automatically with resolution (fraction-of-width),
# so this is purely a speed/quality knob. Override with DETRANS_BIN env.
DETRANS_BIN="${DETRANS_BIN:-2}"

# Sweep parallelism. Each window-stack worker holds a full-res frame stack
# resident (~tens of MB), so the safe job count is bounded by RAM, not just
# cores. On puppy (plenty of RAM) 8 was fine; on a 1 GB eclipticam Pi, 8
# blew past RAM into swap and thrashed (load >20, kswapd pegged). Default
# to min(cores, RAM_GiB) — ~1 job per GiB — capped at 8. Override with --jobs.
_cores=$(nproc 2>/dev/null || echo 4)
_mem_gib=$(awk '/MemTotal/ {printf "%d", $2/1024/1024}' /proc/meminfo 2>/dev/null || echo 4)
[[ "$_mem_gib" -lt 1 ]] && _mem_gib=1
JOBS=$(( _cores < _mem_gib ? _cores : _mem_gib ))
[[ "$JOBS" -gt 8 ]] && JOBS=8
[[ "$JOBS" -lt 1 ]] && JOBS=1

while [[ $# -gt 0 ]]; do
    case "$1" in
        --camera)        CAMERA="$2";        shift 2;;
        --night)         NIGHT="$2";         shift 2;;
        --no-sweep)      NO_SWEEP=1;         shift;;
        --web-only)      WEB_ONLY=1;         shift;;
        --no-publish)    NO_PUBLISH=1;       shift;;
        --reuse-frames)  REUSE_FRAMES=1;     shift;;
        --window-min)    WINDOW_MIN="$2";    shift 2;;
        --step-min)      STEP_MIN="$2";      shift 2;;
        --jobs)          JOBS="$2";          shift 2;;
        --auto-start-stops) AUTO_START_STOPS="$2"; shift 2;;
        --auto-end-stops)   AUTO_END_STOPS="$2";   shift 2;;
        -h|--help)       sed -n '1,/^set -euo/p' "$0" | head -n -1; exit 0;;
        *)               echo "unknown arg: $1" >&2; exit 2;;
    esac
done

for arg in CAMERA NIGHT; do
    [[ -n "${!arg}" ]] || { echo "--${arg,,} required" >&2; exit 2; }
done

# Thread cap — set AFTER JOBS is final (default or --jobs), because threads
# and jobs MULTIPLY: numpy/OpenCV (BLAS/OpenMP) spawn one thread per core
# inside EACH of the JOBS worker processes. Left unbounded that's
# jobs*cores threads — e.g. on an 8-core puppy with jobs=8 that's 64
# threads fighting 8 cores (7x oversubscription, cache/context thrash).
# Couple them so jobs*threads ~= cores (full utilisation, no contention):
#   threads_per_job = max(1, cores // JOBS)
#     puppy   8c jobs=8 -> 1 thread/job  (8 total, 1.0x) — each window-stack
#                         single-threaded, 8 in parallel: ideal
#     eclipti 4c jobs=1 -> 4 threads/job (4 total, 1.0x) — one process,
#                         all cores; fits 1GB at jobs=1
# Override with MAX_CORES env.
_cores=$(nproc 2>/dev/null || echo 4)
MAX_CORES="${MAX_CORES:-$(( _cores / JOBS > 1 ? _cores / JOBS : 1 ))}"
export OMP_NUM_THREADS="$MAX_CORES"
export OPENBLAS_NUM_THREADS="$MAX_CORES"
export MKL_NUM_THREADS="$MAX_CORES"
export NUMEXPR_NUM_THREADS="$MAX_CORES"
export CV2_NUM_THREADS="$MAX_CORES"   # honoured by tools that read it

# ffmpeg/x264 memory is bounded by preset (lookahead) and threads — each
# holds decoded frames resident. -preset medium OOM'd the 1GB Pi. Set a
# host-aware default the sweep scripts honour; override via env.
_mem_gib=$(awk '/MemTotal/ {printf "%d", $2/1024/1024}' /proc/meminfo 2>/dev/null || echo 4)
if   [[ "$_mem_gib" -lt 2 ]]; then export FFMPEG_PRESET="${FFMPEG_PRESET:-veryfast}"; export FFMPEG_THREADS="${FFMPEG_THREADS:-1}"
elif [[ "$_mem_gib" -lt 6 ]]; then export FFMPEG_PRESET="${FFMPEG_PRESET:-fast}";     export FFMPEG_THREADS="${FFMPEG_THREADS:-2}"
else                               export FFMPEG_PRESET="${FFMPEG_PRESET:-medium}";   export FFMPEG_THREADS="${FFMPEG_THREADS:-0}"
fi
echo "parallelism: JOBS=$JOBS  MAX_CORES=$MAX_CORES  (cores=$_cores)  ffmpeg: preset=$FFMPEG_PRESET threads=$FFMPEG_THREADS"

HERE="$(cd "$(dirname "$0")" && pwd)"
REPO="$(cd "$HERE/.." && pwd)"
PY="${ASTRO_VENV_PY:-$REPO/.venv/bin/python}"
[[ -x "$PY" ]] || PY="$HOME/astro/.venv/bin/python"

echo "=== publish-night-cam ${CAMERA} ${NIGHT} ==="

# --- 1. nightly-cam: stacks + brightness + summary -------------------
# WEB_ONLY (backfill): the stacks + full-res sweep mp4s already exist on disk;
# only the web mp4s are new. Skip nightly-cam AND the sweep render entirely;
# just transcode existing sweep-*.mp4 -> sweep-*-web.mp4 + publish. ~1min/night.
if [[ "$WEB_ONLY" -eq 0 ]]; then
    echo "--- nightly-cam"
    if ! "$PY" "$HERE/nightly-cam" --camera "$CAMERA" --night "$NIGHT" --no-derot; then
        echo "nightly-cam produced nothing for ${CAMERA} $NIGHT; skipping sweep + publish"
        exit 0
    fi
else
    echo "--- web-only: skipping nightly-cam (reuse existing deliverables)"
fi

# Locate the night dir from the config so the sweeper + publish find
# the same place. `night_output_dir(cfg, night)` is the canonical path.
night_dir=$("$PY" - <<PYEOF
import sys; sys.path.insert(0, "$REPO")
from astro.config import CameraConfig
from astro.frames import night_output_dir
cfg = CameraConfig.load("$CAMERA")
print(night_output_dir(cfg, "$NIGHT"))
PYEOF
)
brightness_csv="${night_dir}/brightness.csv"

# --- 2. window-stack-sweep: RGB video -------------------------------
if [[ "$NO_SWEEP" -eq 0 ]]; then
  if [[ "$WEB_ONLY" -eq 0 ]]; then
    common_args=(
        --camera "$CAMERA" --night "$NIGHT"
        --sweep-start 22:00 --sweep-end 04:00
        --window-min "$WINDOW_MIN" --step-min "$STEP_MIN"
        --fps "$FPS" --jobs "$JOBS" --stagger-s 1
        --brightness-csv "$brightness_csv"
        --auto-start-stops "$AUTO_START_STOPS"
        --auto-end-stops   "$AUTO_END_STOPS"
    )
    # Force a fresh render unless --reuse-frames (backfill: keep valid frames).
    [[ "$REUSE_FRAMES" -eq 0 ]] && common_args+=(--force)

    # Colour sweep (the pretty/hero one). The mono sweep was dropped from
    # deliverables 2026-06-28 — colour + diff + detrans cover the science.
    for mode in colour; do
        sweep_dir="${night_dir}/sweep-${mode}"
        mkdir -p "$sweep_dir"
        mode_args=("${common_args[@]}" --out-dir "$sweep_dir")
        if [[ "$mode" == "colour" ]]; then
            mode_args+=(--rgb --no-label)
        fi
        echo "--- window-stack-sweep (${mode})"
        if "$HERE/window-stack-sweep" "${mode_args[@]}"; then
            out="${night_dir}/sweep-${mode}.mp4"
            cp "$sweep_dir/sweep.mp4" "$out"
            echo "wrote $out"
        else
            echo "window-stack-sweep (${mode}) FAILED; continuing without it"
        fi
    done

    # --- diff-sweep: (max - mean) per pixel, minus the statistical
    # max-of-N-Gaussians noise floor (M=1). Cancels pedestal, sky
    # pollution DC, and pure-noise speckle; what survives is real
    # bright transients (planes, meteors, satellite trails).
    diff_dir="${night_dir}/sweep-diff"
    mkdir -p "$diff_dir"
    diff_args=(
        --camera "$CAMERA" --night "$NIGHT"
        --sweep-start 22:00 --sweep-end 04:00
        --window-min "$WINDOW_MIN" --step-min "$STEP_MIN"
        --fps "$FPS"
        --out-dir "$diff_dir"
        --noise-floor-mult 1.0
    )
    echo "--- diff-sweep (mono, window-mean subtracted)"
    if "$PY" "$HERE/diff-sweep" "${diff_args[@]}"; then
        out="${night_dir}/sweep-diff.mp4"
        cp "$diff_dir/sweep.mp4" "$out"
        echo "wrote $out"
    else
        echo "diff-sweep FAILED; continuing without it"
    fi

    # --- detrans-sweep: de-translated registered-streak animation.
    # Only runs for cameras with a `detrans` block in camera.json
    # (currently eclipticam-v3w: pole far off-frame so star motion is a
    # near-uniform translation; undistort + shift each frame by -v*dt and
    # max-stack so the 60s streaks register into one sharp high-SNR streak
    # per window). Self-skips (exit 0) for other cameras.
    echo "--- detrans-sweep (registered-streak animation)"
    if "$PY" "$HERE/detrans-sweep" \
            --camera "$CAMERA" --night "$NIGHT" --mode max \
            --window-min "$WINDOW_MIN" --step-min "$STEP_MIN" \
            --bin "$DETRANS_BIN" --fps "$FPS" \
            --out "${night_dir}/sweep-detrans.mp4"; then
        [[ -s "${night_dir}/sweep-detrans.mp4" ]] \
            && echo "wrote ${night_dir}/sweep-detrans.mp4"
    else
        echo "detrans-sweep FAILED; continuing without it"
    fi

    # detrans DEEP: mean of registered frames minus local background —
    # maximum SNR, pulls the faintest stars per window. It used to die on the
    # 1GB Pi (the undistort cache grew unbounded across the sweep -> swap),
    # so it was skipped on <2GB hosts. That LEAK IS FIXED (detrans-sweep
    # a495940: cache pruned to the active window), and detrans-deep now runs
    # to completion on the Pi (measured: 285s, swap flat ~140M). So produce
    # it everywhere by default. Override with SKIP_DETRANS_DEEP=1 if a host
    # ever needs to drop it.
    SKIP_DETRANS_DEEP="${SKIP_DETRANS_DEEP:-0}"
    if [[ "$SKIP_DETRANS_DEEP" -eq 1 ]]; then
        echo "--- detrans-deep SKIPPED (SKIP_DETRANS_DEEP=1)"
    elif "$PY" "$HERE/detrans-sweep" \
            --camera "$CAMERA" --night "$NIGHT" --mode deep \
            --window-min "$WINDOW_MIN" --step-min "$STEP_MIN" \
            --bin "$DETRANS_BIN" --fps "$FPS" \
            --out "${night_dir}/sweep-detrans-deep.mp4"; then
        [[ -s "${night_dir}/sweep-detrans-deep.mp4" ]] \
            && echo "wrote ${night_dir}/sweep-detrans-deep.mp4"
    else
        echo "detrans-deep FAILED; continuing without it"
    fi
  fi  # end render block (skipped when WEB_ONLY: reuse existing sweep mp4s)

    # --- moon crops: extract the moon from the night's frames into
    # <night_dir>/moon/*.jpg (EXIF-tagged, only in-FOV frames). Self-
    # contained (bin/moon-extract); night-mode only; self-skips a camera
    # with no pointing defaults. Runs outside the render block so it also
    # produces on WEB_ONLY re-runs. Gets swept to S3 by the publish step
    # below. The cumulative moon-net.png render is redrawn+published on its
    # own cadence (moon-overlay --publish), not here. See
    # design/moon-daily-delivery.md.
    echo "--- moon-extract"
    "$PY" "$HERE/moon-extract" --camera "$CAMERA" --night "$NIGHT" \
        --mode night --out "${night_dir}/moon" \
        || echo "moon-extract produced nothing; continuing"

    # Per-video poster thumbnails: the middle frame of EACH sweep, so the
    # website previews each clip with a frame from itself (not a shared
    # colour-sweep thumb). poster-<name>.jpg next to <name>.mp4. The
    # colour mid-frame is also copied to thumb.jpg for the calendar card.
    extract_mid () {  # $1 = mp4 path, $2 = out jpg
        [[ -s "$1" ]] || return 0
        local n
        n=$(ffprobe -v error -count_packets -select_streams v:0 \
            -show_entries stream=nb_read_packets -of csv=p=0 "$1")
        n=$(( n / 2 ))
        ffmpeg -y -loglevel error -i "$1" \
            -vf "select=eq(n\,$n)" -frames:v 1 -q:v 4 "$2" \
            && echo "wrote $2 (mid frame $n of $(basename "$1"))"
    }
    for s in colour diff detrans detrans-deep; do
        extract_mid "${night_dir}/sweep-${s}.mp4" \
                    "${night_dir}/poster-${s}.jpg"
    done
    # Calendar card thumbnail = the colour poster.
    [[ -s "${night_dir}/poster-colour.jpg" ]] \
        && cp "${night_dir}/poster-colour.jpg" "${night_dir}/thumb.jpg"

    # Web-delivery versions: 1280-wide, denoised, faststart — ~1.5MB vs the
    # ~15-45MB full-res, visually equivalent at viewing size. The full-res
    # mp4 stays as the high-quality/download copy; the website serves
    # sweep-<name>-web.mp4 (loop+fullscreen). Source from the full-res mp4
    # (near-lossless CRF20) — no need to re-stitch frames. 60fps kept (it's
    # nearly free: consecutive stack frames compress to almost nothing).
    # Web encode honours the host-aware FFMPEG_PRESET/THREADS (set above):
    # the Pi gets veryfast/1-thread, laptops slow/auto. Downscaling to 1280
    # first makes the buffers a quarter of the full-res encode, so this
    # always fits where the full-res encode did.
    make_web () {  # $1 = full-res mp4, $2 = out web mp4
        [[ -s "$1" ]] || return 0
        if ffmpeg -y -loglevel error -threads "$FFMPEG_THREADS" -i "$1" \
            -vf "scale=1280:-2,hqdn3d=4:3:6:4" \
            -c:v libx264 -pix_fmt yuv420p -crf 23 -preset "$FFMPEG_PRESET" \
            -movflags +faststart "$2"; then
            echo "wrote $2 ($(du -h "$2" | cut -f1))"
        else
            echo "web encode FAILED for $(basename "$1"); continuing"
        fi
    }
    for s in colour diff detrans detrans-deep; do
        make_web "${night_dir}/sweep-${s}.mp4" \
                 "${night_dir}/sweep-${s}-web.mp4"
    done
fi

# --- 2b. sensitivity chart (flag-gated, clear nights, graceful skip) ---
# SENSITIVITY=1 enables the per-night freq-vs-mag deliverable. Runs only on
# CLEAR nights (verdict in summary.json), and NEVER fails this run — any
# problem (no solve, missing solve-field, cloudy) just skips with no chart.
# The derot solve is right at the edge of reliable, so some clear nights
# won't produce a chart; that's expected. astrocam only (needs a pole seed).
if [[ "${SENSITIVITY:-0}" -eq 1 && "$CAMERA" == "astrocam" && "$WEB_ONLY" -eq 0 ]]; then
    verdict=$("$PY" - <<PYEOF 2>/dev/null || echo unknown
import json
try:
    print(json.load(open("${night_dir}/summary.json")).get("verdict","unknown"))
except Exception:
    print("unknown")
PYEOF
)
    if [[ "$verdict" == "clear" ]]; then
        echo "--- sensitivity chart (clear night)"
        # pole seed from camera.json pole_prior_xy (binned = /2), else solved default
        pole=$("$PY" - <<PYEOF 2>/dev/null || echo "1176,503"
import sys; sys.path.insert(0,"$REPO")
from astro.config import CameraConfig
c=CameraConfig.load("$CAMERA"); p=c.get("pole_prior_xy")
print(f"{p[0]//2},{p[1]//2}" if p else "1176,503")
PYEOF
)
        px="${pole%,*}"; py="${pole#*,}"
        if "$PY" "$HERE/sensitivity-night" --night-dir "$night_dir" \
                --out-dir "${night_dir}/sensitivity" \
                --pole-x "$px" --pole-y "$py"; then
            cp "${night_dir}/sensitivity/sensitivity.png" "${night_dir}/" 2>/dev/null
            cp "${night_dir}/sensitivity/sensitivity.json" "${night_dir}/" 2>/dev/null
            echo "sensitivity chart produced"
        else
            echo "sensitivity: skipped (no solve / not ready) — continuing"
        fi
    else
        echo "--- sensitivity: skip (verdict=$verdict, not clear)"
    fi
fi

# --- 3. publish to S3 ------------------------------------------------
if [[ "$NO_PUBLISH" -eq 1 ]]; then
    echo "skip publish (--no-publish)"
    exit 0
fi
echo "--- publish to S3"
"$PY" - <<PYEOF
import sys; sys.path.insert(0, "$REPO")
from pathlib import Path
from astro.config import CameraConfig
from astro.present import privacy as P
from astro.present.publish import publish_night
cfg = CameraConfig.load("$CAMERA")
nd = Path("$night_dir")
web_only = $WEB_ONLY
names = [
    "summary.json",
    "brightness.png",
    "max.jpg",
    "derot.jpg",
    "sensitivity.png",
    "sensitivity.json",
    "thumb.jpg",
    "poster-colour.jpg",
    "poster-diff.jpg",
    "poster-detrans.jpg",
    "poster-detrans-deep.jpg",
    # web-delivery versions (what the website actually serves: loop+fullscreen)
    "sweep-colour-web.mp4",
    "sweep-diff-web.mp4",
    "sweep-detrans-web.mp4",
    "sweep-detrans-deep-web.mp4",
]
# Full-res mp4s are big (30-68MB). In web-only backfill they are ALREADY in
# S3 from the original run, so don't re-upload them over a slow uplink —
# only the new web mp4s + posters go up. A normal run uploads them.
if not web_only:
    names += [
        "sweep-colour.mp4", "sweep-diff.mp4",
        "sweep-detrans.mp4", "sweep-detrans-deep.mp4",
    ]
# Deliverables dropped from publishing — delete their stale S3 keys if present.
# (mono sweep dropped 2026-06-28: colour+diff+detrans cover the science.)
RETIRED = ["sweep-mono.mp4", "sweep-mono-web.mp4", "poster-mono.jpg"]
files = [nd/n for n in names if (nd/n).exists()]
missing = [n for n in names if not (nd/n).exists()]
# Videos and the thumb come out of privacy-cropped frames; mark them
# OK so publish's privacy guard doesn't refuse them.
if getattr(cfg, "privacy", None):
    for n in ("sweep-colour.mp4",
              "sweep-diff.mp4", "sweep-detrans.mp4",
              "sweep-detrans-deep.mp4",
              "sweep-colour-web.mp4",
              "sweep-diff-web.mp4", "sweep-detrans-web.mp4",
              "sweep-detrans-deep-web.mp4", "thumb.jpg",
              "poster-colour.jpg",
              "poster-diff.jpg", "poster-detrans.jpg",
              "poster-detrans-deep.jpg"):
        if (nd/n).exists():
            P.mark_ok(nd/n)
publish_night(cfg, "$NIGHT", files)
# Sweep stale S3 keys: deliverables that no longer exist locally, plus
# RETIRED ones we deliberately stopped publishing (e.g. dropped mono).
stale = missing + RETIRED
if stale:
    import boto3
    s3 = boto3.client("s3")
    bucket = cfg.s3["bucket"]
    prefix = cfg.s3["prefix"].strip("/")
    for n in stale:
        key = f"{prefix}/$NIGHT/{n}"
        try:
            s3.head_object(Bucket=bucket, Key=key)
        except Exception:
            continue
        s3.delete_object(Bucket=bucket, Key=key)
        print(f"deleted stale s3://{bucket}/{key}")
PYEOF

# Refresh the multi-night combined brightness plot at the camera prefix.
echo "--- combined brightness (multi-night)"
"$PY" "$HERE/combined-brightness" --camera "$CAMERA" --publish || true

# Refresh the accumulating moon net: the reference-night max-stack with every
# marked moon thread drawn over it. Fixed camera => the threads accumulate into
# a net of known-position curves across the field. One stable key at the camera
# prefix (like combined-brightness). Self-skips cleanly when the camera has no
# moon-net.json (e.g. eclipticam-v1) or no reference stack on disk.
echo "--- moon net (accumulated moon threads)"
"$PY" "$HERE/moon-overlay" --camera "$CAMERA" --extend --publish || true

# Refresh the calendar manifest at the PUBLIC camera prefix so the website
# renders its per-night index from one S3 object (no per-night list/get/presign
# in the Lambda). This camera may be a sub-camera (eclipticam-v3w) of a public
# camera (eclipticam); strip the sensor suffix to get the public name and
# rebuild the full v3w+v1 union. Idempotent — running it from either sub-camera
# leg produces the same manifest.
PUBLIC_CAMERA="${CAMERA%-v3w}"; PUBLIC_CAMERA="${PUBLIC_CAMERA%-v1}"
echo "--- calendar index (public camera: ${PUBLIC_CAMERA})"
"$PY" "$HERE/build-calendar-index" --camera "$PUBLIC_CAMERA" --publish || true
echo "=== done ==="
