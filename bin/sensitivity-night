#!/usr/bin/env python3
"""sensitivity-night — per-night astrocam sensitivity chart, end to end.

Clear-night deliverable (gated by the caller). Runs the full chain, printing
PASS/step and exiting NONZERO on any failure so the caller can skip gracefully
(no chart on nights that don't solve, rather than breaking the run):

  1. bin the dark-window frames (2x2 sum -> panchromatic) + EPOCH_MS header
  2. combined mask: hot spikes + foreground (frame edges + bottom houses)
  3. find-candidates (masked) -> real sky stars, not foreground
  4. fit-pole (seed from --pole) then fit-geometry (pole + k1,k2)
  5. derot-windows (short, frame-centre) -> frame-centre crop
  6. solve-field (needs solve-field + Tycho-2 indices on this host)
  7. sensitivity-plot -> sensitivity.{png,json}

Not yet guaranteed per night: the derot registration is right at the edge of
solvable, so some clear nights won't solve. That is EXPECTED — exit 2 and the
caller skips. See TODO "tighten derot registration".

Usage:
    sensitivity-night --night-dir <astrocam-night-dir> --out-dir <dir> \\
        --pole-x 1176 --pole-y 503
"""
from __future__ import annotations
import argparse, subprocess, sys, glob, csv, os
import numpy as np
from astropy.io import fits
from scipy import ndimage

ASTRO = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
PY = f"{ASTRO}/.venv/bin/python"


def sh(cmd):
    print("  $", " ".join(str(c) for c in cmd), flush=True)
    return subprocess.run([str(c) for c in cmd], capture_output=True, text=True)


def main():
    ap = argparse.ArgumentParser(description=__doc__.split("\n", 1)[0])
    ap.add_argument("--night-dir", required=True)
    ap.add_argument("--out-dir", required=True)
    ap.add_argument("--pole-x", type=float, required=True,
                    help="seed pole X (binned) — solved/config prior")
    ap.add_argument("--pole-y", type=float, required=True)
    ap.add_argument("--window", type=int, default=40,
                    help="derot window length in frames (short = ~6 min)")
    ap.add_argument("--anchor-name", default="Polaris")
    ap.add_argument("--anchor-mag", type=float, default=1.98)
    args = ap.parse_args()

    nd = args.night_dir
    work = args.out_dir
    binned = f"{work}/binned"
    os.makedirs(binned, exist_ok=True)

    # 1. dark-window frames -> binned + EPOCH_MS
    try:
        rows = list(csv.DictReader(open(f"{nd}/brightness.csv")))
    except OSError as e:
        print(f"SKIP: no brightness.csv ({e})"); return 2
    mean = np.array([float(r["mean"]) for r in rows])
    dark = [r for r, m in zip(rows, mean) if m <= np.median(mean)]
    if len(dark) < 100:
        print(f"SKIP: only {len(dark)} dark frames"); return 2
    print(f"[1] binning {len(dark)} dark frames", flush=True)
    Hb = Wb = None
    for r in dark:
        d = fits.open(r["filename"])[1].data.astype(np.float32)
        H, W = d.shape
        H, W = H // 2 * 2, W // 2 * 2
        b = d[:H, :W].reshape(H // 2, 2, W // 2, 2).sum(axis=(1, 3))
        Hb, Wb = b.shape
        hdu = fits.PrimaryHDU(b.astype(np.float32))
        hdu.header["EPOCH_MS"] = int(r["epoch_ms"])
        hdu.writeto(f"{binned}/{int(r['epoch_ms'])}.fits.fz", overwrite=True)

    # 2. combined mask: hot spikes (on binned min) + foreground region
    mn = fits.open(f"{nd}/min.fits.fz")[1].data.astype(np.float32)
    mflat = mn - ndimage.median_filter(mn, 3)
    msig = 1.4826 * np.median(np.abs(mflat - np.median(mflat)))
    hot = mflat > 12 * msig
    if hot.shape != (Hb, Wb):        # min stored full-res on some cams
        hh, ww = hot.shape
        hot = hot[:hh // 2 * 2, :ww // 2 * 2].reshape(
            hh // 2, 2, ww // 2, 2).any(axis=(1, 3))
    fg = np.zeros((Hb, Wb), bool)
    m = 60
    fg[:m, :] = fg[-m:, :] = fg[:, :m] = fg[:, -m:] = True
    fg[int(Hb * 0.72):, :] = True    # bottom (houses/trees)
    mask = (hot | fg).astype(np.uint8)
    fits.HDUList([fits.PrimaryHDU(), fits.ImageHDU(mask)]).writeto(
        f"{work}/mask.fits.fz", overwrite=True)
    print(f"[2] mask: {100 * mask.mean():.0f}% excluded", flush=True)

    # 3. find-candidates (masked)
    print("[3] find-candidates", flush=True)
    r3 = sh([PY, f"{ASTRO}/bin/find-candidates", binned, "--grid", 80,
             "--mask", f"{work}/mask.fits.fz",
             "--out", f"{binned}/candidates.csv"])
    if r3.returncode:
        print("SKIP: find-candidates failed\n", r3.stderr); return 2

    # 4. fit-pole then fit-geometry
    print("[4] fit-pole + fit-geometry", flush=True)
    r4 = sh([PY, f"{ASTRO}/bin/fit-pole", binned,
             "--pole-x", args.pole_x, "--pole-y", args.pole_y,
             "--range", 20, "--grid", 7, "--frames", 150,
             "--top", 40, "--refine"])
    if r4.returncode or "recommended" not in r4.stdout:
        print("SKIP: fit-pole did not converge\n", r4.stderr); return 2
    t = [l for l in r4.stdout.splitlines() if "recommended" in l][-1].split()
    px = float(t[t.index("--pole-x") + 1]); py = float(t[t.index("--pole-y") + 1])
    r4b = sh([PY, f"{ASTRO}/bin/fit-geometry", binned,
              "--candidates", f"{binned}/candidates.csv",
              "--pole-x", px, "--pole-y", py, "--frames", 150, "--top", 40])
    if not r4b.returncode:
        t2 = [l for l in r4b.stdout.splitlines() if "recommended" in l]
        if t2:
            tk = t2[-1].split()
            px = float(tk[tk.index("--pole-x") + 1])
            py = float(tk[tk.index("--pole-y") + 1])
    print(f"    pole ({px:.1f},{py:.1f})", flush=True)

    # 5. derot-windows -> frame-centre crop
    print("[5] derot-windows", flush=True)
    r5 = sh([PY, f"{ASTRO}/bin/derot-windows", binned, "--window", args.window,
             "--pole-x", px, "--pole-y", py, "--out", f"{work}/windows"])
    if r5.returncode:
        print("SKIP: derot-windows failed\n", r5.stderr); return 2
    wins = sorted(glob.glob(f"{work}/windows/w0*.fits.fz"))
    if not wins:
        print("SKIP: no derot windows"); return 2
    d = fits.open(wins[len(wins) // 2])[0].data
    if d is None:
        d = fits.open(wins[len(wins) // 2])[1].data
    d = d.astype(np.float32)
    flat = np.clip(d - ndimage.median_filter(d, 15), 0, None)
    cy0, cx0, R = Hb // 2, Wb // 2, 480
    crop = flat[max(0, cy0 - R):cy0 + R, max(0, cx0 - R):cx0 + R]
    fits.PrimaryHDU(crop.astype(np.float32)).writeto(
        f"{work}/solve.fits", overwrite=True)

    # 6. solve-field (graceful skip if not installed or no solve)
    print("[6] solve-field", flush=True)
    r6 = sh(["solve-field", f"{work}/solve.fits", "--scale-units",
             "arcsecperpix", "--scale-low", 130, "--scale-high", 175,
             "--no-plots", "--overwrite", "--downsample", 2,
             "--dec", 80, "--radius", 30, "--cpulimit", 150])
    if not os.path.exists(f"{work}/solve.solved"):
        print("SKIP: field did not plate-solve (expected on some nights)")
        return 2

    # 7. sensitivity-plot
    print("[7] sensitivity-plot", flush=True)
    r7 = sh([PY, f"{ASTRO}/bin/sensitivity-plot", "--solve-base",
             f"{work}/solve", "--anchor-name", args.anchor_name,
             "--anchor-mag", args.anchor_mag, "--title",
             f"astrocam {os.path.basename(nd)}", "--out",
             f"{work}/sensitivity.png"])
    if r7.returncode:
        print("SKIP: sensitivity-plot failed\n", r7.stderr); return 2
    print("OK: sensitivity.png produced")
    return 0


if __name__ == "__main__":
    sys.exit(main())
