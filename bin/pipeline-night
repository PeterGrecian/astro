#!/usr/bin/env bash
# pipeline-night — end-of-night processing for one night dir.
#
# Stages:
#   A. Per-hour prep: pipeline-hour for each HH (bin + scan + sum).
#   B. Per-night hot-pixel mask: sum-of-sums → hot-pixel-mask --sweep.
#   C. Refresh plot-brightness for the whole night-tree.
#   D. Pick sky mask: most recent ~/astro/calib/sky-mask-starcam-*.fits.fz
#      with date ≤ this night's date (logs and continues if none).
#   E. Per-hour PATCH-BASED bootstrap loop (the key speedup: every
#      fit evaluates peak/mean on top-N candidate patches, not the
#      whole image, so Nelder-Mead converges in minutes not days):
#        iter 1-2: fit-pole       (3D: pole_x, pole_y, omega)
#        iter 3+:  fit-geometry   (5D: + k1, k2 radial distortion)
#        every iter: derot-patches → find-candidates on the derot
#                    stack to seed the next iter
#      Darkest hour first; converged pole carried forward as seed
#      for the next-darkest hour. Result: <HHb>/final/derot.fits.fz.
#   F. derot-night → <night>/all-night-derot.fits.fz
#
# Writes <night>/pipeline.log + <night>/pipeline-poles.csv.
#
# Usage:
#   pipeline-night <night-dir>
#   pipeline-night <night-dir> --pole-x 910 --pole-y 40
#   pipeline-night <night-dir> --sky-threshold 80 --max-iters 6 --force
#   pipeline-night <night-dir> --no-sky-mask    # skip sky mask this run
#   pipeline-night <night-dir> --restart        # ignore prior iter state
#   pipeline-night <night-dir> --min-move 0.1 --max-iters 30
#                                              # fit harder
#   pipeline-night <night-dir> --hot-pct 4      # use 4pct hot mask
#
# Variants — run side-by-side with the default attempt:
#   pipeline-night <night-dir> --variant max80 --max-mean 80
#     ↳ bins into HH-max80/, writes max80_pipeline.log,
#       max80_pipeline-poles.csv, max80_all-night-derot.{fits.fz,jpg},
#       max80_sum_HH.jpg per hour.
# Without --variant the legacy names (HHb/, pipeline.log, etc.) are used.
#
# Resume is the default: re-running the same command picks up where it
# left off. patches-iterN/derot.fits.fz headers carry pole/k1/k2 so
# subsequent iterations seed from the last converged state. If
# <HHb>/final/derot.fits.fz exists the hour is skipped entirely.
#
# Per-night opt-out:
#   touch <night>/.no-sky-mask         # persistent: no sky mask for this night
#   (use when the camera has moved but you haven't re-painted yet)
set -euo pipefail

POLE_X=910
POLE_Y=40
SKY_THRESH=100
MAX_ITERS=10
FORCE=0
RESTART=0
NO_SKY_MASK=0
HEARTBEAT_S=30
FRAMES=100
FRAMES_GEOM=200   # patch-only sampling is cheap; 200 gives better k1/k2
TOP=10
PATCH=50
GEOM_AFTER_ITER=2
MIN_MOVE=1.0
VARIANT=""        # named bin variant; "" = default (HHb/, unprefixed outputs)
MAX_MEAN=""       # forwarded to pipeline-hour --max-mean if set
HOT_PCT=0.1       # which hot-pixel-mask strictness to use downstream
                  # (0.01, 0.1, 1, 2, 4); higher = more pixels masked

usage() { sed -n '2,/^set -e/p' "$0" | sed 's/^# \{0,1\}//;/^set -e/d'; }

ORIG_ARGS="$*"

NIGHT=""
while [ $# -gt 0 ]; do
    case "$1" in
        --pole-x) POLE_X="$2"; shift 2;;
        --pole-y) POLE_Y="$2"; shift 2;;
        --sky-threshold) SKY_THRESH="$2"; shift 2;;
        --max-iters) MAX_ITERS="$2"; shift 2;;
        --min-move) MIN_MOVE="$2"; shift 2;;
        --hot-pct) HOT_PCT="$2"; shift 2;;
        --force) FORCE=1; shift;;
        --restart) RESTART=1; shift;;
        --no-sky-mask) NO_SKY_MASK=1; shift;;
        --variant) VARIANT="$2"; shift 2;;
        --max-mean) MAX_MEAN="$2"; shift 2;;
        -h|--help) usage; exit 0;;
        *) if [ -z "$NIGHT" ]; then NIGHT="$1"; shift
           else echo "extra arg: $1" >&2; exit 2; fi;;
    esac
done

[ -n "$NIGHT" ] || { usage; exit 2; }
NIGHT="${NIGHT%/}"
[ -d "$NIGHT" ] || { echo "no such dir: $NIGHT" >&2; exit 2; }
NIGHT_DATE=$(basename "$NIGHT")

# Variant: empty → legacy unprefixed names + HHb/ dirs.
# Named   → <variant>_ prefix on night-level files + HH-<variant>/ dirs.
if [ -n "$VARIANT" ]; then
    PREFIX="${VARIANT}_"
    BIN_SUFFIX="-${VARIANT}"
else
    PREFIX=""
    BIN_SUFFIX="b"
fi

LOG="$NIGHT/${PREFIX}pipeline.log"
SUMMARY="$NIGHT/${PREFIX}pipeline-poles.csv"
# Append (don't truncate) — multiple runs against the same night
# leave a single audit trail. Mark each new run with a banner.
{
    echo ""
    echo "################################################################"
    echo "# pipeline-night run starting $(date -u +%FT%TZ)"
    echo "# args: $0 $ORIG_ARGS"
    echo "################################################################"
} >> "$LOG"
echo "hh,started_utc,mean,pole_x,pole_y,status" > "$SUMMARY"

# Wall-clock at start, for prefix-elapsed.
T0=$(date +%s)

# Prefix every log line with HH:MM:SS elapsed since pipeline start.
# stdbuf -oL keeps awk line-buffered so tail -f works in real time.
_log_filter() {
    stdbuf -oL awk -v t0="$T0" '
        { t = systime() - t0
          h = int(t/3600); m = int((t%3600)/60); s = t%60
          printf "[%02d:%02d:%02d] %s\n", h, m, s, $0
          fflush() }'
}

step() { printf '\n=== %s ===\n' "$*" | _log_filter | tee -a "$LOG"; }

run() { "$@" 2>&1 | _log_filter | tee -a "$LOG"; }

# Heartbeat: every HEARTBEAT_S seconds, dump the live worker processes
# (PID, CPU%, MEM_MB, command) so we know it's not dead. Background it
# and arrange a kill trap.
PARENT_PID=$$
HEARTBEAT_PID=""
heartbeat_loop() {
    while sleep "$HEARTBEAT_S"; do
        # All descendants of pipeline-night, filtered to relevant tools.
        ps -eo pid,pcpu,rss,cmd --sort=-pcpu --no-headers 2>/dev/null \
            | awk -v p="$PARENT_PID" '
                /pipeline-(night|hour)|fit-pole|fit-geometry|derot-(patches|night)|find-candidates|bin-frames|sum-frames|hot-pixel-mask|scan-brightness/ \
                && !/awk|grep/ \
                { printf "heartbeat: PID=%s CPU=%s%% RES=%dMB  %s\n", $1, $2, $3/1024, substr($0, index($0,$4)) }' \
            | _log_filter | tee -a "$LOG" >/dev/null
    done
}
heartbeat_loop &
HEARTBEAT_PID=$!
trap '[ -n "$HEARTBEAT_PID" ] && kill "$HEARTBEAT_PID" 2>/dev/null' EXIT

# ---------- Stage A: per-hour prep -----------------------------------
step "A. per-hour prep${VARIANT:+ (variant=$VARIANT)}"
PIPE_HOUR_ARGS=()
[ "$FORCE" = "1" ] && PIPE_HOUR_ARGS+=(--force)
[ -n "$VARIANT" ] && PIPE_HOUR_ARGS+=(--variant "$VARIANT")
[ -n "$MAX_MEAN" ] && PIPE_HOUR_ARGS+=(--max-mean "$MAX_MEAN")
for cand in "$NIGHT"/[0-2][0-9]; do
    [ -d "$cand" ] || continue
    run pipeline-hour "$cand" "${PIPE_HOUR_ARGS[@]}"
done

# ---------- Stage B: per-night hot-pixel mask ------------------------
step "B. per-night hot-pixel mask (sum-of-sums)"
NIGHT_SUM="$NIGHT/${PREFIX}sum-of-sums.fits.fz"
BIN_GLOB="[0-2][0-9]${BIN_SUFFIX}"
if [ "$FORCE" = "1" ] || [ ! -e "$NIGHT_SUM" ]; then
    python3 <<PY 2>&1 | tee -a "$LOG"
from astropy.io import fits
from pathlib import Path
import numpy as np, sys

night = Path("$NIGHT")
hh_sums = sorted(night.glob("$BIN_GLOB/sum.fits.fz"))
if not hh_sums:
    print("no per-hour sums found", file=sys.stderr); sys.exit(1)
print(f"summing {len(hh_sums)} hourly sums:")
acc = None
for fn in hh_sums:
    with fits.open(fn) as h:
        hdu = next(x for x in h if x.data is not None and x.data.ndim == 2)
        d = hdu.data.astype(np.int64)
    acc = d if acc is None else acc + d
    print(f"  + {fn.parent.name}/{fn.name}  max={int(d.max())}  running max={int(acc.max())}")
print(f"final: min={int(acc.min())} max={int(acc.max())} mean={float(acc.mean()):.1f}")
primary = fits.PrimaryHDU()
comp = fits.CompImageHDU(data=acc.astype(np.int32), compression_type="RICE_1")
comp.header["NHOURS"] = (len(hh_sums), "hourly sums combined")
fits.HDUList([primary, comp]).writeto("$NIGHT_SUM", overwrite=True)
print(f"wrote $NIGHT_SUM")
PY
else
    echo "  skip (exists): $NIGHT_SUM"
fi

step "B.2 hot-pixel-mask sweep on $NIGHT_SUM → $NIGHT/"
HOT_CAMERA="starcam-${NIGHT_DATE}${VARIANT:+-${VARIANT}}"
if [ "$FORCE" = "1" ] || [ ! -e "$NIGHT/hot-pixels-${HOT_CAMERA}-4pct.fits.fz" ]; then
    # Write masks with the night date (+variant) in the filename for
    # unambiguous selection later. hot-pixel-mask uses --camera in the
    # filename; we override --out-dir and re-suffix afterwards via mv.
    run hot-pixel-mask "$NIGHT_SUM" --sweep --out-dir "$NIGHT" \
        --camera "$HOT_CAMERA"
fi

# Pick the chosen-strictness mask for downstream tools. Filenames are
# "...-0.1pct.fits.fz", "...-1pct.fits.fz", "...-4pct.fits.fz" etc;
# normalise integer-style numbers (4 → "4", not "4.0").
HOT_PCT_STR=$(python3 -c "v=$HOT_PCT; print(int(v) if v == int(v) else v)")
NIGHT_HOT_MASK="$NIGHT/hot-pixels-${HOT_CAMERA}-${HOT_PCT_STR}pct.fits.fz"
if [ ! -e "$NIGHT_HOT_MASK" ]; then
    # Fall back to next strictest available.
    for fb in 1 0.1 2 4; do
        cand="$NIGHT/hot-pixels-${HOT_CAMERA}-${fb}pct.fits.fz"
        if [ -e "$cand" ]; then
            echo "  warn: $NIGHT_HOT_MASK missing; falling back to $cand" \
                | tee -a "$LOG"
            NIGHT_HOT_MASK="$cand"
            break
        fi
    done
fi
echo "using hot mask: $NIGHT_HOT_MASK" | tee -a "$LOG"

# ---------- Stage C: refresh plot-brightness -------------------------
step "C. plot-brightness"
ROOT="$(dirname "$NIGHT")"
run plot-brightness "$ROOT" --out "$ROOT/brightness.png" || true

# ---------- Stage D: pick sky mask -----------------------------------
step "D. sky mask"
SKY_MASK=""
if [ "$NO_SKY_MASK" = "1" ] || [ -e "$NIGHT/.no-sky-mask" ]; then
    why="--no-sky-mask flag"
    [ -e "$NIGHT/.no-sky-mask" ] && why="$NIGHT/.no-sky-mask marker"
    echo "sky mask disabled for this night ($why)" | tee -a "$LOG"
else
    for cand in $(ls -1 "$HOME/astro/calib/sky-mask-starcam-"*.fits.fz 2>/dev/null | sort -r); do
        cand_date=$(basename "$cand" .fits.fz | sed 's/sky-mask-starcam-//')
        if [ "$cand_date" \< "$NIGHT_DATE" ] || [ "$cand_date" = "$NIGHT_DATE" ]; then
            SKY_MASK="$cand"
            break
        fi
    done
    if [ -n "$SKY_MASK" ]; then
        echo "using sky mask: $SKY_MASK" | tee -a "$LOG"
    else
        echo "no sky mask found ≤ $NIGHT_DATE — proceeding without" | tee -a "$LOG"
    fi
fi

# ---------- Stage E: per-hour fit + derot bootstrap ------------------
step "E. per-hour patch-based bootstrap: fit-pole then fit-geometry, derot, repeat (darkest hour first)"

# Order hours by mean brightness (darkest first) using the raw HH CSVs.
declare -A HH_MEAN
ORDER_FILE=$(mktemp)
for cand in "$NIGHT"/[0-2][0-9]; do
    [ -d "$cand" ] || continue
    h="$(basename "$cand")"
    if [ -f "$cand/brightness.csv" ]; then
        m=$(awk -F, 'NR>1 {s+=$4; n++} END{if(n>0) print s/n; else print 9999}' \
            "$cand/brightness.csv")
    else
        m=9999
    fi
    HH_MEAN["$h"]="$m"
    printf '%s %s\n' "$m" "$h" >> "$ORDER_FILE"
done
ORDER=($(sort -n "$ORDER_FILE" | awk '{print $2}'))
rm -f "$ORDER_FILE"
echo "hour order (darkest first): ${ORDER[*]}" | tee -a "$LOG"

PX="$POLE_X"; PY="$POLE_Y"
K1="0.0"; K2="0.0"

# Combined mask once for all hours (hot ∪ sky). Apply at fit-pole/
# fit-geometry/find-candidates via --mask. derot-patches doesn't take
# a mask currently; masking happens through find-candidates filtering
# which seeds the derot patches. TODO: wire --mask through derot-patches.
COMBINED_MASK="$NIGHT_HOT_MASK"
if [ -n "$SKY_MASK" ] && [ -e "$NIGHT_HOT_MASK" ]; then
    COMBINED_MASK="$NIGHT/${PREFIX}combined-mask.fits.fz"
    python3 <<PY 2>&1 | tee -a "$LOG"
from astropy.io import fits
import numpy as np
hot = fits.getdata("$NIGHT_HOT_MASK")
sky = fits.getdata("$SKY_MASK")
comb = ((hot != 0) | (sky != 0)).astype(np.uint8)
prim = fits.PrimaryHDU()
c = fits.CompImageHDU(data=comb, compression_type="RICE_1")
c.header["NEXCL"] = int(comb.sum())
fits.HDUList([prim, c]).writeto("$COMBINED_MASK", overwrite=True)
print(f"combined mask: {int(comb.sum())} excluded ({100*comb.sum()/comb.size:.2f}%)")
PY
fi

for HH in "${ORDER[@]}"; do
    HH_DIR="$NIGHT/$HH"
    HHB="$NIGHT/${HH}${BIN_SUFFIX}"
    [ -d "$HH_DIR" ] || continue
    [ -d "$HHB" ] || continue
    MEAN="${HH_MEAN[$HH]:-9999}"
    NOW=$(date -u +%FT%TZ)

    # Empty HHb (e.g. all frames gated out by bin-frames --max-mean) — skip.
    # set -o pipefail makes `ls ... | wc -l` fatal on no-match; count
    # directly via shell globbing instead.
    shopt -s nullglob
    HHB_FRAMES=("$HHB"/[0-9]*.fits.fz)
    shopt -u nullglob
    NFRAMES=${#HHB_FRAMES[@]}
    if [ "$NFRAMES" = "0" ]; then
        printf '  skip hour %s: no binned frames in %s\n' "$HH" "$HHB" | tee -a "$LOG"
        echo "$HH,$NOW,$MEAN,,,skipped-empty" >> "$SUMMARY"
        continue
    fi

    if python3 -c "import sys; sys.exit(0 if float('$MEAN') > $SKY_THRESH else 1)"; then
        printf '  skip hour %s: mean %.1f > sky-threshold %s\n' \
            "$HH" "$MEAN" "$SKY_THRESH" | tee -a "$LOG"
        echo "$HH,$NOW,$MEAN,,,skipped-bright" >> "$SUMMARY"
        continue
    fi

    # Resume: if final/derot.fits.fz already exists, skip this hour.
    if [ "$RESTART" != "1" ] && [ -e "$HHB/final/derot.fits.fz" ]; then
        # Read pole from final stack header for the carry-forward chain.
        FINAL_HDR=$(python3 -c "
from astropy.io import fits
with fits.open('$HHB/final/derot.fits.fz') as h:
    for hdu in h:
        if 'POLEX' in hdu.header:
            print(f\"{hdu.header['POLEX']} {hdu.header['POLEY']} {hdu.header.get('K1',0.0)} {hdu.header.get('K2',0.0)}\")
            break" 2>/dev/null)
        if [ -n "$FINAL_HDR" ]; then
            PX=$(echo "$FINAL_HDR" | awk '{print $1}')
            PY=$(echo "$FINAL_HDR" | awk '{print $2}')
            K1=$(echo "$FINAL_HDR" | awk '{print $3}')
            K2=$(echo "$FINAL_HDR" | awk '{print $4}')
            printf '  hour %s already done; pole=(%s,%s) k1=%s k2=%s\n' \
                "$HH" "$PX" "$PY" "$K1" "$K2" | tee -a "$LOG"
            echo "$HH,$NOW,$MEAN,$PX,$PY,resumed" >> "$SUMMARY"
            continue
        fi
    fi

    # Resume: if patches-iterN/derot.fits.fz exists, jump to iter N+1
    # with pole/k1/k2 read from that header.
    RESUME_ITER=0
    if [ "$RESTART" != "1" ]; then
        LAST_PATCH_DIR=""
        for d in "$HHB"/patches-iter*/derot.fits.fz; do
            [ -e "$d" ] || continue
            LAST_PATCH_DIR="$d"
        done
        if [ -n "$LAST_PATCH_DIR" ]; then
            RESUME_ITER=$(echo "$LAST_PATCH_DIR" | sed -E 's|.*patches-iter([0-9]+).*|\1|')
            RES_HDR=$(python3 -c "
from astropy.io import fits
with fits.open('$LAST_PATCH_DIR') as h:
    for hdu in h:
        if 'POLEX' in hdu.header:
            print(f\"{hdu.header['POLEX']} {hdu.header['POLEY']} {hdu.header.get('K1',0.0)} {hdu.header.get('K2',0.0)}\")
            break" 2>/dev/null)
            if [ -n "$RES_HDR" ]; then
                PX=$(echo "$RES_HDR" | awk '{print $1}')
                PY=$(echo "$RES_HDR" | awk '{print $2}')
                K1=$(echo "$RES_HDR" | awk '{print $3}')
                K2=$(echo "$RES_HDR" | awk '{print $4}')
            fi
        fi
    fi

    step "hour $HH: seed pole=($PX,$PY) k1=$K1 k2=$K2 (resume_iter=$RESUME_ITER)"

    # find-candidates round 0
    if [ "$FORCE" = "1" ] || [ ! -e "$HHB/candidates.csv" ]; then
        run find-candidates "$HHB" --grid 100 \
            --mask "$COMBINED_MASK" --top-cells
    fi

    # bootstrap loop
    ITER="$RESUME_ITER"
    while [ "$ITER" -lt "$MAX_ITERS" ]; do
        ITER=$((ITER + 1))
        if [ "$ITER" -le "$GEOM_AFTER_ITER" ]; then
            step "  iter $ITER: fit-pole"
            FIT_OUT=$(fit-pole "$HHB" --pole-x "$PX" --pole-y "$PY" \
                --frames "$FRAMES" --patch "$PATCH" --top "$TOP" \
                --refine 2>&1)
        else
            step "  iter $ITER: fit-geometry"
            FIT_OUT=$(fit-geometry "$HHB" --pole-x "$PX" --pole-y "$PY" \
                --k1 "$K1" --k2 "$K2" \
                --frames "$FRAMES_GEOM" --patch "$PATCH" --top "$TOP" \
                2>&1)
        fi
        echo "$FIT_OUT" | tail -20 | tee -a "$LOG" >/dev/null

        REC=$(echo "$FIT_OUT" | grep -E '^recommended ' | tail -1 || true)
        NEW_PX=$(echo "$REC" | grep -oE -- '--pole-x [-0-9.]+' | awk '{print $2}' || true)
        NEW_PY=$(echo "$REC" | grep -oE -- '--pole-y [-0-9.]+' | awk '{print $2}' || true)
        NEW_K1=$(echo "$REC" | grep -oE -- '--k1 [-0-9.]+' | awk '{print $2}' || true)
        NEW_K2=$(echo "$REC" | grep -oE -- '--k2 [-0-9.]+' | awk '{print $2}' || true)
        if [ -z "$NEW_PX" ] || [ -z "$NEW_PY" ]; then
            echo "  fitter failed; aborting hour $HH" | tee -a "$LOG"
            break
        fi
        MOVE=$(python3 -c "import math; print(math.hypot($NEW_PX - $PX, $NEW_PY - $PY))")
        printf '  pole moved %.2f px (%s,%s → %s,%s)\n' \
            "$MOVE" "$PX" "$PY" "$NEW_PX" "$NEW_PY" | tee -a "$LOG"
        PX="$NEW_PX"; PY="$NEW_PY"
        [ -n "$NEW_K1" ] && K1="$NEW_K1"
        [ -n "$NEW_K2" ] && K2="$NEW_K2"

        OUT_DIR="$HHB/patches-iter$ITER"
        run derot-patches "$HHB" --pole-x "$PX" --pole-y "$PY" \
            --k1 "$K1" --k2 "$K2" \
            --frames "$FRAMES" --patch "$PATCH" --top "$TOP" \
            --out-dir "$OUT_DIR"
        mv "$OUT_DIR/stack-derot.fits.fz" "$OUT_DIR/derot.fits.fz" 2>/dev/null || true

        run find-candidates "$OUT_DIR" --grid 50 --top-cells \
            --out "$HHB/candidates.csv"

        if python3 -c "import sys; sys.exit(0 if $MOVE < $MIN_MOVE else 1)"; then
            echo "  converged after $ITER iterations" | tee -a "$LOG"
            break
        fi
    done

    # Final all-frames stack for this hour
    step "  hour $HH: final all-frames derot"
    shopt -s nullglob
    ALL_FRAMES=("$HHB"/[0-9]*.fits.fz)
    shopt -u nullglob
    ALL=${#ALL_FRAMES[@]}
    FINAL_DIR="$HHB/final"
    run derot-patches "$HHB" --pole-x "$PX" --pole-y "$PY" \
        --k1 "$K1" --k2 "$K2" \
        --frames "$ALL" --patch "$PATCH" --top "$TOP" \
        --out-dir "$FINAL_DIR"
    mv "$FINAL_DIR/stack-derot.fits.fz" "$FINAL_DIR/derot.fits.fz" 2>/dev/null || true

    echo "$HH,$NOW,$MEAN,$PX,$PY,ok" >> "$SUMMARY"
done

# ---------- Stage F: all-night derot ---------------------------------
step "F. all-night derot"
DEROT_NIGHT_ARGS=()
[ -n "$VARIANT" ] && DEROT_NIGHT_ARGS+=(--variant "$VARIANT")
run derot-night "$NIGHT" "${DEROT_NIGHT_ARGS[@]}"

# ---------- Stage G: structured run summary --------------------------
step "G. write-run-summary"
SUMMARY_ARGS=("$NIGHT")
[ -n "$VARIANT" ] && SUMMARY_ARGS+=(--variant "$VARIANT")
[ -n "$MAX_MEAN" ] && SUMMARY_ARGS+=(--max-mean "$MAX_MEAN")
SUMMARY_ARGS+=(--wall-seconds "$(($(date +%s) - T0))")
SUMMARY_ARGS+=(--started-utc "$(date -u -d "@$T0" +%FT%TZ)")
SUMMARY_ARGS+=(
    --params "pole_x=$POLE_X"
    --params "pole_y=$POLE_Y"
    --params "sky_threshold=$SKY_THRESH"
    --params "max_iters=$MAX_ITERS"
    --params "patch=$PATCH"
    --params "top=$TOP"
    --params "frames=$FRAMES"
    --params "frames_geom=$FRAMES_GEOM"
    --params "geom_after_iter=$GEOM_AFTER_ITER"
    --params "min_move=$MIN_MOVE"
)
run write-run-summary "${SUMMARY_ARGS[@]}"

step "night complete: $NIGHT"
printf 'summary: %s\n' "$SUMMARY"
column -s, -t "$SUMMARY"
