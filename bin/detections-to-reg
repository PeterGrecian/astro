#!/usr/bin/env python3
"""detections-to-reg — convert detect-stars CSV → DS9 .reg overlay.

DS9 region files are read by splay (and DS9, of course) as image-coord
overlays alongside FITS. A row per detection becomes a circle (or
ellipse, if --tangential is on and the pole columns are present).

Region colour is by SNR: green ≥ 30, yellow ≥ 10, red < 10.
Region radius is proportional to log(flux) for visual ranking.

Usage:
    detections-to-reg detections.csv detections.reg

    # With tangent-aligned ellipses (requires pole_x, pole_y columns):
    detections-to-reg detections.csv detections.reg --tangential

    # Override the default colour scheme:
    detections-to-reg detections.csv detections.reg --colour=cyan

Splay autoloads <stack>.reg next to <stack>.fits.fz; name accordingly.
"""
from __future__ import annotations

import argparse
import csv
import math
import sys
from pathlib import Path


def colour_for_snr(snr: float) -> str:
    if snr >= 30:
        return "green"
    if snr >= 10:
        return "yellow"
    return "red"


def radius_for_flux(flux: float, min_r: float = 3.0,
                    max_r: float = 12.0) -> float:
    """Log-scale radius based on flux."""
    if flux <= 0:
        return min_r
    log_flux = math.log10(max(flux, 1.0))
    # Map log_flux roughly 3..7 → min_r..max_r
    scaled = (log_flux - 3) / 4
    scaled = max(0.0, min(1.0, scaled))
    return min_r + scaled * (max_r - min_r)


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__.split("\n", 1)[0])
    ap.add_argument("detections_csv", type=Path)
    ap.add_argument("reg_out", type=Path)
    ap.add_argument("--tangential", action="store_true",
                    help="draw ellipses aligned with the tangent direction "
                         "(requires pole_x, pole_y columns)")
    ap.add_argument("--colour", default=None,
                    help="single colour for all regions (overrides SNR-coding)")
    ap.add_argument("--label", default="snr",
                    choices=["snr", "flux", "fwhm", "none", "id"],
                    help="text label per region")
    args = ap.parse_args()

    rows = list(csv.DictReader(open(args.detections_csv)))
    if not rows:
        print(f"empty: {args.detections_csv}", file=sys.stderr)
        # Still write an empty region file so splay knows.
        args.reg_out.write_text(
            "# Region file format: DS9 version 4.1\n"
            "image\n")
        return 0

    lines = [
        "# Region file format: DS9 version 4.1",
        f"# generated by detections-to-reg from {args.detections_csv.name}",
        "global color=green dashlist=8 3 width=1 "
        "font=\"helvetica 10 normal roman\" select=1 highlite=1 "
        "dash=0 fixed=0 edit=1 move=1 delete=1 include=1 source=1",
        "image",
    ]

    for i, r in enumerate(rows):
        cx = float(r["centroid_x"]) + 1  # DS9 uses 1-indexed image coords
        cy = float(r["centroid_y"]) + 1
        flux = float(r.get("flux", 0))
        snr = float(r.get("snr", 0))
        rad = radius_for_flux(flux)
        col = args.colour or colour_for_snr(snr)

        # Label text
        if args.label == "snr":
            text = f"snr={snr:.0f}"
        elif args.label == "flux":
            text = f"f={flux:.0f}"
        elif args.label == "fwhm":
            text = f"f={float(r.get('fwhm_mean', 0)):.1f}"
        elif args.label == "id":
            text = str(r.get("detection_id", i))
        else:
            text = ""

        if args.tangential and "pole_x" in r and "pole_y" in r:
            # Ellipse aligned with tangent at the detection's position.
            px = float(r["pole_x"])
            py = float(r["pole_y"])
            dx = cx - 1 - px
            dy = cy - 1 - py
            # Tangent direction angle (deg, image-coord CCW from +x).
            angle_deg = math.degrees(math.atan2(dx, -dy)) % 360
            # Major axis (along tangent) somewhat longer than perpendicular.
            major = rad * 1.6
            minor = rad
            line = (f'ellipse({cx:.2f},{cy:.2f},'
                    f'{major:.2f},{minor:.2f},{angle_deg:.1f}) '
                    f'# color={col} text="{text}"')
        else:
            line = (f'circle({cx:.2f},{cy:.2f},{rad:.2f}) '
                    f'# color={col} text="{text}"')
        lines.append(line)

    args.reg_out.write_text("\n".join(lines) + "\n")
    print(f"wrote {args.reg_out} ({len(rows)} regions)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
