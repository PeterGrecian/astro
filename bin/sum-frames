#!/usr/bin/env python3
"""sum-frames — raw pixel-wise sum of all .fits.fz in a directory.

No derotation, no abs-diff, no time-window logic: just `acc = sum
frame[i]` for every .fits.fz directly under the given dir. Use this
when you want to look at "what does an hour of sky look like
stacked" — stars trace arcs, hot pixels stack to N x, sky averages up.

For abs-diff (motion-only) stacking use `streak-sum`.
For derotated stacking (collapse arcs back to points) use `derot-sim`
(sim) or — when the real-data derotator lands — `derotate`.

Output:
  <dir>/sum.fits.fz   uint16 clipped sum (accumulator is uint32)

Usage:
    sum-frames                              # cwd
    sum-frames /path/to/HH
    sum-frames /path/to/HH --out other.fits.fz
"""
from __future__ import annotations

import argparse
import sys
from pathlib import Path

import numpy as np
from astropy.io import fits
from PIL import Image


def load_frame(path: Path) -> np.ndarray:
    with fits.open(path, memmap=True) as h:
        for hdu in h:
            if hdu.data is not None and hdu.data.ndim == 2:
                return hdu.data
    raise SystemExit(f"no 2D image in {path}")


def main() -> int:
    ap = argparse.ArgumentParser(
        description=__doc__.split("\n", 1)[0],
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    ap.add_argument("dir", type=Path, nargs="?", default=Path.cwd(),
                    help="directory containing .fits.fz (default: cwd)")
    ap.add_argument("--out", type=Path, default=None,
                    help="output FITS path (default: <dir>/sum.fits.fz)")
    ap.add_argument("--out-jpg", type=Path, default=None,
                    help="output JPG path (default: sibling of --out, "
                         "renamed sum.jpg). Use to land the eyeballable "
                         "JPG outside the input dir.")
    args = ap.parse_args()

    fns = sorted(args.dir.glob("*.fits.fz"))
    fns = [f for f in fns if f.name not in ("sum.fits.fz",)
           and not f.name.startswith("stack")]
    if not fns:
        print(f"no .fits.fz in {args.dir}", file=sys.stderr)
        return 1

    out_path = args.out or (args.dir / "sum.fits.fz")
    print(f"summing {len(fns)} frames from {args.dir}")

    acc: np.ndarray | None = None
    for i, fn in enumerate(fns):
        d = load_frame(fn).astype(np.uint32)
        acc = d if acc is None else acc + d
        if i == 0 or (i + 1) % 200 == 0 or i == len(fns) - 1:
            print(f"  [{i+1}/{len(fns)}] acc max={int(acc.max())}",
                  flush=True)

    assert acc is not None
    print(f"sum: min={int(acc.min())} max={int(acc.max())} "
          f"mean={float(acc.mean()):.1f}")

    # Store as int32 to preserve the full accumulator range (hot pixels
    # can sum to millions of ADU). FITS doesn't have native uint32 but
    # int32 covers up to 2**31 = 2.1e9 — plenty for any plausible stack.
    primary = fits.PrimaryHDU()
    comp = fits.CompImageHDU(data=acc.astype(np.int32),
                             compression_type="RICE_1")
    comp.header["NFRAMES"] = (len(fns), "frames summed (raw)")
    fits.HDUList([primary, comp]).writeto(out_path, overwrite=True)
    print(f"wrote {out_path}")

    # Companion jpg for quick eyeballing. p50 → p99.9 (top 0.1% saturate)
    # so dim hours don't look "burnt" just because hot pixels stand out.
    jpg_path = args.out_jpg or out_path.with_suffix("").with_suffix(".jpg")
    jpg_path.parent.mkdir(parents=True, exist_ok=True)
    lo = float(np.percentile(acc, 50))
    hi = float(np.percentile(acc, 99.9))
    if hi <= lo:
        hi = lo + 1.0
    u8 = (np.clip((acc - lo) / (hi - lo), 0, 1) * 255).astype(np.uint8)
    Image.fromarray(u8).save(jpg_path, quality=92)
    print(f"wrote {jpg_path} (p50={lo:.0f} → p99.9={hi:.0f})")
    return 0


if __name__ == "__main__":
    sys.exit(main())
