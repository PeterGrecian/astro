#!/usr/bin/env python3
"""scan-brightness — per-frame brightness stats for a night.

Walks every HH/ subdir under a night dir and writes a `brightness.csv`
*inside each HH dir* with one row per frame. Re-running is cheap: if
the CSV already has a row for every frame in the dir, it's skipped;
otherwise only the missing frames are measured and appended.

CSV columns:
    epoch_ms, iso_utc, filename, mean, median, p95, max, bright_pixels

Where `bright_pixels` = count of pixels >= 500 (a "something hot in this
frame" signal — saturated stars, aircraft lights, hot pixels).

By default both .fits.fz (→ brightness.csv) and .npy (→ brightnessnpy.csv)
are scanned. Use --only fits or --only npy to restrict.

Usage:
    scan-brightness <night-dir>
    scan-brightness <night-dir> --only fits            # only .fits.fz
    scan-brightness <night-dir> --only npy             # only .npy
    scan-brightness <night-dir> --limit 100            # smoke test
"""
from __future__ import annotations

import argparse
import csv
import sys
import time
from datetime import datetime, timezone
from pathlib import Path

import numpy as np
from astropy.io import fits


def load_frame(path: Path) -> np.ndarray:
    """Return the 2D image array regardless of fits.fz or npy input."""
    if path.suffix == ".npy":
        return np.load(path, mmap_mode="r")
    with fits.open(path, memmap=True) as h:
        for hdu in h:
            if hdu.data is not None and hdu.data.ndim == 2:
                return hdu.data
    raise SystemExit(f"no 2D image in {path}")


def epoch_ms_from_name(p: Path) -> int | None:
    # Strip ALL extensions: 1779404330189.fits.fz → 1779404330189
    name = p.name.split(".", 1)[0]
    try:
        return int(name)
    except ValueError:
        return None


EXAMPLES = """\
Examples:
  scan-brightness ~/starcam-frames/night/2026-05-21
      → writes <night>/HH/brightness.csv for each hour dir

  scan-brightness ~/starcam-frames/night/2026-05-21 --limit 50
      → smoke test on at most 50 frames per hour dir

  scan-brightness ~/starcam-frames/night/2026-05-21 --only npy
      → scan .npy files only (→ brightnessnpy.csv)

  scan-brightness ~/starcam-frames/night/2026-05-21 --only fits
      → scan .fits.fz only (→ brightness.csv)

CSV columns:
  epoch_ms, iso_utc, filename, mean, median, p95, max, bright_pixels
"""


HEADER = ["epoch_ms", "iso_utc", "filename",
          "mean", "median", "p95", "max", "bright_pixels"]


def read_done(csv_path: Path) -> set[str]:
    """Return set of filenames already present in the CSV (basename)."""
    if not csv_path.exists():
        return set()
    done: set[str] = set()
    with open(csv_path, newline="") as f:
        r = csv.reader(f)
        try:
            header = next(r)
        except StopIteration:
            return done
        if header != HEADER:
            # Unknown format — treat as empty and overwrite header on append.
            return done
        for row in r:
            if len(row) >= 3:
                done.add(Path(row[2]).name)
    return done


def measure(fn: Path):
    arr = load_frame(fn)
    epoch_ms = epoch_ms_from_name(fn)
    if epoch_ms is None:
        return None
    iso = datetime.fromtimestamp(epoch_ms / 1000, tz=timezone.utc).isoformat()
    mean = float(arr.mean())
    median = float(np.median(arr))
    p95 = float(np.percentile(arr, 95))
    mx = int(arr.max())
    bright = int((arr >= 500).sum())
    return [epoch_ms, iso, str(fn), f"{mean:.3f}",
            f"{median:.1f}", f"{p95:.1f}", mx, bright]


def process_hour_dir(hour_dir: Path, ext: str, csv_name: str,
                     limit: int) -> None:
    csv_path = hour_dir / csv_name
    # Create CSV (with header) before counting, so it exists from the off.
    if not csv_path.exists() or csv_path.stat().st_size == 0:
        with open(csv_path, "w", newline="") as f:
            csv.writer(f).writerow(HEADER)

    files = sorted(hour_dir.glob(ext))
    if not files:
        print(f"{hour_dir}: no {ext} frames", flush=True)
        return
    done = read_done(csv_path)

    if len(done) == len(files) and all(f.name in done for f in files):
        print(f"{hour_dir}: {len(files)} {ext}, csv complete — skip",
              flush=True)
        return

    todo = [f for f in files if f.name not in done]
    if limit:
        todo = todo[:limit]
    print(f"{hour_dir}: {len(files)} {ext}, {len(done)} done, "
          f"{len(todo)} to measure → {csv_path.name}", flush=True)

    t0 = time.time()
    with open(csv_path, "a", newline="") as f:
        w = csv.writer(f)
        for i, fn in enumerate(todo):
            try:
                row = measure(fn)
            except Exception as e:
                print(f"  [{i}] FAIL {fn}: {e}", file=sys.stderr)
                continue
            if row is None:
                continue
            w.writerow(row)
            if i == 0 or i % 200 == 0:
                elapsed = time.time() - t0
                rate = (i + 1) / max(0.001, elapsed)
                eta = (len(todo) - i - 1) / max(0.001, rate)
                print(f"  [{i}/{len(todo)}] {fn.name} "
                      f"mean={row[3]} max={row[6]} bright={row[7]} "
                      f"({rate:.1f} fps, ETA {eta/60:.1f} min)",
                      flush=True)
    print(f"  wrote {csv_path} in {time.time()-t0:.1f}s", flush=True)


def main() -> int:
    ap = argparse.ArgumentParser(
        description=__doc__.split("\n", 1)[0],
        epilog=EXAMPLES,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    ap.add_argument("night_dir", type=Path,
                    help="night dir containing HH/*.fits.fz, OR a single HH dir")
    ap.add_argument("--only", choices=["fits", "npy"], default=None,
                    help="scan only one format (default: both)")
    ap.add_argument("--limit", type=int, default=0,
                    help="per-hour cap on new measurements (0 = no cap)")
    args = ap.parse_args()

    # (glob pattern, csv filename) per format we'll scan
    formats: list[tuple[str, str]] = []
    if args.only in (None, "fits"):
        formats.append(("*.fits.fz", "brightness.csv"))
    if args.only in (None, "npy"):
        formats.append(("*.npy", "brightnessnpy.csv"))

    # If the arg looks like an HH dir (contains frames directly), treat it
    # as a single hour; otherwise treat as a night dir of HH subdirs.
    has_frames = any(args.night_dir.glob("*.fits.fz")) or \
        any(args.night_dir.glob("*.npy"))
    if has_frames:
        hour_dirs = [args.night_dir]
    else:
        hour_dirs = sorted(d for d in args.night_dir.iterdir() if d.is_dir())
    if not hour_dirs:
        print(f"no subdirectories in {args.night_dir}", file=sys.stderr)
        return 1

    for hd in hour_dirs:
        for ext, csv_name in formats:
            process_hour_dir(hd, ext, csv_name, args.limit)
    return 0


if __name__ == "__main__":
    sys.exit(main())
