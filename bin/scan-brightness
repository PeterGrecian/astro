#!/usr/bin/env python3
"""scan-brightness — per-frame brightness stats for a night.

Walks every .fits.fz (or .npy if requested) in a night dir, emits a
CSV row per frame. Cheap to re-slice later for outlier hunts and
"give me the darkest N% in this window" queries.

CSV columns:
    epoch_ms, iso_utc, filename, mean, median, p95, max, bright_pixels

Where `bright_pixels` = count of pixels >= 500 (a "something hot in this
frame" signal — saturated stars, aircraft lights, hot pixels).

Usage:
    scan-brightness <night-dir>                        # default → night.csv
    scan-brightness <night-dir> --out my.csv
    scan-brightness <night-dir> --npy                  # read .npy not .fits.fz
    scan-brightness <night-dir> --limit 100            # smoke test
"""
from __future__ import annotations

import argparse
import csv
import os
import sys
import time
from datetime import datetime, timezone
from pathlib import Path

import numpy as np
from astropy.io import fits


def load_frame(path: Path) -> np.ndarray:
    """Return the 2D image array regardless of fits.fz or npy input."""
    if path.suffix == ".npy":
        return np.load(path, mmap_mode="r")
    with fits.open(path, memmap=True) as h:
        for hdu in h:
            if hdu.data is not None and hdu.data.ndim == 2:
                return hdu.data
    raise SystemExit(f"no 2D image in {path}")


def epoch_ms_from_name(p: Path) -> int | None:
    # Strip ALL extensions: 1779404330189.fits.fz → 1779404330189
    name = p.name.split(".", 1)[0]
    try:
        return int(name)
    except ValueError:
        return None


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__.split("\n", 1)[0])
    ap.add_argument("night_dir", type=Path)
    ap.add_argument("--out", type=Path, default=None,
                    help="output CSV (default: <night-dir>/brightness.csv)")
    ap.add_argument("--npy", action="store_true",
                    help="scan .npy instead of .fits.fz")
    ap.add_argument("--limit", type=int, default=0,
                    help="cap (0 = no cap)")
    args = ap.parse_args()

    ext = "*.npy" if args.npy else "*.fits.fz"
    files = sorted(args.night_dir.rglob(ext))
    print(f"{len(files)} {ext} frames in {args.night_dir}", flush=True)
    if args.limit:
        files = files[:args.limit]
        print(f"limited to {len(files)}", flush=True)
    if not files:
        return 1

    out_path = args.out or (args.night_dir / "brightness.csv")
    print(f"writing → {out_path}")

    t0 = time.time()
    with open(out_path, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(["epoch_ms", "iso_utc", "filename",
                    "mean", "median", "p95", "max", "bright_pixels"])
        for i, fn in enumerate(files):
            try:
                arr = load_frame(fn)
            except Exception as e:
                print(f"  [{i}] FAIL {fn}: {e}", file=sys.stderr)
                continue
            epoch_ms = epoch_ms_from_name(fn)
            if epoch_ms is None:
                continue
            iso = datetime.fromtimestamp(
                epoch_ms / 1000, tz=timezone.utc).isoformat()
            mean = float(arr.mean())
            median = float(np.median(arr))
            p95 = float(np.percentile(arr, 95))
            mx = int(arr.max())
            bright = int((arr >= 500).sum())
            w.writerow([epoch_ms, iso, str(fn), f"{mean:.3f}",
                        f"{median:.1f}", f"{p95:.1f}", mx, bright])
            if i == 0 or i % 200 == 0:
                elapsed = time.time() - t0
                rate = (i + 1) / max(0.001, elapsed)
                eta = (len(files) - i - 1) / max(0.001, rate)
                print(f"  [{i}/{len(files)}] {fn.name} "
                      f"mean={mean:.1f} max={mx} bright={bright} "
                      f"({rate:.1f} fps, ETA {eta/60:.1f} min)",
                      flush=True)
    print(f"wrote {out_path} in {time.time()-t0:.1f}s", flush=True)
    return 0


if __name__ == "__main__":
    sys.exit(main())
