#!/usr/bin/env python3
"""detrans-sweep — animate de-translated (detrans) stacks across a night.

For a far-off-pole camera (eclipticam-v3w) the star motion across the
sensor is, over a short window, a near-uniform TRANSLATION. "Detrans" a
window = undistort each frame (k1,k2), shift each by -v*(t-t0) to cancel
that translation, then max-stack — the per-frame 60 s streaks overlap
into one sharp, high-SNR streak per star instead of smearing across the
window. Sliding the window 1 min per output frame and encoding the
stacks to mp4 gives an animation of the night with registered streaks.

Calibration (eclipticam-v3w, from the star-trail distortion + detrans
velocity work, worklog 2026-06-21): k1=-0.636, k2=+0.311 (radial,
binned 1152x648, centre=frame centre, rho=half-diag); v=0.040 px/s at
7.8 deg from horizontal.

Step-by-step friendly: --max-windows N processes only the first N
output frames (a short slice) so you can check + time before the full
night.

Usage
-----
    detrans-sweep --camera eclipticam-v3w --night 2026-06-20 \\
        --window-min 10 --step-min 1 --out ~/tmp/detrans-sweep.mp4 \\
        [--max-windows 20]
"""
from __future__ import annotations

import argparse
import glob
import os
import subprocess
import sys
import time
from pathlib import Path

import numpy as np
import cv2
from astropy.io import fits

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
from astro.config import CameraConfig

# eclipticam-v3w calibration — fallback defaults; the real values are
# read from camera.json (distortion + detrans blocks).
#
# Detrans velocity is stored resolution-INDEPENDENTLY as a fraction of
# image WIDTH per second, so it survives capture-resolution changes (the
# night daemon went 2304x1296 binned -> 4608x2592 full-res on 2026-06-22).
# At runtime it is scaled to whatever width the working frame is at:
#   v_px_per_s = v_frac_per_s * W.
# The original fit was v=0.040 px/s on the binned 1152-wide geometry, i.e.
# 0.040 / 1152 = 3.4722e-5 of the width per second.
K1, K2 = -0.636, 0.311
V_FRAC_PS = 0.040 / 1152.0        # fraction of image width per second
V_ANGLE_DEG = 7.8

# Crop fractions to trim the barrel-undistort black border, per edge
# (left, right, top, bottom). Established by hand in GIMP from a real
# detrans frame (peter@pip 2026-06-28). The two modes differ only on the
# RIGHT edge: deep uses the closer "version 2" framing (~1.84 aspect),
# trimming more of the busy ghost/streak region on the right; max keeps it
# wider (~2.31). yuv420p/libx264 needs even dims — the slice below rounds
# down to even.
_CLOSE_CROP = (0.142, 0.299, 0.189, 0.270)   # L, R, T, B -> ~1.84 aspect
CROP_FRAC = {
    #          left,   right,  top,    bottom
    "max":  (0.142, 0.155, 0.189, 0.270),   # 2.31 aspect (wider)
    "deep": _CLOSE_CROP,                     # 1.84 aspect (closer, deep only)
}


def epoch_ms(p):
    return int(Path(p).name.split(".")[0])


def load_bin(p, n=1):
    """Load a v3w frame and optionally n×n sum-bin it.

    n=1 keeps full resolution (the default — we want the detail). n>1
    bins for speed/SNR. Resolution no longer needs to match any fixed
    calibration geometry: distortion rho is normalised (scale-invariant)
    and detrans v is a fraction of image width (scaled to W at runtime),
    so both survive the 2026-06-22 full-res switch and any binning."""
    d = fits.open(p)[1].data.astype(np.float32)
    if n <= 1:
        return d
    H, W = d.shape
    H, W = H // n * n, W // n * n
    d = d[:H, :W]
    return d.reshape(H // n, n, W // n, n).sum(axis=(1, 3))


def undistort_map(H, W, k1=K1, k2=K2):
    cx, cy = (W - 1) / 2.0, (H - 1) / 2.0
    R = 0.5 * np.hypot(W, H)
    ys, xs = np.mgrid[0:H, 0:W].astype(np.float32)
    dx, dy = xs - cx, ys - cy
    rt = np.sqrt(dx * dx + dy * dy) / R
    s = np.ones_like(rt)
    for _ in range(12):
        rd = rt / s
        s = 1 + k1 * rd * rd + k2 * rd ** 4
    return (cx + dx / s).astype(np.float32), (cy + dy / s).astype(np.float32)


def stretch_u8(img, lo_pct=50, hi_pct=99.6, linear=False):
    """asinh percentile stretch (max mode) or a plain LINEAR percentile
    clip (deep mode). The linear lo=13 hi=97.4 default matches splay's
    own stretch (fits_array_to_surface) tuned for the deep mean-bg
    image — black at the noise floor, white at p97.4, so the faint
    stars span the full range."""
    lo, hi = np.percentile(img, lo_pct), np.percentile(img, hi_pct)
    x = np.clip((img - lo) / max(hi - lo, 1e-6), 0, 1 if linear else None)
    if linear:
        return (x * 255).astype(np.uint8)
    return np.clip(np.arcsinh(x * 12) / np.arcsinh(12) * 255, 0, 255).astype(np.uint8)


def local_bg_subtract(img, down=4, med=13):
    """Subtract a large-kernel median background (downsample-filter-
    upsample for speed). Used by deep mode to remove the sky pedestal
    so faint registered stars sit on a near-zero, low-noise floor —
    the maximum-SNR / deepest path."""
    from scipy import ndimage
    small = cv2.resize(img, (img.shape[1] // down, img.shape[0] // down),
                       interpolation=cv2.INTER_AREA)
    bg_small = ndimage.median_filter(small, size=med)
    bg = cv2.resize(bg_small, (img.shape[1], img.shape[0]),
                    interpolation=cv2.INTER_LINEAR)
    return np.clip(img - bg, 0, None)


def main():
    ap = argparse.ArgumentParser(description=__doc__.split("\n", 1)[0])
    ap.add_argument("--camera", default="eclipticam-v3w")
    ap.add_argument("--night", required=True)
    ap.add_argument("--window-min", type=float, default=10.0)
    ap.add_argument("--step-min", type=float, default=1.0)
    ap.add_argument("--mode", choices=("max", "deep"), default="max",
                    help="max: overlap 60s streaks into one bright streak "
                         "(animation). deep: MEAN the registered frames "
                         "then subtract local background — maximum SNR, "
                         "pulls the faintest stars (linear p13-p97.4 "
                         "stretch matching splay).")
    ap.add_argument("--v", type=float, default=None,
                    help="detrans velocity as FRACTION of image width per "
                         "second (default: camera.json detrans.v_frac_per_s)")
    ap.add_argument("--v-px", type=float, default=None,
                    help="detrans velocity in px/sec at the WORKING "
                         "resolution — dev override; bypasses fraction scaling")
    ap.add_argument("--angle", type=float, default=None,
                    help="deg (default: camera.json detrans.angle_deg)")
    ap.add_argument("--k1", type=float, default=None)
    ap.add_argument("--k2", type=float, default=None)
    ap.add_argument("--bin", type=int, default=1,
                    help="n×n sum-bin factor (1=full res, default). Larger "
                         "is faster/higher-SNR; v scales automatically.")
    ap.add_argument("--fps", type=int, default=12)
    ap.add_argument("--max-windows", type=int, default=None,
                    help="process only the first N output frames (slice)")
    ap.add_argument("--out", type=Path, required=True)
    ap.add_argument("--frames-glob", default=None,
                    help="override frame glob (default resolves v3w night)")
    args = ap.parse_args()

    cfg = CameraConfig.load(args.camera)
    # Calibration from camera.json (distortion + detrans blocks), with
    # CLI overrides and the module fallbacks. A camera with no `detrans`
    # block isn't a detrans candidate — skip cleanly so the pipeline can
    # call this unconditionally.
    detr = cfg.get("detrans") or {}
    dist = cfg.get("distortion") or {}
    if not detr and args.v is None and args.v_px is None:
        sys.stderr.write(f"{args.camera} has no `detrans` block in "
                         "camera.json and no --v/--v-px given; skipping "
                         "(not a detrans camera)\n")
        return 0
    # Detrans velocity as a fraction of image width per second. Prefer the
    # resolution-independent config key; fall back to the legacy px/s key
    # (which was fit on the binned 1152-wide geometry) divided by 1152.
    if args.v is not None:
        v_frac = args.v
    elif "v_frac_per_s" in detr:
        v_frac = detr["v_frac_per_s"]
    elif "v_px_per_s" in detr:
        v_frac = detr["v_px_per_s"] / 1152.0     # legacy: fit at 1152-wide
    else:
        v_frac = V_FRAC_PS
    angle = args.angle if args.angle is not None \
        else detr.get("angle_deg", V_ANGLE_DEG)
    k1 = args.k1 if args.k1 is not None else dist.get("k1", K1)
    k2 = args.k2 if args.k2 is not None else dist.get("k2", K2)

    if args.frames_glob:
        fs = glob.glob(args.frames_glob)
    else:
        # legacy percam tree: <root>/night/<night>/v3w/HH/*.fits.fz
        base = cfg.frames_root / "night" / args.night / "v3w"
        fs = glob.glob(str(base / "*" / "*.fits.fz"))
    if not fs:
        sys.stderr.write("no frames found\n")
        return 2
    # Sort by TIMESTAMP, not lexically: the night spans 23->00->01->02 UTC
    # and the hour dirs sort 00,01,02,23 — lexical order is non-monotonic
    # in time, which breaks the windowing.
    fs = sorted(fs, key=epoch_ms)
    t0_ms = epoch_ms(fs[0])
    ts = np.array([(epoch_ms(p) - t0_ms) / 1000.0 for p in fs])
    print(f"{len(fs)} frames spanning {ts[-1]/3600:.2f} h")

    win_s = args.window_min * 60
    step_s = args.step_min * 60
    starts = np.arange(0, ts[-1] - win_s, step_s)
    if args.max_windows:
        starts = starts[:args.max_windows]
    print(f"{len(starts)} output frames "
          f"(window {args.window_min}min, step {args.step_min}min)")

    # peek one frame for geometry + map
    H, W = load_bin(fs[0], args.bin).shape
    mapx, mapy = undistort_map(H, W, k1, k2)
    a = np.radians(angle)
    dv = np.array([np.cos(a), np.sin(a)])

    # Resolve detrans velocity to px/s at THIS working resolution. --v-px
    # is an explicit px/s override at the working res (dev use); otherwise
    # scale the width-fraction by the actual frame width.
    v = args.v_px if args.v_px is not None else v_frac * W
    print(f"calibration: v={v:.4f} px/s ({v_frac*1e5:.4f}e-5 width/s) "
          f"@ {angle}deg, k1={k1} k2={k2}, {W}x{H} (bin {args.bin})")

    args.out.parent.mkdir(parents=True, exist_ok=True)
    # mode-specific scratch so max + deep runs don't collide
    tmpdir = Path(f"~/tmp/detrans-sweep-frames-{args.mode}").expanduser()
    tmpdir.mkdir(parents=True, exist_ok=True)
    for f in tmpdir.glob("*.png"):
        f.unlink()

    # Cache decoded+undistorted frames lazily — adjacent windows overlap
    # (e.g. 10-min window, 1-min step => ~9/10 frames shared), so caching
    # the active working set avoids re-decoding. Each cached frame is a
    # full binned float array, so the cache MUST be bounded to the frames
    # still reachable, or it grows across the whole night and swaps a 1GB
    # Pi (measured ~440MB+ with the old loose eviction). Windows advance
    # monotonically in time, so once a window is done, any frame before the
    # NEXT window's first frame is dead — evict it (see prune_cache below).
    cache = {}

    def get_und(i):
        if i not in cache:
            cache[i] = cv2.remap(load_bin(fs[i], args.bin), mapx, mapy,
                                 cv2.INTER_LINEAR)
        return cache[i]

    def prune_cache(min_keep_idx):
        """Drop cached frames below min_keep_idx (no future window needs them)."""
        for k in [k for k in cache if k < min_keep_idx]:
            del cache[k]

    t_start = time.monotonic()
    for wi, w0 in enumerate(starts):
        w1 = w0 + win_s
        idx = np.where((ts >= w0) & (ts < w1))[0]
        if len(idx) == 0:
            continue
        wt0 = ts[idx[0]]
        if args.mode == "deep":
            # MEAN the registered frames (noise averages down √N), then
            # subtract the local background → faint stars on a near-zero
            # floor. Linear p13-p97.4 stretch (splay's), tuned for depth.
            acc = np.zeros((H, W), dtype=np.float64)
            for i in idx:
                sh = -v * (ts[i] - wt0) * dv
                M = np.float32([[1, 0, sh[0]], [0, 1, sh[1]]])
                acc += cv2.warpAffine(get_und(i), M, (W, H),
                                      flags=cv2.INTER_LINEAR)
            deep = local_bg_subtract((acc / len(idx)).astype(np.float32))
            out8 = stretch_u8(deep, lo_pct=13.0, hi_pct=97.4, linear=True)
        else:
            # MAX: overlap the 60s streaks into one bright streak.
            acc = None
            for i in idx:
                sh = -v * (ts[i] - wt0) * dv
                M = np.float32([[1, 0, sh[0]], [0, 1, sh[1]]])
                w = cv2.warpAffine(get_und(i), M, (W, H),
                                   flags=cv2.INTER_LINEAR)
                acc = w if acc is None else np.maximum(acc, w)
            out8 = stretch_u8(acc)
        # Crop the barrel-undistort black border (per-edge, mode-specific —
        # see CROP_FRAC). Undistorting k1=-0.636 leaves a lens-shaped valid
        # region inside black wedges; a full black-free crop would discard
        # most of the frame, so trim a hand-tuned inset. Fractional =>
        # resolution-independent.
        fl, fr, ft, fb = CROP_FRAC[args.mode]
        ch, cw = out8.shape[:2]
        x0, x1 = int(cw * fl), cw - int(cw * fr)
        y0, y1 = int(ch * ft), ch - int(ch * fb)
        out8 = out8[y0:y1, x0:x1]
        # yuv420p / libx264 needs even dimensions — drop a last row/col if odd.
        out8 = out8[:out8.shape[0] // 2 * 2, :out8.shape[1] // 2 * 2]
        cv2.imwrite(str(tmpdir / f"f{wi:04d}.png"), out8)
        # Bound the cache: the next window starts at starts[wi]+step_s, so any
        # frame before that is no longer reachable — evict it. Keeps the cache
        # to ~one window's worth of frames (the working set), not the whole
        # night. This is what stops the 1GB-Pi swap.
        next_w0 = starts[wi] + step_s
        keep_from = int(np.searchsorted(ts, next_w0, side="left"))
        prune_cache(keep_from)
        if wi % 20 == 0:
            el = time.monotonic() - t_start
            print(f"  {wi+1}/{len(starts)}  {el:.0f}s "
                  f"({el/(wi+1):.2f}s/frame)  cache={len(cache)}", flush=True)

    # encode. x264 preset/threads bound memory (frames held resident) —
    # default medium OOM'd the 1GB Pi. Honour host-aware FFMPEG_PRESET/THREADS
    # from publish-night-cam; default safe.
    _preset = os.environ.get("FFMPEG_PRESET", "veryfast")
    _threads = os.environ.get("FFMPEG_THREADS", "1")
    print("encoding...")
    subprocess.run([
        "ffmpeg", "-y", "-loglevel", "error",
        "-threads", str(_threads), "-framerate", str(args.fps),
        "-i", str(tmpdir / "f%04d.png"),
        "-c:v", "libx264", "-pix_fmt", "yuv420p", "-crf", "20",
        "-preset", _preset,
        str(args.out)], check=True)
    print(f"wrote {args.out} "
          f"({len(starts)} frames, {time.monotonic()-t_start:.0f}s total)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
