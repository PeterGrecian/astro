#!/usr/bin/env python3
"""Drive SG90 to a target angle smoothly and write state file.

Invoked by cover-open.service / cover-close.service on the camera Pi.

pigpiod idles at ~12% CPU on the Pi 1B, so we start it just for the
move and stop it after. Requires passwordless sudo for
`systemctl start/stop pigpiod` (installed by the astro-camera role
via /etc/sudoers.d/peter-pigpiod).
"""
import subprocess
import sys
import time
from pathlib import Path

SIGNAL_PIN = 18
DEG_PER_SEC = 30.0
STEP_HZ = 50
STATE_PATH = Path.home() / ".cover-state"


def main():
    if len(sys.argv) != 3:
        print("usage: cover-move <angle_deg> <state_label>", file=sys.stderr)
        sys.exit(2)
    target_deg = float(sys.argv[1])
    state_label = sys.argv[2]

    subprocess.run(["sudo", "systemctl", "start", "pigpiod"], check=True)
    try:
        time.sleep(0.3)
        from gpiozero import Servo
        from gpiozero.pins.pigpio import PiGPIOFactory

        servo = Servo(SIGNAL_PIN, pin_factory=PiGPIOFactory())
        current = 0.0
        servo.value = 0.0
        time.sleep(0.3)

        dt = 1.0 / STEP_HZ
        step = DEG_PER_SEC * dt
        while abs(current - target_deg) > step / 2:
            current += step if target_deg > current else -step
            servo.value = max(-1.0, min(1.0, current / 90.0))
            time.sleep(dt)
        servo.value = max(-1.0, min(1.0, target_deg / 90.0))
        time.sleep(0.5)
        servo.detach()
    finally:
        subprocess.run(["sudo", "systemctl", "stop", "pigpiod"], check=False)

    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
    STATE_PATH.write_text(f"{state_label}\n{target_deg}\n{int(time.time())}\n")
    print(f"cover now {state_label} (angle={target_deg})")
    append_night_log(state_label, target_deg)
    alert_state_change(state_label, target_deg)


def append_night_log(state_label: str, angle: float) -> None:
    """Append the event to the night's frame dir on NFS so puppy can read it
    without scraping the journal. iso_utc,state,angle columns. The night
    label uses noon-rollover, matching where the daemon writes frames."""
    iso = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
    night = time.strftime("%Y-%m-%d", time.gmtime(time.time() - 12 * 3600))
    night_dir = Path.home() / "starcam-frames" / "night" / night
    cover_csv = night_dir / "cover.csv"
    try:
        night_dir.mkdir(parents=True, exist_ok=True)
        new_file = not cover_csv.exists()
        with open(cover_csv, "a") as f:
            if new_file:
                f.write("iso_utc,state,angle\n")
            f.write(f"{iso},{state_label},{angle}\n")
    except OSError as e:
        # NFS down or dir not writable — non-fatal, the move still happened.
        print(f"cover-move: night-log append failed (non-fatal): {e}",
              file=sys.stderr)


def alert_state_change(state_label: str, angle: float) -> None:
    """Notify on every actual cover move (Slack + quiet xMatters). This is the
    universal chokepoint — controller, the 05:00 safety close and manual moves
    all end here, so alerting here covers every state change exactly once.
    Best-effort: never let a notification failure affect the move."""
    alert = Path.home() / "super" / "bin" / "alert"
    if not alert.exists():
        return
    try:
        subprocess.run(
            [str(alert), "--xinfo", "--source", "starcam",
             "--detail", f"angle={angle}", f"starcam cover {state_label.upper()}"],
            check=False, timeout=20)
    except Exception as e:
        print(f"cover-move: alert failed (non-fatal): {e}", file=sys.stderr)


if __name__ == "__main__":
    main()
