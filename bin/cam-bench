#!/usr/bin/env python3
"""Benchmark: capture full-res raw .npy, 2x2 sum-bin, write rice .fits.fz.
Reports per-stage timing."""
import sys
import time
import argparse
from pathlib import Path
import numpy as np
from picamera2 import Picamera2
from astropy.io import fits

ap = argparse.ArgumentParser()
ap.add_argument("--camera", type=int, default=0)
ap.add_argument("--out", default="/tmp/bench.fits.fz")
ap.add_argument("--reps", type=int, default=3)
args = ap.parse_args()

cam = Picamera2(camera_num=args.camera)
# Use the sensor's full-res raw mode. Each sensor has different max:
modes = cam.sensor_modes
full = max(modes, key=lambda m: m["size"][0] * m["size"][1])
print(f"sensor max mode: {full['size']} fmt={full['format']}")

cfg = cam.create_still_configuration(raw={"size": full["size"]})
cam.configure(cfg)
cam.start()
time.sleep(0.3)

for rep in range(args.reps):
    t0 = time.perf_counter()
    req = cam.capture_request()
    try:
        raw = req.make_array("raw")
    finally:
        req.release()
    t_capture = time.perf_counter() - t0

    arr = raw.view(np.uint16)
    print(f"  raw shape={arr.shape} dtype={arr.dtype} nbytes={arr.nbytes/1e6:.1f} MB")

    t0 = time.perf_counter()
    np.save("/tmp/bench.npy", arr)
    t_npy = time.perf_counter() - t0
    npy_sz = Path("/tmp/bench.npy").stat().st_size

    # 2x2 sum-bin
    t0 = time.perf_counter()
    h, w = arr.shape[:2]
    h2, w2 = h - (h % 2), w - (w % 2)
    a = arr[:h2, :w2]
    binned = (a[0::2, 0::2].astype(np.uint32) +
              a[0::2, 1::2] + a[1::2, 0::2] + a[1::2, 1::2])
    binned = np.clip(binned, 0, 65535).astype(np.uint16)
    t_bin = time.perf_counter() - t0

    # rice-compressed fits
    t0 = time.perf_counter()
    hdu = fits.CompImageHDU(binned, compression_type="RICE_1")
    hdul = fits.HDUList([fits.PrimaryHDU(), hdu])
    hdul.writeto(args.out, overwrite=True)
    t_fits = time.perf_counter() - t0
    fits_sz = Path(args.out).stat().st_size

    print(f"rep{rep}: cap={t_capture*1000:6.0f}ms "
          f"npy={t_npy*1000:5.0f}ms ({npy_sz/1e6:.1f}MB) "
          f"bin2={t_bin*1000:5.0f}ms "
          f"fits.fz={t_fits*1000:5.0f}ms ({fits_sz/1e6:.2f}MB) "
          f"TOTAL={(t_capture+t_npy+t_bin+t_fits)*1000:.0f}ms")

cam.stop()
Path("/tmp/bench.npy").unlink(missing_ok=True)
