# Source this file to enter "astro mode":
#   source ~/astro/activate
#
# Activates the astro venv and puts ~/astro/bin on PATH.

if [ -n "${BASH_SOURCE[0]}" ] && [ "${BASH_SOURCE[0]}" = "$0" ]; then
    echo "astro: this file must be sourced, not executed" >&2
    echo "  source ~/astro/activate" >&2
    exit 1
fi

_astro_root="$HOME/astro"

if [ ! -f "$_astro_root/.venv/bin/activate" ]; then
    echo "astro: no venv at $_astro_root/.venv — create one with:" >&2
    echo "  python3 -m venv $_astro_root/.venv && \\" >&2
    echo "  source $_astro_root/.venv/bin/activate && \\" >&2
    echo "  pip install -r $_astro_root/requirements.txt" >&2
    unset _astro_root
    return 1
fi

# shellcheck disable=SC1091
source "$_astro_root/.venv/bin/activate"

case ":$PATH:" in
    *":$_astro_root/bin:"*) ;;
    *) export PATH="$_astro_root/bin:$PATH" ;;
esac

unset _astro_root

# STARCAM_ROOT autodetect: NFS mount on pip, local path on puppy/muppet.
if [ -d /mnt/puppy/starcam-frames/night ]; then
    export STARCAM_ROOT=/mnt/puppy/starcam-frames/night
elif [ -d "$HOME/starcam-frames/night" ]; then
    export STARCAM_ROOT="$HOME/starcam-frames/night"
fi

# cdd — cd into today's noon-rollover night dir and export $CDD.
# Before noon local time, "today" is yesterday's date (the night that
# started before midnight). Per ~/astro/CLAUDE.md noon-noon rollover.
cdd() {
    local night
    night=$(date +%H 2>/dev/null)
    if [ "$night" -lt 12 ] 2>/dev/null; then
        night=$(date -d 'yesterday' +%Y-%m-%d)
    else
        night=$(date +%Y-%m-%d)
    fi
    if [ -z "$STARCAM_ROOT" ]; then
        echo "cdd: no STARCAM_ROOT set" >&2
        return 1
    fi
    export CDD="$STARCAM_ROOT/$night"
    if [ ! -d "$CDD" ]; then
        echo "cdd: no night dir at $CDD" >&2
        return 1
    fi
    cd "$CDD" || return 1
    echo "cdd → $CDD"
}

echo "astro mode: venv active, ~/astro/bin on PATH"
[ -n "$STARCAM_ROOT" ] && echo "  STARCAM_ROOT=$STARCAM_ROOT  (cdd: today's night dir)"
